<script>
// ── CLOCK
function tick() {
  const n = new Date();
  const p = v => String(v).padStart(2,'0');
  document.getElementById('clock').textContent = p(n.getUTCHours())+':'+p(n.getUTCMinutes())+':'+p(n.getUTCSeconds())+' UTC';
}
setInterval(tick, 1000); tick();

// ── TAB SWITCHING
document.querySelectorAll('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById(tab.dataset.view).classList.add('active');
  });
});

// ── CONTEXT TABS
document.querySelectorAll('.ctx-tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.ctx-tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
  });
});

// ── NAV ITEMS
document.querySelectorAll('.nav-item').forEach(n => {
  n.addEventListener('click', () => {
    document.querySelectorAll('.nav-item').forEach(x => x.classList.remove('active'));
    n.classList.add('active');
  });
});

// ── OVERVIEW → ASK AI shortcut
function goAskAI(q) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelector('[data-view="v-askai"]').classList.add('active');
  document.getElementById('v-askai').classList.add('active');
  if (q && q.trim()) {
    document.getElementById('ai-input').value = q;
    setTimeout(sendMessage, 200);
  }
}

// ── AUDIT CARD TOGGLE
function toggleAudit(card) {
  const isOpen = card.classList.contains('open');
  document.querySelectorAll('.audit-card').forEach(c => c.classList.remove('open'));
  if (!isOpen) card.classList.add('open');
}

// ── FILE UPLOAD
const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');
const fqList = document.getElementById('fq-list');
const fqEmpty = document.getElementById('fq-empty');
const analyzeBtn = document.getElementById('analyze-btn');
const analyzeNote = document.getElementById('analyze-note');
let uploadedFiles = [];

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag');
  handleFiles(Array.from(e.dataTransfer.files));
});
fileInput.addEventListener('change', () => handleFiles(Array.from(fileInput.files)));

function handleFiles(files) {
  files.forEach(file => {
    if (uploadedFiles.find(f => f.name === file.name)) return;
    uploadedFiles.push(file);
    renderFile(file);
  });
  updateQueueState();
}

function renderFile(file) {
  fqEmpty.style.display = 'none';
  const ext = file.name.split('.').pop().toUpperCase();
  const icons = { PDF:'📄', CSV:'📊', XLSX:'📊', XLS:'📊', TXT:'📝' };
  const icon = icons[ext] || '📁';
  const size = file.size > 1024*1024 ? (file.size/1024/1024).toFixed(1)+' MB' : (file.size/1024).toFixed(0)+' KB';
  const id = 'fq-' + Date.now() + Math.random().toString(36).slice(2,6);
  const item = document.createElement('div');
  item.className = 'fq-item'; item.id = id;
  item.innerHTML = `
    <div class="fq-icon">${icon}</div>
    <div class="fq-info">
      <div class="fq-name">${file.name}</div>
      <div class="fq-meta">${ext} · ${size}</div>
      <div class="fq-prog"><div class="fq-prog-fill" style="width:0%" id="prog-${id}"></div></div>
    </div>
    <div class="fq-status ready" id="status-${id}">READY</div>
    <div class="fq-remove" onclick="removeFile('${id}','${file.name}')">✕</div>
  `;
  fqList.appendChild(item);
  setTimeout(() => { document.getElementById('prog-'+id).style.width = '100%'; }, 100);
}

function removeFile(id, name) {
  uploadedFiles = uploadedFiles.filter(f => f.name !== name);
  const el = document.getElementById(id);
  if (el) el.remove();
  if (!uploadedFiles.length) fqEmpty.style.display = '';
  updateQueueState();
}

