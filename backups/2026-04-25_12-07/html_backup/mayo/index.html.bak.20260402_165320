function appendMsg(role, text) {
  const isAI = role === 'ai';
  const div = document.createElement('div');
  div.className = 'msg ' + role;
  // Format AI responses with basic markdown-ish rendering
  let formatted = text
    .replace(/\*\*(.*?)\*\*/g, '<strong style="color:var(--bright)">$1</strong>')
    .replace(/\n\n/g, '<br><br>')
    .replace(/\n/g, '<br>')
    .replace(/^- (.*)/gm, '▸ $1');
  div.innerHTML = `
    <div class="msg-avatar">${isAI ? '🧠' : '👤'}</div>
    <div class="msg-body">
      <div class="msg-label">${isAI ? 'SOVEREIGN STRATEGIST' : 'YOU'}</div>
