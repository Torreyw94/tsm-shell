<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TSM | Healthcare Command Phase 1</title>
  <style>
    :root{
      --bg:#030812;
      --panel:#07111c;
      --panel2:#0a1623;
      --line:#173149;
      --text:#d8ebff;
      --muted:#7ea8ca;
      --cyan:#00d9ff;
      --green:#00ff9c;
      --yellow:#ffd84d;
      --orange:#ff9a1f;
      --red:#ff5c7a;
      --purple:#b268ff;
      --pink:#ff5fd2;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      background:var(--bg);
      color:var(--text);
      font-family:Arial,sans-serif;
    }
    .topbar{
      display:grid;
      grid-template-columns:320px 1fr 320px;
      gap:12px;
      align-items:center;
      padding:12px 16px 8px;
      border-bottom:1px solid var(--line);
      background:#04101a;
    }
    .brand{
      font-weight:800;
      letter-spacing:.14em;
      text-transform:uppercase;
      font-size:18px;
    }
    .brand small{
      display:block;
      color:var(--muted);
      font-size:10px;
      margin-top:4px;
      letter-spacing:.2em;
    }
    .tabs,.pills,.chips{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }
    .tab,.pill,.chip,.btn,.tool{
      border:1px solid var(--line);
      background:#081522;
      color:var(--text);
      padding:7px 10px;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.14em;
      cursor:pointer;
    }
    .tab.active,.chip.active{border-color:#f4b63f;color:#f4b63f}
    .pill.green{color:var(--green)}
    .pill.blue{color:var(--cyan)}
    .pill.yellow{color:var(--yellow)}
    .kpis{
      display:grid;
      grid-template-columns:repeat(7,1fr);
      border-bottom:1px solid var(--line);
      background:#040b12;
    }
    .kpi{
      padding:8px 12px 10px;
      border-right:1px solid rgba(255,255,255,.05);
      min-height:70px;
    }
    .kpi:last-child{border-right:0}
    .kpi .v{font-size:28px;font-weight:800}
    .kpi .l{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.16em;margin-top:4px}
    .kpi .s{font-size:10px;color:#8ad9f0;margin-top:3px}
    .ticker{
      height:28px;
      display:flex;
      align-items:center;
      overflow:hidden;
      padding:0 10px;
      border-bottom:1px solid var(--line);
      color:#f4b63f;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.15em;
      background:#03080f;
    }
    .shell{
      display:grid;
      grid-template-columns:168px 1fr 300px;
      min-height:calc(100vh - 150px);
    }
    .left,.right{
      background:#030912;
    }
    .left{border-right:1px solid var(--line)}
    .right{border-left:1px solid var(--line);display:flex;flex-direction:column}
    .section{
      padding:12px 10px 10px;
      border-bottom:1px solid rgba(255,255,255,.04);
    }
    .title{
      font-size:10px;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.24em;
      margin-bottom:8px;
    }
    .nav{
      display:flex;
      justify-content:space-between;
      padding:7px 6px;
      margin-bottom:2px;
      font-size:11px;
      color:#8fb5d3;
      border-left:2px solid transparent;
    }
    .nav.active{border-left-color:var(--cyan);background:rgba(0,217,255,.05);color:#fff}
    .stat{
      display:flex;
      justify-content:space-between;
      font-size:10px;
      color:#8fb5d3;
      margin-bottom:6px;
      text-transform:uppercase;
    }
    .main{
      display:grid;
      grid-template-rows:auto auto 1fr auto;
    }
    .command{
      padding:12px 12px 8px;
      border-bottom:1px solid rgba(255,255,255,.04);
      background:#040c15;
    }
    .directive{
      display:grid;
      grid-template-columns:1fr 116px 116px;
      gap:10px;
      margin-top:8px;
    }
    input{
      width:100%;
      background:#02070c;
      border:1px solid var(--line);
      color:#fff;
      padding:10px 12px;
      font-size:12px;
      outline:none;
    }
    .deploy{border-color:#f4b63f;color:#f4b63f}
    .synth{border-color:var(--purple);color:var(--purple)}
    .tools{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      padding:10px 12px;
      border-bottom:1px solid rgba(255,255,255,.04);
      background:#050d17;
    }
    .grid{
      display:grid;
      grid-template-columns:repeat(5,minmax(0,1fr));
      border-top:1px solid var(--line);
      border-left:1px solid var(--line);
    }
    .card{
      min-height:255px;
      background:#07101b;
      border-right:1px solid var(--line);
      border-bottom:1px solid var(--line);
      padding:10px;
      display:flex;
      flex-direction:column;
      gap:8px;
    }
    .head{
      display:flex;
      justify-content:space-between;
      font-size:9px;
      text-transform:uppercase;
      letter-spacing:.18em;
    }
    .live{color:var(--green)}
    .port{color:var(--muted)}
    .ctitle{
      font-size:20px;
      font-weight:800;
      text-transform:uppercase;
    }
    .desc{
      font-size:10px;
      color:var(--muted);
      min-height:28px;
    }
    .bar{
      height:4px;
      background:rgba(255,255,255,.08);
      position:relative;
      overflow:hidden;
    }
    .bar span{
      position:absolute;
      inset:0 auto 0 0;
      width:0%;
      background:var(--cyan);
    }
    .out{
      flex:1;
      background:rgba(0,0,0,.18);
      border:1px solid rgba(255,255,255,.04);
      padding:8px;
      font-size:11px;
      line-height:1.45;
      color:#bfd6eb;
      white-space:pre-wrap;
      overflow:auto;
    }
    .foot{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:8px;
      font-size:9px;
      text-transform:uppercase;
      color:var(--muted);
    }
    .open{
      border:1px solid var(--purple);
      color:var(--purple);
      background:transparent;
      padding:6px 8px;
      font-size:9px;
      text-transform:uppercase;
      letter-spacing:.16em;
    }
    .rec{
      border-top:1px solid var(--line);
      background:#030912;
      padding:10px 12px 12px;
      min-height:150px;
    }
    .rec-title{
      font-size:11px;
      color:var(--purple);
      text-transform:uppercase;
      letter-spacing:.22em;
      margin-bottom:8px;
    }
    .rec-body{
      min-height:104px;
      font-size:11px;
      color:#a4c2dd;
      line-height:1.55;
      white-space:pre-wrap;
    }
    .r-top{padding:12px;border-bottom:1px solid rgba(255,255,255,.04)}
    .r-title{font-size:18px;font-weight:800;color:#ff70d4;letter-spacing:.08em}
    .r-sub{margin-top:4px;color:var(--muted);font-size:10px;line-height:1.5;text-transform:uppercase}
    .r-chips{display:flex;flex-wrap:wrap;gap:6px;padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.04)}
    .r-stream{flex:1;padding:12px;font-size:11px;color:#9fc2df;line-height:1.6;white-space:pre-wrap;overflow:auto;min-height:220px}
    .next{margin:0 12px 12px;border:1px solid rgba(255,95,210,.4);background:rgba(255,95,210,.04);padding:10px}
    .next .l{font-size:10px;text-transform:uppercase;letter-spacing:.18em;color:#ff70d4;margin-bottom:6px}
    .next .b{font-size:11px;color:#fff;line-height:1.55;white-space:pre-wrap}
    .r-actions{display:grid;grid-template-columns:1fr 88px;gap:8px;padding:0 12px 12px}
    .risk{border:1px solid var(--cyan);background:rgba(0,217,255,.06);color:var(--cyan);text-transform:uppercase;letter-spacing:.14em;font-size:10px}
    @media (max-width:1320px){
      .grid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .kpis{grid-template-columns:repeat(3,1fr)}
    }
  
    .playbook-tab{cursor:pointer;user-select:none;pointer-events:auto;position:relative;z-index:5}
    .playbook-tab:hover{background:rgba(0,217,255,.06)}
    .playbook-tab.active{border-left-color:var(--cyan)!important;background:rgba(0,217,255,.08)!important;color:#fff!important}
  
    .left,.section,.nav,.playbook-tab,.btn,.tool,.chip,.tab,.tiny-btn,.risk,.open{
      position:relative !important;
      z-index:3012 !important;
      pointer-events:auto !important;
    }
    .main,.right,.ticker,.severity-banner,.topbar,.shell{
      position:relative;
      z-index:1;
    }
    iframe, canvas{
      pointer-events:none !important;
    }
    #clickDebug{
      position:fixed;
      bottom:10px;
      right:10px;
      z-index:10000;
      background:#08111b;
      color:#7eeaff;
      border:1px solid #173149;
      padding:6px 8px;
      font-size:10px;
      letter-spacing:.12em;
      text-transform:uppercase;
    }
  
    .severity-banner{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:10px 12px;
      border-bottom:1px solid rgba(255,255,255,.05);
      background:#07111c;
    }
    .severity-main{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }
    .severity-badge{
      padding:6px 10px;
      border:1px solid #173149;
      font-size:10px;
      letter-spacing:.16em;
      text-transform:uppercase;
      font-weight:700;
    }
    .severity-badge.low{color:#7eeaff;border-color:#7eeaff}
    .severity-badge.moderate{color:#ffd84d;border-color:#ffd84d}
    .severity-badge.high{color:#ff9a1f;border-color:#ff9a1f}
    .severity-badge.critical{color:#ff5c7a;border-color:#ff5c7a}
    .severity-text{
      color:#cfe4f7;
      font-size:11px;
      line-height:1.4;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:780px;
    }
    .quick-runs{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      padding:8px 12px 10px;
      border-bottom:1px solid rgba(255,255,255,.04);
      background:#06111b;
    }
    .quick-btn, .bnca-btn{
      border:1px solid #173149;
      background:#091521;
      color:#d8ebff;
      padding:7px 10px;
      font-size:10px;
      letter-spacing:.14em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .quick-btn:hover, .bnca-btn:hover{border-color:#00d9ff}
    .action-stack{
      display:grid;
      gap:8px;
      padding:0 12px 12px;
    }
    .action-row{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:8px;
    }
    .top-issue-box{
      margin:0 12px 12px;
      border:1px solid rgba(255,92,122,.28);
      background:rgba(255,92,122,.05);
      padding:10px;
    }
    .top-issue-box .label{
      font-size:10px;
      color:#ff5c7a;
      letter-spacing:.18em;
      text-transform:uppercase;
      margin-bottom:6px;
    }
    .top-issue-box .body{
      font-size:11px;
      color:#fff;
      line-height:1.5;
      white-space:pre-wrap;
    }
  
.playbook-btn-fixed{
  position:fixed;
  bottom:20px; max-width:220px;
  right:20px;
  z-index:50; /* LOWER than overlay + panels */
}

@media (min-width: 1200px){
  .playbook-btn-fixed{
    right:260px; /* clears right strategist panel */
  }
}

    .docked-rail{
      position:fixed;
      top:110px;
      right:12px;
      width:240px;
      z-index:70;
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .docked-rail.collapsed{
      width:54px;
    }
    .docked-card{
      background:#07111c;
      border:1px solid #173149;
      padding:10px;
      box-shadow:0 0 0 1px rgba(0,217,255,.05) inset;
    }
    .docked-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:8px;
      color:#ffd84d;
      font-size:10px;
      letter-spacing:.18em;
      text-transform:uppercase;
      margin-bottom:8px;
    }
    .docked-toggle{
      border:1px solid #173149;
      background:#091521;
      color:#7eeaff;
      padding:4px 6px;
      font-size:10px;
      cursor:pointer;
    }
    .docked-body{
      color:#d8ebff;
      font-size:11px;
      line-height:1.5;
      white-space:pre-wrap;
    }
    .docked-actions{
      display:grid;
      gap:8px;
    }
    .docked-btn{
      border:1px solid #173149;
      background:#091521;
      color:#d8ebff;
      padding:8px 10px;
      font-size:10px;
      letter-spacing:.14em;
      text-transform:uppercase;
      cursor:pointer;
      width:100%;
      text-align:left;
    }
    .docked-btn:hover{border-color:#00d9ff}
    .docked-rail.collapsed .docked-body,
    .docked-rail.collapsed .docked-actions,
    .docked-rail.collapsed .docked-card:not(:first-child){
      display:none;
    }
    .docked-rail.collapsed .docked-card:first-child{
      padding:8px;
    }
    .docked-pill{
      display:inline-block;
      padding:4px 6px;
      border:1px solid rgba(255,255,255,.14);
      font-size:9px;
      text-transform:uppercase;
      letter-spacing:.16em;
      color:#7eeaff;
      margin-top:4px;
    }
    @media (max-width: 1200px){
      .docked-rail{
        top:auto;
        bottom:20px;
        right:20px;
        width:220px;
      }
    }
  
.rail-tab{
  position:fixed;
  top:160px;
  right:0;
  z-index:80;
  background:#07111c;
  border:1px solid #00d9ff;
  border-right:none;
  padding:10px 6px;
  font-size:10px;
  letter-spacing:.2em;
  writing-mode:vertical-rl;
  text-orientation:mixed;
  cursor:pointer;
  color:#00d9ff;
}
.docked-rail.collapsed{
  transform:translateX(100%);
}

.rail-tab.alerting{
  border-color:#ff5c7a !important;
  color:#ff5c7a !important;
  box-shadow:0 0 12px rgba(255,92,122,.45);
}

</style>


  <link rel="stylesheet" href="/overlay/overlay.css">
</head>
<body>
  <div class="topbar">
    <div class="brand">
      TSM | Healthcare Command
      <small>Tripartite Health Intelligence System · TSMatter</small>
    </div>
    <div class="tabs">
      <button class="tab active">MED-CORE</button>
      <button class="tab">RX-INTEL</button>
      <button class="tab">PAYOR</button>
      <button class="tab">COMPLIANCE</button>
      <button class="tab">BILLING</button>
      <button class="tab">STRATEGIST</button>
    </div>
    <div class="pills" style="justify-content:flex-end">
      <span class="pill green">HC-Strategist Online</span>
      <span class="pill blue">10-Node Fleet</span>
      <span class="pill yellow">HonorHealth Demo</span>
      <span class="pill" id="clock">UTC --:--:--</span>
    </div>
  </div>

  <div class="kpis" id="kpis"></div>
  <div class="ticker" id="ticker"></div>
  <div class="severity-banner" id="severityBanner">
    <div class="severity-main">
      <div class="severity-badge low" id="severityBadge">LOW</div>
      <div class="severity-text" id="severityText">No active alert yet.</div>
    </div>
    <div class="severity-main" style="justify-content:flex-end;">
      <button class="quick-btn" id="refreshEngineBtn" type="button">Refresh Engine</button>
    </div>
  </div>

  <div class="shell">
    <aside class="left">
      <div class="section">
        <div class="title">Playbooks</div>
        <div class="playbook-btn-fixed" data-playbook="claim-recovery"><span>Claim Recovery</span><span>●</span></div>
        <div class="playbook-btn-fixed" data-playbook="audit-sweep"><span>Audit Sweep</span><span>236k</span></div>
        <div class="playbook-btn-fixed" data-playbook="margin-review"><span>Margin Review</span><span>LOW</span></div>
        <div class="playbook-btn-fixed" data-playbook="payer-contract-review"><span>Payer Contract Review</span><span>APR 15</span></div>
        <div class="playbook-btn-fixed" data-playbook="vendor-supply-risk"><span>Vendor / Supply Risk</span><span>2</span></div>
        <div class="playbook-btn-fixed" data-playbook="cash-flow"><span>Cash Flow</span><span>71%</span></div>
        <div class="playbook-btn-fixed" data-playbook="tax-sweep"><span>Tax Sweep</span><span>$177k</span></div>
        <div class="playbook-btn-fixed" data-playbook="bmca"><span>BMCA</span><span>BEST</span></div>
      </div>
      <div class="section">
        <div class="title">Enterprise</div>
        <div class="playbook-btn-fixed" data-playbook="executive-brief"><span>Executive Brief</span><span>READY</span></div>
        <div class="playbook-btn-fixed" data-playbook="capacity-throughput"><span>Capacity / Throughput</span><span>+18%</span></div>
        <div class="playbook-btn-fixed" data-playbook="staff-vendor-roi"><span>Staff / Vendor ROI</span><span>LIVE</span></div>
      </div>
      <div class="section">
        <div class="title">System</div>
        <div class="stat"><span>Uplink</span><span style="color:var(--green)">Active</span></div>
        <div class="stat"><span>Nodes Online</span><span style="color:var(--cyan)">10 / 10</span></div>
        <div class="stat"><span>AI Core</span><span style="color:var(--purple)">HC-Strategist</span></div>
        <div class="stat"><span>Last Synthesis</span><span id="lastRun">Pending</span></div>
      </div>
    </aside>

    <main class="main">
      <div class="command">
        <div class="quick-runs" id="quickRuns">
          <button class="quick-btn" type="button" data-quick="revenue">Revenue Risk</button>
          <button class="quick-btn" type="button" data-quick="denials">Denial Recovery</button>
          <button class="quick-btn" type="button" data-quick="compliance">Compliance Audit</button>
          <button class="quick-btn" type="button" data-quick="executive">Executive Brief</button>
        </div>
        <div class="title">Deploy Query To Nodes</div>
        <div class="chips" id="chips"></div>
        <div class="directive">
          <input id="directive" value="Review denial exposure, claims backlog, compliance drift, and produce the best next course of action across the full healthcare command." />
          <button class="btn deploy" id="deploy">Deploy</button>
          <button class="btn synth" id="synth">Synthesize</button>
        </div>
      </div>

      <div class="tools">
        <button class="tool">Upload Document</button>
        <button class="tool">Full Analysis</button>
        <button class="tool">Extract</button>
        <button class="tool">Compliance Scan</button>
        <button class="tool">Financial Extract</button>
        <button class="tool">Exec Summary</button>
      </div>

      <section class="grid" id="grid"></section>

      <section class="rec">
        <div class="rec-title">Unified Command Recommendation</div>
        <div class="rec-body" id="recBody">Awaiting deploy.</div>
      </section>
    </main>

    <aside class="right">
      <div class="r-top">
        <div class="r-title">Sovereign HC-Strategist</div>
        <div class="r-sub">Best next course of action · healthcare intelligence synthesis</div>
      </div>
      <div class="r-chips" id="rchips"></div>
      <div class="r-stream" id="stream">HC-Strategist initialized. Deploy a command to generate merged healthcare recommendations.</div>
      <div class="next">
        <div class="l">Best Next Course Of Action</div>
        <div class="b" id="nextBody">No strategist recommendation yet.</div>
      </div>
      
      
      <div class="r-actions">
        <input value="Ask the strategist..." />
        <button class="risk" id="risk">Risk</button>
      </div>
    </aside>
  </div>

  

<div id="clickDebug">UI Ready</div>










<!-- SAFE OVERLAY -->
<style>
.help-btn{position:fixed;bottom:20px; max-width:220px;left:20px;z-index:30129;
background:#0b1622;border:1px solid #1f3a52;color:#7eeaff;
padding:10px;cursor:pointer;}
.help-modal{position:fixed;inset:0;background:rgba(0,0,0,.85);
display:none;align-items:center;justify-content:center;z-index:30128;}
.help-box{width:600px;background:#07111c;border:1px solid #1f3a52;padding:20px;}

    .severity-banner{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:10px 12px;
      border-bottom:1px solid rgba(255,255,255,.05);
      background:#07111c;
    }
    .severity-main{
      display:flex;
      align-items:center;
      gap:10px;
      min-width:0;
    }
    .severity-badge{
      padding:6px 10px;
      border:1px solid #173149;
      font-size:10px;
      letter-spacing:.16em;
      text-transform:uppercase;
      font-weight:700;
    }
    .severity-badge.low{color:#7eeaff;border-color:#7eeaff}
    .severity-badge.moderate{color:#ffd84d;border-color:#ffd84d}
    .severity-badge.high{color:#ff9a1f;border-color:#ff9a1f}
    .severity-badge.critical{color:#ff5c7a;border-color:#ff5c7a}
    .severity-text{
      color:#cfe4f7;
      font-size:11px;
      line-height:1.4;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:780px;
    }
    .quick-runs{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      padding:8px 12px 10px;
      border-bottom:1px solid rgba(255,255,255,.04);
      background:#06111b;
    }
    .quick-btn, .bnca-btn{
      border:1px solid #173149;
      background:#091521;
      color:#d8ebff;
      padding:7px 10px;
      font-size:10px;
      letter-spacing:.14em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .quick-btn:hover, .bnca-btn:hover{border-color:#00d9ff}
    .action-stack{
      display:grid;
      gap:8px;
      padding:0 12px 12px;
    }
    .action-row{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:8px;
    }
    .top-issue-box{
      margin:0 12px 12px;
      border:1px solid rgba(255,92,122,.28);
      background:rgba(255,92,122,.05);
      padding:10px;
    }
    .top-issue-box .label{
      font-size:10px;
      color:#ff5c7a;
      letter-spacing:.18em;
      text-transform:uppercase;
      margin-bottom:6px;
    }
    .top-issue-box .body{
      font-size:11px;
      color:#fff;
      line-height:1.5;
      white-space:pre-wrap;
    }
  
.playbook-btn-fixed{
  position:fixed;
  bottom:20px; max-width:220px;
  right:20px;
  z-index:50; /* LOWER than overlay + panels */
}

@media (min-width: 1200px){
  .playbook-btn-fixed{
    right:260px; /* clears right strategist panel */
  }
}

    .docked-rail{
      position:fixed;
      top:110px;
      right:12px;
      width:240px;
      z-index:70;
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .docked-rail.collapsed{
      width:54px;
    }
    .docked-card{
      background:#07111c;
      border:1px solid #173149;
      padding:10px;
      box-shadow:0 0 0 1px rgba(0,217,255,.05) inset;
    }
    .docked-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:8px;
      color:#ffd84d;
      font-size:10px;
      letter-spacing:.18em;
      text-transform:uppercase;
      margin-bottom:8px;
    }
    .docked-toggle{
      border:1px solid #173149;
      background:#091521;
      color:#7eeaff;
      padding:4px 6px;
      font-size:10px;
      cursor:pointer;
    }
    .docked-body{
      color:#d8ebff;
      font-size:11px;
      line-height:1.5;
      white-space:pre-wrap;
    }
    .docked-actions{
      display:grid;
      gap:8px;
    }
    .docked-btn{
      border:1px solid #173149;
      background:#091521;
      color:#d8ebff;
      padding:8px 10px;
      font-size:10px;
      letter-spacing:.14em;
      text-transform:uppercase;
      cursor:pointer;
      width:100%;
      text-align:left;
    }
    .docked-btn:hover{border-color:#00d9ff}
    .docked-rail.collapsed .docked-body,
    .docked-rail.collapsed .docked-actions,
    .docked-rail.collapsed .docked-card:not(:first-child){
      display:none;
    }
    .docked-rail.collapsed .docked-card:first-child{
      padding:8px;
    }
    .docked-pill{
      display:inline-block;
      padding:4px 6px;
      border:1px solid rgba(255,255,255,.14);
      font-size:9px;
      text-transform:uppercase;
      letter-spacing:.16em;
      color:#7eeaff;
      margin-top:4px;
    }
    @media (max-width: 1200px){
      .docked-rail{
        top:auto;
        bottom:20px;
        right:20px;
        width:220px;
      }
    }
  
.rail-tab{
  position:fixed;
  top:160px;
  right:0;
  z-index:80;
  background:#07111c;
  border:1px solid #00d9ff;
  border-right:none;
  padding:10px 6px;
  font-size:10px;
  letter-spacing:.2em;
  writing-mode:vertical-rl;
  text-orientation:mixed;
  cursor:pointer;
  color:#00d9ff;
}
.docked-rail.collapsed{
  transform:translateX(100%);
}
</style>



<button class="help-btn" onclick="document.getElementById('hm').style.display='flex'">HOW TO</button>

<div class="help-modal" id="hm">
<div class="help-box">
<h3>How To Use</h3>
<p>1. Choose Quick Run</p>
<p>2. Click Deploy</p>
<p>3. Follow Strategist</p>
<button onclick="document.getElementById('hm').style.display='none'">Close</button>
</div>
</div>

  




<div class="docked-rail" id="dockedRail">
  <div class="docked-card">
    <div class="docked-header">
      <span>Action Rail</span>
      <button class="docked-toggle" id="dockedToggle" type="button">Collapse</button>
    </div>
    <div class="docked-body" id="dockedPlaybookBody">Playbook: Claim Recovery</div>
    <div class="docked-pill" id="dockedPlaybookTag">Active Playbook</div>
  </div>

  <div class="docked-card">
    <div class="docked-header"><span>BNCA Actions</span></div>
    <div class="docked-actions">
      <button class="docked-btn" id="railAction1" type="button">Launch Denial Sprint</button>
      <button class="docked-btn" id="railAction2" type="button">Run Coding Audit</button>
      <button class="docked-btn" id="railAction3" type="button">Trigger Compliance Review</button>
    </div>
  </div>

  <div class="docked-card">
    <div class="docked-header"><span>Alerts</span></div>
    <div class="docked-body" id="dockedAlertBody">No active alert.</div>
  </div>
</div>








<div id="railTab" class="rail-tab">ACTION</div>







<script>
console.log("TSM HC COMMAND ENGINE LOADED");

// ── NODE DEFINITIONS ─────────────────────────────────────────────────────────
const HC_NODES = [
  {
    id:'med-core', title:'MED-CORE', port:'3012',
    color:'#00d9ff',
    desc:'Clinical intelligence · Diagnosis coding · Treatment protocols · CMS guidelines',
    sys:'You are the TSM MED-CORE intelligence node — expert in clinical documentation, ICD-10/CPT coding accuracy, treatment protocol compliance, CMS clinical guidelines, prior authorization medical necessity, and clinical denial appeals. Provide specific, actionable, dollar-focused analysis.'
  },
  {
    id:'rx-intel', title:'RX-INTEL', port:'3012',
    color:'#7eeaff',
    desc:'Pharmacy benefits · Formulary · Drug utilization · 340B · PBM analysis',
    sys:'You are the TSM RX-INTEL node — expert in pharmacy benefit management, formulary optimization, 340B drug pricing program compliance, PBM contract analysis, drug utilization review, and specialty pharmacy cost management. Provide dollar-specific analysis.'
  },
  {
    id:'payor', title:'PAYOR', port:'3012',
    color:'#ffd84d',
    desc:'Payor contracts · Reimbursement · Network adequacy · Fee schedules',
    sys:'You are the TSM Payor Intelligence node — expert in payor contract negotiation, fee schedule analysis, network adequacy compliance, reimbursement rate benchmarking, COB coordination, and payor-specific denial patterns. Identify dollar recovery opportunities.'
  },
  {
    id:'compliance', title:'COMPLIANCE', port:'3017',
    color:'#a78bfa',
    desc:'HIPAA · OIG · Stark Law · Anti-kickback · CMS conditions of participation',
    sys:'You are the TSM Healthcare Compliance node — expert in HIPAA Privacy/Security, OIG exclusion screening, Stark Law, Anti-Kickback Statute, CMS Conditions of Participation, EMTALA, and healthcare fraud/waste/abuse. Quantify penalty exposure in dollars.'
  },
  {
    id:'billing', title:'BILLING', port:'3012',
    color:'#00e676',
    desc:'Revenue cycle · Claims · Denial management · AR · Coding audit',
    sys:'You are the TSM Billing Intelligence node — expert in revenue cycle management, claims adjudication, denial root cause analysis, AR aging optimization, CPT/ICD-10 coding audits, upcoding/undercoding risk, and timely filing compliance. Dollar recovery focus.'
  },
  {
    id:'strategist', title:'STRATEGIST', port:'3001',
    color:'#ff5c7a',
    desc:'Cross-node synthesis · BNCA · Executive intelligence · Risk matrix',
    sys:'You are the TSM HC-Strategist — cross-vertical healthcare intelligence synthesizer. Produce: EXECUTIVE SUMMARY, CRITICAL RISKS (ranked by dollar exposure), IMMEDIATE ACTIONS (30 days), BNCA — single best action right now. Be decisive and dollar-focused.'
  }
];

// ── RESPONSE NORMALIZER ───────────────────────────────────────────────────────
function normalizeResponse(d, raw){
  return d?.choices?.[0]?.message?.content ||
         d?.response || d?.answer || d?.content ||
         d?.analysis || d?.summary || raw || 'No response';
}

// ── RENDER NODE GRID ─────────────────────────────────────────────────────────
function renderGrid(){
  const grid = document.getElementById('grid');
  if(!grid) return;
  grid.innerHTML = HC_NODES.map(n => `
    <div class="card" id="card-${n.id}">
      <div class="head">
        <span class="live" id="status-${n.id}">● STANDBY</span>
        <span class="port">:${n.port}</span>
      </div>
      <div class="ctitle" style="color:${n.color}">${n.title}</div>
      <div class="desc">${n.desc}</div>
      <div class="bar"><span id="bar-${n.id}" style="background:${n.color}"></span></div>
      <div class="out" id="out-${n.id}">Awaiting directive deployment...</div>
      <div class="foot">
        <span id="wc-${n.id}">0 words</span>
        <button class="open" onclick="window.open('https://healthcare.tsmatter.com','_blank')" style="font-size:9px;padding:2px 7px;border:1px solid rgba(255,255,255,.12);background:transparent;color:#7eeaff;cursor:pointer;letter-spacing:.1em;text-transform:uppercase;">OPEN ↗</button>
      </div>
    </div>`).join('');
}

// ── RENDER CHIPS ─────────────────────────────────────────────────────────────
function renderChips(){
  const chips = document.getElementById('chips');
  if(!chips) return;
  chips.innerHTML = HC_NODES.map(n => `
    <span class="chip active" data-node="${n.id}" onclick="toggleChip(this)"
      style="border-color:${n.color};color:${n.color};background:${n.color}18;
      padding:4px 10px;font-size:9px;letter-spacing:.12em;text-transform:uppercase;
      cursor:pointer;border:1px solid;border-radius:1px;transition:all .15s;">
      ${n.title}
    </span>`).join('');
}

function toggleChip(el){
  el.classList.toggle('active');
  el.style.opacity = el.classList.contains('active') ? '1' : '0.3';
}

function getActiveNodes(){
  return Array.from(document.querySelectorAll('.chip.active')).map(c=>c.dataset.node);
}

// ── SET NODE STATUS ───────────────────────────────────────────────────────────
function setNodeStatus(id, status, text){
  const statusEl = document.getElementById('status-'+id);
  const barEl = document.getElementById('bar-'+id);
  const outEl = document.getElementById('out-'+id);
  const node = HC_NODES.find(n=>n.id===id);
  if(statusEl){
    statusEl.textContent = status==='firing'?'● FIRING...':status==='done'?'● COMPLETE':status==='err'?'● ERROR':'● STANDBY';
    statusEl.style.color = status==='firing'?'#ffd84d':status==='done'?(node?.color||'#00e676'):status==='err'?'#ff5c7a':'#7eeaff';
  }
  if(barEl){
    barEl.style.transition='width 1s ease';
    barEl.style.width = status==='firing'?'60%':status==='done'?'100%':'0%';
  }
  if(text && outEl){
    outEl.textContent = text;
    const words = text.split(/\s+/).filter(Boolean).length;
    const wc = document.getElementById('wc-'+id);
    if(wc) wc.textContent = words+' words';
  }
}

// ── CALL A NODE ───────────────────────────────────────────────────────────────
async function callNode(nodeId, query){
  const node = HC_NODES.find(n=>n.id===nodeId);
  if(!node) return null;
  const url = node.port==='3001' ? '/api/strat-chat' : '/ai/chat';
  setNodeStatus(nodeId, 'firing');
  try{
    const res = await fetch(url, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        messages:[
          {role:'system', content:node.sys},
          {role:'user', content:query}
        ],
        message: query,
        max_tokens:700, temperature:0.4
      })
    });
    if(!res.ok) throw new Error('HTTP '+res.status);
    const raw = await res.text();
    let d={};
    try{d=JSON.parse(raw);}catch(e){d={content:raw};}
    const text = normalizeResponse(d, raw);
    setNodeStatus(nodeId, 'done', text);
    lastOutputs[nodeId] = text;
    return text;
  }catch(err){
    setNodeStatus(nodeId, 'err', '⚠ '+err.message);
    return null;
  }
}

// ── DEPLOY ────────────────────────────────────────────────────────────────────
let lastOutputs = {};

async function deploy(){
  const query = document.getElementById('directive')?.value?.trim();
  if(!query){ alert('Enter a directive first.'); return; }
  const activeNodes = getActiveNodes();
  if(!activeNodes.length){ alert('Select at least one node.'); return; }

  const deployBtn = document.getElementById('deploy');
  if(deployBtn){ deployBtn.disabled=true; deployBtn.textContent='DEPLOYING...'; }
  document.getElementById('recBody').textContent = 'Nodes firing — awaiting results...';

  // Reset all active nodes
  activeNodes.forEach(id=>{
    const outEl=document.getElementById('out-'+id);
    if(outEl) outEl.textContent='Analyzing...';
    setNodeStatus(id,'firing');
  });

  lastOutputs = {};
  const promises = activeNodes.map(id => callNode(id, query));
  await Promise.all(promises);

  if(deployBtn){ deployBtn.disabled=false; deployBtn.textContent='DEPLOY'; }
  document.getElementById('recBody').textContent = 'All nodes complete. Press SYNTHESIZE for unified recommendation.';
}

// ── SYNTHESIZE ────────────────────────────────────────────────────────────────
async function synthesize(){
  const outputs = Object.entries(lastOutputs);
  if(!outputs.length){ alert('Deploy a query first.'); return; }
  const synthBtn = document.getElementById('synth');
  if(synthBtn){ synthBtn.disabled=true; synthBtn.textContent='SYNTHESIZING...'; }
  document.getElementById('recBody').textContent = 'HC-Strategist synthesizing...';

  const context = outputs.map(([id,text])=>{
    const node = HC_NODES.find(n=>n.id===id);
    return `[${node?.title||id.toUpperCase()} NODE]\n${text}`;
  }).join('\n\n---\n\n');

  try{
    const res = await fetch('/api/strat-chat',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        messages:[
          {role:'system',content:'You are the TSM HC-Strategist. Synthesize these healthcare intelligence node outputs into: EXECUTIVE SUMMARY (2-3 sentences), CRITICAL RISKS (top 3, dollar exposure), IMMEDIATE ACTIONS (next 30 days), BNCA — single best action now.'},
          {role:'user',content:context.slice(0,5000)}
        ],
        max_tokens:800, temperature:0.35
      })
    });
    const raw = await res.text();
    let d={};
    try{d=JSON.parse(raw);}catch(e){d={content:raw};}
    const text = normalizeResponse(d,raw);
    document.getElementById('recBody').textContent = text;
    const nextBody = document.getElementById('nextBody');
    if(nextBody) nextBody.textContent = text.split('\n')[0]||text.slice(0,200);
    document.getElementById('stream').textContent = text;
  }catch(err){
    document.getElementById('recBody').textContent = '⚠ Synthesis error: '+err.message;
  }
  if(synthBtn){ synthBtn.disabled=false; synthBtn.textContent='SYNTHESIZE'; }
}

// ── WIRE BUTTONS ─────────────────────────────────────────────────────────────
window.addEventListener('load', ()=>{
  renderGrid();
  renderChips();

  const deployBtn = document.getElementById('deploy');
  const synthBtn = document.getElementById('synth');
  if(deployBtn) deployBtn.addEventListener('click', deploy);
  if(synthBtn) synthBtn.addEventListener('click', synthesize);

  // Tool buttons
  const toolPrompts = {
    'Upload Document':'Analyze uploaded healthcare document for compliance gaps, billing issues, and revenue recovery opportunities.',
    'Full Analysis':'Run a comprehensive healthcare intelligence analysis across all nodes: clinical, payor, billing, compliance, and pharmacy.',
    'Extract':'Extract key data points, metrics, and actionable intelligence from current node outputs.',
    'Compliance Scan':'Run a full compliance scan: HIPAA, OIG, Stark Law, Anti-Kickback, CMS Conditions of Participation.',
    'Financial Extract':'Extract all financial metrics: AR aging, denial rates, revenue recovery opportunities, payor performance.',
    'Exec Summary':'Generate a C-suite executive summary of current healthcare operations, risks, and recommended actions.'
  };
  document.querySelectorAll('.tool').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const prompt = toolPrompts[btn.textContent] || btn.textContent;
      const dir = document.getElementById('directive');
      if(dir) dir.value = prompt;
      deploy();
    });
  });

  // Quick run buttons in right rail
  document.querySelectorAll('.quick-btn, .bnca-btn, .docked-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const dir = document.getElementById('directive');
      if(dir) dir.value = btn.textContent.trim();
      deploy();
    });
  });

  // Clock
  function tick(){
    const n=new Date(),p=v=>String(v).padStart(2,'0');
    const el=document.querySelector('.clock,#clock,[class*=clock]');
    if(el) el.textContent=p(n.getHours())+':'+p(n.getMinutes())+':'+p(n.getSeconds())+' UTC';
  }
  setInterval(tick,1000); tick();
});

console.log("TSM HC COMMAND — GRID ENGINE READY");
</script>

<script id="tsm-unified-render">
function renderTSM(data, target){
  try {
    const el = document.querySelector(target) || document.body;

    if (!data) {
      el.innerHTML = "<div style='color:red'>No data</div>";
      return;
    }

    // Normalize fallback
    if (!data.feed && data.choices) {
      data = {
        report_title: "AI Response",
        kpis: [],
        feed: [{ message: data.choices[0].message.content }]
      };
    }

    if (!data.feed) {
      el.innerHTML = "<pre>" + JSON.stringify(data, null, 2) + "</pre>";
      return;
    }

    let htmlOut = "<div style='padding:12px;font-family:monospace'>";

    if (data.report_title) {
      htmlOut += "<h3 style='color:#00ffc3'>" + data.report_title + "</h3>";
    }

    data.feed.forEach(item => {
      htmlOut += "<div style='margin-bottom:10px'>";
      htmlOut += "<div style='color:#d7f7ff'>" + (item.message || "") + "</div>";
      if (item.detail) {
        htmlOut += "<div style='opacity:0.6;font-size:12px'>" + item.detail + "</div>";
      }
      htmlOut += "</div>";
    });

    htmlOut += "</div>";
    el.innerHTML = htmlOut;

  } catch(e) {
    console.error("Render error", e);
  }
}
</script>

</body>
</html>