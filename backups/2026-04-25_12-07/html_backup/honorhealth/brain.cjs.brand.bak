const DEF={name:'TSM Intelligence',system:'You are a TSM Matter intelligence engine specializing in business operations, compliance, and financial intelligence. All apps $399/mo. Be expert, precise, actionable.'};
app.post('/api/chat',async(req,res)=>{
  const host=(req.headers['host']||'').toLowerCase().split(':')[0];
  const c=CLIENTS[host]||DEF;
  try{
    const r=await axios.post('https://api.groq.com/openai/v1/chat/completions',{model:'llama-3.3-70b-versatile',messages:[{role:'system',content:c.system},...(req.body.messages||[{role:'user',content:req.body.message||'Hello'}])],max_tokens:req.body.max_tokens||1200,temperature:0.4},{headers:{'Authorization':'Bearer '+KEY}});
    const cnt=r.data.choices[0].message.content;
    res.json({success:true,response:cnt,answer:cnt,content:cnt,choices:r.data.choices});
  }catch(e){console.error('WL error:',e.message);res.status(500).json({success:false,error:e.message});}
});
app.get('/health',(req,res)=>{const host=(req.headers['host']||'').toLowerCase().split(':')[0];const c=CLIENTS[host]||DEF;res.json({status:'ok',client:c.name,host});});
app.listen(3093,()=>console.log('TSM Whitelabel multi-tenant brain on 3090'));
