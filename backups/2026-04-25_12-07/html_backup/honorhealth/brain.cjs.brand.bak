const rateLimit = require('express-rate-limit');
const express=require('express');const axios=require('axios');const app=express();app.use(express.json());
const limiter = rateLimit({
  windowMs: 60 * 1000,       // 1 minute window
  max: 20,                    // 20 requests per IP per minute
  standardHeaders: true,
  legacyHeaders: false,
  message: { error: 'Too many requests — slow down and try again in 60 seconds.' }
});
app.use(limiter);

const KEY='GROQ_KEY_REMOVED';
const CLIENTS={
'honorhealth.tsmatter.com':{name:'HonorHealth',system:'You are the dedicated AI engine for HonorHealth Command Center (TSM Matter). HonorHealth: 6 hospitals, 70+ care sites, Phoenix metro, 14,000+ staff. Alerts: 18.4% billing denial rate ($48K stalled), 14 open compliance items, 38 prior auth pending, $840K malpractice matter. Specialize in healthcare revenue cycle, HIPAA/CMS/OIG, CPT/ICD-10, credentialing. All apps $399/mo. Always reference HonorHealth. Be expert, precise, actionable.'},
