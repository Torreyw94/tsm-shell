<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TSM Hub</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'ui-monospace',SFMono-Regular,Menlo,monospace;background:#0b1120;color:#e5e7eb;display:grid;grid-template-columns:280px 1fr;height:100vh;overflow:hidden}
.sidebar{background:#0d1526;border-right:1px solid #1a2540;display:flex;flex-direction:column;overflow:hidden}
.header{padding:12px 16px;border-bottom:1px solid #1a2540;display:flex;align-items:center;gap:8px}
.logo{font-size:11px;font-weight:800;color:#7dd3fc;letter-spacing:.15em;text-transform:uppercase}
.badge{font-size:9px;padding:2px 6px;background:#7c3aed22;border:1px solid #7c3aed55;border-radius:4px;color:#a78bfa;letter-spacing:.05em}
.search{padding:8px 10px;border-bottom:1px solid #1a2540}
.search input{width:100%;font-size:12px;padding:7px 10px;border:1px solid #1e2d47;border-radius:6px;outline:none;background:#081018;color:#e5e7eb;font-family:inherit}
.search input::placeholder{color:#4b5563}
.sectors{padding:8px 10px;border-bottom:1px solid #1a2540;display:flex;flex-wrap:wrap;gap:4px}
.sector-btn{font-size:10px;padding:3px 8px;border:1px solid #1e2d47;border-radius:4px;background:transparent;color:#6b7280;cursor:pointer;font-family:inherit;transition:all .15s}
.sector-btn:hover{border-color:#334155;color:#94a3b8}
.sector-btn.active{background:#1e3a5f;border-color:#3b82f6;color:#93c5fd}
.count{font-size:10px;color:#4b5563;padding:6px 14px;border-bottom:1px solid #1a2540;display:flex;justify-content:space-between}
.count span{color:#6b7280}
.list{overflow-y:auto;flex:1;scrollbar-width:thin;scrollbar-color:#1e2d47 transparent}
.list::-webkit-scrollbar{width:3px}
.list::-webkit-scrollbar-track{background:transparent}
.list::-webkit-scrollbar-thumb{background:#1e2d47;border-radius:2px}
.group-label{padding:8px 14px 4px;font-size:9px;font-weight:700;color:#374151;letter-spacing:.12em;text-transform:uppercase;border-top:1px solid #111d30;margin-top:4px}
.group-label:first-child{border-top:none;margin-top:0}
.item{padding:8px 14px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:8px;color:#9ca3af;border-bottom:1px solid #0e1829;transition:all .12s}
.item:hover{background:#111f35;color:#e5e7eb}
.item.active{background:#1a2e4a;color:#7dd3fc;border-left:2px solid #3b82f6;padding-left:12px}
.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;transition:all .15s}
.dot.local  {background:#1e3a5f;border:1px solid #2563eb55}
.dot.cached {background:#0f2a1a;border:1px solid #16653455}
.item.active .dot{background:#3b82f6;box-shadow:0 0 6px #3b82f680}
.tag{font-size:8px;padding:1px 5px;border-radius:3px;margin-left:auto;flex-shrink:0;letter-spacing:.06em;font-weight:700}
.tag.local  {background:#0f1e3a;border:1px solid #1e40af;color:#60a5fa}
.tag.cached {background:#0f2a1a;border:1px solid #166534;color:#4ade80}
.main{display:flex;flex-direction:column;background:#060d1a}
.bar{padding:8px 14px;border-bottom:1px solid #1a2540;display:flex;align-items:center;gap:6px;background:#0a1628}
.url{flex:1;font-size:11px;padding:7px 10px;border:1px solid #1a2d47;border-radius:6px;background:#060d1a;color:#4b6584;font-family:inherit;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0}
.bar-btn{font-size:11px;padding:7px 11px;border:1px solid #1a2d47;border-radius:6px;background:#0d1a2e;color:#9ca3af;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap;flex-shrink:0}
.bar-btn:hover{background:#162035;color:#e5e7eb;border-color:#2563eb44}
#live-btn{display:none;font-size:11px;padding:7px 11px;border:1px solid #166534;border-radius:6px;background:#0a1f10;color:#4ade80;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap;flex-shrink:0}
#live-btn:hover{background:#14532d;color:#86efac;border-color:#22c55e}
#live-btn.visible{display:block}
.frame-wrap{flex:1;position:relative;overflow:hidden}
iframe{position:absolute;inset:0;width:100%;height:100%;border:none;background:#fff}
.foot{padding:6px 14px;border-top:1px solid #1a2540;font-size:10px;color:#374151;background:#0a1628;display:flex;gap:16px;align-items:center}
.live-dot{color:#22c55e;font-weight:700;letter-spacing:.05em}
#active-label{color:#6b7280}
.empty{padding:40px 20px;text-align:center;color:#374151;font-size:12px;line-height:1.8}
.legend{padding:5px 14px;font-size:9px;color:#374151;display:flex;gap:10px;border-bottom:1px solid #111d30;flex-wrap:wrap}
.legend span{display:flex;align-items:center;gap:4px}
</style>
</head>
<body>
<div class="sidebar">
  <div class="header">
    <span class="logo">TSM Hub</span>
    <span class="badge">LIVE</span>
  </div>
  <div class="search"><input id="q" placeholder="Search apps..." oninput="filterApps(this.value)"></div>
  <div class="sectors" id="sector-tabs"></div>
  <div class="count"><span id="count">0 apps</span><span id="sector-label">ALL</span></div>
  <div class="legend">
    <span><span class="tag local">LOCAL</span> built here</span>
    <span><span class="tag cached">CACHED</span> local copy · live available</span>
  </div>
  <div class="list" id="list"></div>
</div>
<div class="main">
  <div class="bar">
    <div class="url" id="url-bar">select an app</div>
    <button id="live-btn" onclick="openLive()">&#x2197; Live Site</button>
    <button class="bar-btn" onclick="reloadFrame()">&#x27F3; Reload</button>
    <button class="bar-btn" onclick="openCurrentTab()">&#x2197; Open</button>
  </div>
  <div class="frame-wrap">
    <iframe id="frame" src="about:blank"
      sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-top-navigation"></iframe>
  </div>
  <div class="foot">
    <span class="live-dot">&#x25CF; live</span>
    <span id="active-label">none selected</span>
    <span id="foot-type" style="margin-left:auto;font-size:9px;color:#1e3a5f"></span>
    <span style="color:#1e3a5f">tsm-shell hub</span>
  </div>
</div>
<script>
// ALL_APPS — EXT type removed entirely.
// Former EXT apps are now type:'cached' with liveUrl fallback.
// Run:  bash fetch-ext-apps.sh   to populate /html/ with their snapshots.
const ALL_APPS = [

  // ── Healthcare ──────────────────────────────────────────────────────────────
  { sector:'Healthcare', name:'HonorHealth Command',   type:'local',  url:'/html/honorhealth-dee.html' },
  { sector:'Healthcare', name:'Healthcare Command',    type:'local',  url:'/html/healthcare-command.html' },
  { sector:'Healthcare', name:'HC Billing',            type:'cached', url:'/html/hc-billing.tsmatter.html',             liveUrl:'https://hc-billing.tsmatter.com' },
  { sector:'Healthcare', name:'HC Compliance',         type:'cached', url:'/html/hc-compliance.tsmatter.html',          liveUrl:'https://hc-compliance.tsmatter.com' },
  { sector:'Healthcare', name:'HC Financial',          type:'cached', url:'/html/hc-financial.tsmatter.html',           liveUrl:'https://hc-financial.tsmatter.com' },
  { sector:'Healthcare', name:'HC Grants',             type:'cached', url:'/html/hc-grants.tsmatter.html',              liveUrl:'https://hc-grants.tsmatter.com' },
  { sector:'Healthcare', name:'HC Insurance',          type:'cached', url:'/html/hc-insurance.tsmatter.html',           liveUrl:'https://hc-insurance.tsmatter.com' },
  { sector:'Healthcare', name:'HC Legal',              type:'cached', url:'/html/hc-legal.tsmatter.html',               liveUrl:'https://hc-legal.tsmatter.com' },
  { sector:'Healthcare', name:'HC Medical',            type:'cached', url:'/html/hc-medical.tsmatter.html',             liveUrl:'https://hc-medical.tsmatter.com' },
  { sector:'Healthcare', name:'HC Pharmacy',           type:'cached', url:'/html/hc-pharmacy.tsmatter.html',            liveUrl:'https://hc-pharmacy.tsmatter.com' },
  { sector:'Healthcare', name:'HC Strategist',         type:'cached', url:'/html/hc-strategist.tsmatter.html',          liveUrl:'https://hc-strategist.tsmatter.com' },
  { sector:'Healthcare', name:'HC Tax Prep',           type:'cached', url:'/html/hc-taxprep.tsmatter.html',             liveUrl:'https://hc-taxprep.tsmatter.com' },
  { sector:'Healthcare', name:'HC Vendors',            type:'cached', url:'/html/hc-vendors.tsmatter.html',             liveUrl:'https://hc-vendors.tsmatter.com' },
  { sector:'Healthcare', name:'HonorHealth Dee',       type:'local',  url:'https://tsm-honorhealth-dee.fly.dev/' },
  { sector:'Healthcare', name:'TSM HonorHealth',       type:'cached', url:'/html/tsm-honorhealth-dee.tsmatter.html',    liveUrl:'https://honorhealth.tsmatter.com' },
  { sector:'Healthcare', name:'Honor Portal',          type:'local',  url:'/html/honor-portal/' },
  { sector:'Healthcare', name:'DME',                   type:'local',  url:'/html/dme.html' },
  { sector:'Healthcare', name:'Banner Health',         type:'cached', url:'/html/banner-health.tsmatter.html',          liveUrl:'https://banner-health.tsmatter.com' },
  { sector:'Healthcare', name:'Abrazo Health',         type:'cached', url:'/html/abrazo.tsmatter.html',                 liveUrl:'https://abrazo.tsmatter.com' },
  { sector:'Healthcare', name:'Valleywise Health',     type:'cached', url:'/html/valleywise.tsmatter.html',             liveUrl:'https://valleywise.tsmatter.com' },
  { sector:'Healthcare', name:'HealthOps BPO',         type:'cached', url:'/html/bpo-healthcare.tsmatter.html',         liveUrl:'https://bpo-healthcare.tsmatter.com' },

  // ── BPO ─────────────────────────────────────────────────────────────────────
  { sector:'BPO', name:'BPO Legal',                    type:'cached', url:'/html/bpo-legal.tsmatter.html',              liveUrl:'https://bpo-legal.tsmatter.com' },
  { sector:'BPO', name:'BPO Realty',                   type:'cached', url:'/html/bpo-realty.tsmatter.html',             liveUrl:'https://bpo-realty.tsmatter.com' },
  { sector:'BPO', name:'BPO Tax',                      type:'cached', url:'/html/bpo-tax.tsmatter.html',                liveUrl:'https://bpo-tax.tsmatter.com' },
  { sector:'BPO', name:'HealthOps BPO',                type:'cached', url:'/html/bpo-healthcare.tsmatter.html',         liveUrl:'https://bpo-healthcare.tsmatter.com' },
  { sector:'BPO', name:'ConstructionOps BPO',          type:'cached', url:'/html/bpo-construction.tsmatter.html',       liveUrl:'https://bpo-construction.tsmatter.com' },
  { sector:'BPO', name:'HotelOps BPO',                 type:'cached', url:'/html/bpo-hotelops.tsmatter.html',           liveUrl:'https://bpo-hotelops.tsmatter.com' },
  { sector:'BPO', name:'BrokerOps BPO',                type:'cached', url:'/html/bpo-realty.tsmatter.html',             liveUrl:'https://bpo-realty.tsmatter.com' },

  // ── Financial ───────────────────────────────────────────────────────────────
  { sector:'Financial', name:'Financial Command',      type:'cached', url:'/html/financial-command.tsmatter.html',      liveUrl:'https://financial-command.tsmatter.com' },
  { sector:'Financial', name:'Desert Financial',       type:'cached', url:'/html/desert-financial.tsmatter.html',       liveUrl:'https://desert-financial.tsmatter.com' },
  { sector:'Financial', name:'Strategist',             type:'cached', url:'/html/strategist00.tsmatter.html',           liveUrl:'https://strategist00.tsmatter.com' },
  { sector:'Financial', name:'Strategist Index',       type:'local',  url:'/html/strategist-index.html' },
  { sector:'Financial', name:'Financial',              type:'local',  url:'/html/financial.html' },
  { sector:'Financial', name:'Compliance',             type:'cached', url:'/html/compliance.tsmatter.html',             liveUrl:'https://compliance.tsmatter.com' },
  { sector:'Financial', name:'Tax Intelligence',       type:'cached', url:'/html/tax.tsmatter.html',                    liveUrl:'https://tax.tsmatter.com' },
  { sector:'Financial', name:'Zero Trust',             type:'local',  url:'/html/zero-trust.html' },

  // ── Construction ────────────────────────────────────────────────────────────
  { sector:'Construction', name:'Construction Command', type:'cached', url:'/html/construction-command.tsmatter.html',  liveUrl:'https://construction-command.tsmatter.com' },
  { sector:'Construction', name:'Construction Center',  type:'local',  url:'/html/construction-center.html' },
  { sector:'Construction', name:'Construction',         type:'local',  url:'/html/construction.html' },
  { sector:'Construction', name:'Ameris Portal',        type:'local',  url:'/html/ameris-portal/' },
  { sector:'Construction', name:'ConstructionOps BPO',  type:'cached', url:'/html/bpo-construction.tsmatter.html',      liveUrl:'https://bpo-construction.tsmatter.com' },
  { sector:'Construction', name:'Ameris Construction',  type:'cached', url:'/html/ameris-construction.tsmatter.html',   liveUrl:'https://ameris-construction.tsmatter.com' },

  // ── Insurance ───────────────────────────────────────────────────────────────
  { sector:'Insurance', name:'PC Command',              type:'cached', url:'/html/pc-command.tsmatter.html',             liveUrl:'https://pc-command.tsmatter.com' },
  { sector:'Insurance', name:'AZ Insurance',            type:'cached', url:'/html/az-ins.tsmatter.html',                 liveUrl:'https://az-ins.tsmatter.com' },
  { sector:'Insurance', name:'AZ Life',                 type:'local',  url:'/html/az-life.html' },
  { sector:'Insurance', name:'Insurance Command',       type:'cached', url:'/html/insurance-command.tsmatter.html',      liveUrl:'https://insurance-command.tsmatter.com' },

  // ── Legal ───────────────────────────────────────────────────────────────────
  { sector:'Legal', name:'BPO Legal',                   type:'cached', url:'/html/bpo-legal.tsmatter.html',              liveUrl:'https://bpo-legal.tsmatter.com' },
  { sector:'Legal', name:'Legal Intelligence',          type:'cached', url:'/html/legal.tsmatter.html',                  liveUrl:'https://legal.tsmatter.com' },
  { sector:'Legal', name:'Legal Analyst Pro',           type:'cached', url:'/html/legal-analyst-pro.tsmatter.html',      liveUrl:'https://legal-analyst-pro.tsmatter.com' },

  // ── Real Estate ─────────────────────────────────────────────────────────────
  { sector:'Real Estate', name:'REO Pro',               type:'cached', url:'/html/reo-pro.tsmatter.html',                liveUrl:'https://reo-pro.tsmatter.com' },
  { sector:'Real Estate', name:'REO Command',           type:'local',  url:'/html/reo-command.html' },
  { sector:'Real Estate', name:'Mortgage Command',      type:'local',  url:'/html/mortgage-command.html' },
  { sector:'Real Estate', name:'Real Estate Command',   type:'cached', url:'/html/real-estate-command.tsmatter.html',    liveUrl:'https://real-estate-command.tsmatter.com' },
  { sector:'Real Estate', name:'Mortgage',              type:'cached', url:'/html/mortgage.tsmatter.html',               liveUrl:'https://mortgage.tsmatter.com' },
  { sector:'Real Estate', name:'BrokerOps BPO',         type:'cached', url:'/html/bpo-realty.tsmatter.html',             liveUrl:'https://bpo-realty.tsmatter.com' },

  // ── Education ───────────────────────────────────────────────────────────────
  { sector:'Education', name:'Schools Command',         type:'local',  url:'/html/schools-command.html' },
  { sector:'Education', name:'Schools',                 type:'cached', url:'/html/schools.tsmatter.html',                liveUrl:'https://schools.tsmatter.com' },
  { sector:'Education', name:'Schools Command (Live)',  type:'cached', url:'/html/schools-command.tsmatter.html',        liveUrl:'https://schools-command.tsmatter.com' },

  // ── Hospitality ─────────────────────────────────────────────────────────────
  { sector:'Hospitality', name:'Concierge Command',     type:'local',  url:'/html/concierge-command.html' },
  { sector:'Hospitality', name:'HotelOps Pro',          type:'cached', url:'/html/hotelops.tsmatter.html',               liveUrl:'https://hotelops.tsmatter.com' },
  { sector:'Hospitality', name:'HotelOps BPO',          type:'cached', url:'/html/bpo-hotelops.tsmatter.html',           liveUrl:'https://bpo-hotelops.tsmatter.com' },

  // ── Enterprise ──────────────────────────────────────────────────────────────
  { sector:'Enterprise', name:'RRD Command',            type:'cached', url:'/html/rrd-command.tsmatter.html',            liveUrl:'https://rrd-command.tsmatter.com' },
  { sector:'Enterprise', name:'Case Tech',              type:'cached', url:'/html/case-tech.tsmatter.html',              liveUrl:'https://case-tech.tsmatter.com' },
  { sector:'Enterprise', name:'Agents',                 type:'local',  url:'/html/agents-ins-html/' },
  { sector:'Enterprise', name:'Agents (HTML)',          type:'local',  url:'/html/agents-ins.html' },
  { sector:'Enterprise', name:'AuditOps Pro',           type:'local',  url:'/html/auditops-pro-html/' },
  { sector:'Enterprise', name:'AuditOps Pro (HTML)',    type:'local',  url:'/html/auditops-pro.html' },
  { sector:'Enterprise', name:'Suite Builder',          type:'local',  url:'/html/suite-builder.html' },
  { sector:'Enterprise', name:'Zero Trust',             type:'local',  url:'/html/zero-trust.html' },
  { sector:'Enterprise', name:'Access',                 type:'local',  url:'/html/access.html' },
  { sector:'Enterprise', name:'ESD Portal',             type:'local',  url:'/html/esd-portal/' },
  { sector:'Enterprise', name:'TSM Strategy',           type:'local',  url:'/html/tsm-strategy/' },
  { sector:'Enterprise', name:'DocPro',                 type:'cached', url:'/html/docpro.tsmatter.html',                 liveUrl:'https://docpro.tsmatter.com' },
  { sector:'Enterprise', name:'Appointments',           type:'cached', url:'/html/appointments.tsmatter.html',           liveUrl:'https://appointments.tsmatter.com' },
  { sector:'Enterprise', name:'AuditOps',               type:'cached', url:'/html/auditops.tsmatter.html',               liveUrl:'https://auditops.tsmatter.com' },
  { sector:'Enterprise', name:'Music Command',          type:'cached', url:'/html/music-command.tsmatter.html',          liveUrl:'https://music-command.tsmatter.com' },
  { sector:'Enterprise', name:'AI',                     type:'cached', url:'/html/ai.tsmatter.html',                     liveUrl:'https://ai.tsmatter.com' },

  // ── Demo Decks ──────────────────────────────────────────────────────────────
  { sector:'Demo Decks', name:'BNCA GTM HC',            type:'local',  url:'/html/demo/bnca-gtm-hc.html' },
  { sector:'Demo Decks', name:'Demo Click Guide',       type:'local',  url:'/html/demo/demo-click-guide.html' },
  { sector:'Demo Decks', name:'Desert Pitch',           type:'local',  url:'/html/demo/desert-pitch.html' },
  { sector:'Demo Decks', name:'Honor Portal DM',        type:'local',  url:'/html/demo/honor-portal-dm.html' },
  { sector:'Demo Decks', name:'Strategist HC',          type:'local',  url:'/html/demo/strategist-hc.html' },
  { sector:'Demo Decks', name:'Suite Builder Demo',     type:'local',  url:'/html/demo/suite-builder.html' },
  { sector:'Demo Decks', name:'Tax',                    type:'local',  url:'/html/demo/tax.html' },
  { sector:'Demo Decks', name:'TSM Pricing',            type:'local',  url:'/html/demo/tsm-pricing.html' },
  { sector:'Demo Decks', name:'Desert Financial Pitch', type:'cached', url:'/html/desert-financial-pitch.tsmatter.html', liveUrl:'https://clients.tsmatter.com/demo/desert-financial-pitch.html' },
  { sector:'Demo Decks', name:'Command Promo',          type:'cached', url:'/html/command-promo.tsmatter.html',          liveUrl:'https://clients.tsmatter.com/demo/command-promo.html' },
  { sector:'Demo Decks', name:'Why TSM',                type:'cached', url:'/html/why-tsm.tsmatter.html',                liveUrl:'https://clients.tsmatter.com/demo/why-tsm.html' },
  { sector:'Demo Decks', name:'Bundle Demo',            type:'cached', url:'/html/bundle.tsmatter.html',                 liveUrl:'https://clients.tsmatter.com/demo/bundle.html' },
  { sector:'Demo Decks', name:'Financial Analyst',      type:'cached', url:'/html/financial-analyst.tsmatter.html',      liveUrl:'https://clients.tsmatter.com/demo/financial-analyst.html' },
];

const SECTORS_LIST   = [...new Set(ALL_APPS.map(a=>a.sector))];
const UNIQUE_SECTORS = ['All','Local','Cached',...SECTORS_LIST];

let activeFilter='All', searchQuery='', currentId=null, currentUrl=null, currentLive=null, currentName=null;

function buildSectorTabs(){
  document.getElementById('sector-tabs').innerHTML=UNIQUE_SECTORS.map(s=>
    `<button class="sector-btn${s===activeFilter?' active':''}" onclick="setSector('${s}')">${s}</button>`
  ).join('');
}

function setSector(s){
  activeFilter=s; searchQuery='';
  document.getElementById('q').value='';
  buildSectorTabs(); render();
}

function getVisible(){
  const q=searchQuery.toLowerCase();
  let pool = activeFilter==='All'    ? ALL_APPS
           : activeFilter==='Local'  ? ALL_APPS.filter(a=>a.type==='local')
           : activeFilter==='Cached' ? ALL_APPS.filter(a=>a.type==='cached')
           : ALL_APPS.filter(a=>a.sector===activeFilter);
  if(q) pool=pool.filter(a=>a.name.toLowerCase().includes(q)||a.url.toLowerCase().includes(q));
  return pool;
}

function render(){
  const visible=getVisible();
  document.getElementById('count').textContent=visible.length+' apps';
  document.getElementById('sector-label').textContent=activeFilter.toUpperCase();
  if(!visible.length){
    document.getElementById('list').innerHTML='<div class="empty">No apps match.</div>';
    return;
  }
  const grouped={};
  visible.forEach(a=>{const g=a.sector||'Other';(grouped[g]=grouped[g]||[]).push(a);});
  document.getElementById('list').innerHTML=Object.keys(grouped).map(g=>
    `<div class="group-label">${g}</div>`+grouped[g].map(itemHtml).join('')
  ).join('');
  if(currentId) document.querySelectorAll('.item').forEach(el=>
    el.classList.toggle('active',el.dataset.id===currentId)
  );
}

function itemHtml(a){
  const dc={local:'dot local',cached:'dot cached'}[a.type]||'dot local';
  const tc={local:'tag local',cached:'tag cached'}[a.type]||'tag local';
  const tt={local:'LOCAL',    cached:'CACHED'}[a.type]||'LOCAL';
  const live=a.liveUrl?` data-live="${a.liveUrl}"`:'';
  return `<div class="item" data-id="${a.url}" data-name="${a.name}" data-type="${a.type}"${live} onclick="loadApp(this)">
    <span class="${dc}"></span>
    <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${a.name}</span>
    <span class="${tc}">${tt}</span>
  </div>`;
}

function loadApp(el){
  const id=el.dataset.id, name=el.dataset.name, type=el.dataset.type, live=el.dataset.live||null;
  currentId=id; currentUrl=id; currentName=name; currentLive=live;

  document.querySelectorAll('.item').forEach(e=>e.classList.toggle('active',e.dataset.id===id));
  document.getElementById('url-bar').textContent=id;
  document.getElementById('active-label').textContent=name;

  const liveBtn=document.getElementById('live-btn');
  if(type==='cached'&&live){liveBtn.classList.add('visible');liveBtn.title='Open live: '+live;}
  else{liveBtn.classList.remove('visible');}

  const footType=document.getElementById('foot-type');
  footType.textContent={local:'● local',cached:'◎ cached · live available'}[type]||'';
  footType.style.color={local:'#1e40af',cached:'#166534'}[type]||'#374151';

  document.getElementById('frame').src=id;
}

function openLive(){if(currentLive)window.open(currentLive,'_blank');}
function reloadFrame(){
  if(!currentUrl)return;
  const f=document.getElementById('frame'),s=f.src;
  f.src='about:blank';setTimeout(()=>{f.src=s;},80);
}
function openCurrentTab(){if(currentUrl&&currentUrl!=='about:blank')window.open(currentUrl,'_blank');}
function filterApps(q){searchQuery=q;render();}

buildSectorTabs();
render();
const first=ALL_APPS.find(a=>a.type==='local');
if(first){
  currentId=currentUrl=first.url;currentName=first.name;currentLive=null;
  document.getElementById('url-bar').textContent=first.url;
  document.getElementById('frame').src=first.url;
  document.getElementById('active-label').textContent=first.name;
  document.getElementById('foot-type').textContent='● local';
  document.getElementById('foot-type').style.color='#1e40af';
  setTimeout(()=>{document.querySelectorAll('.item').forEach(el=>
    el.classList.toggle('active',el.dataset.id===first.url));},50);
}
</script>
</body>
</html>
