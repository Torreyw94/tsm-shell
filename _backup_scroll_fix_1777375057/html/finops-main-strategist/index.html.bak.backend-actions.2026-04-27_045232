  <button onclick="runFinopsAction('MONTH_END')">▶ Lock Month-End Close</button>
  <button onclick="runFinopsAction('1099_TRACK')">▶ Run 1099 Outreach</button>
  <button onclick="runFinopsAction('EXPORT')">▶ Export Controller Report</button>
