[READY] Awaiting actions...
</div>

<script>
function updateTimestamp(){
  const el=document.getElementById('finops-ts');
  if(el) el.innerText=new Date().toLocaleString();
}
updateTimestamp();

function log(msg){
  const el=document.getElementById('finops-log');
  if(!el) return;
  const line = "["+new Date().toLocaleTimeString()+"] " + msg;
  el.innerHTML = line + "<br>" + el.innerHTML;
}

function runFinopsAction(type){
  log("Executing: "+type);

  let output = "";

  if(type==="AP_QUEUE"){
    output = "AP queue prioritized. High-risk vendors flagged. Approval routing initiated.";
  }
  if(type==="RECON_REVIEW"){
    output = "Bank reconciliation workflow triggered. Matching engine activated.";
  }
  if(type==="MONTH_END"){
    output = "Month-end checklist locked. Close readiness confirmed.";
  }
  if(type==="1099_TRACK"){
    output = "1099 vendor outreach started. W-9 requests sent.";
  }
  if(type==="EXPORT"){
    output = "Executive report generated. Ready for controller review.";
  }

  log(output);

  // update BNCA panel if present
  const bnca = document.querySelector("#finops-bnca, .finops-bnca");
  if(bnca){
    bnca.innerText = "UPDATED ACTION:\n\n" + output;
  }
}
</script>


