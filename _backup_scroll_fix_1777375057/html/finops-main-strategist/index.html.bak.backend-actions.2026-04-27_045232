<script id="finops-accounting-lanes-js">
function buildFinOpsAccountingReport(){
  const report = `TSM FINANCIAL OPERATIONS LAYER — ACCOUNTING OPS REPORT

AP VENDOR INVOICE LANE
- 12 vendor invoices pending validation.
- Validate invoice accuracy, approvals, timing, and supporting documentation.
- Prioritize invoices by due date and vendor impact.

BANK RECONCILIATION LANE
- 3 reconciling items require documentation.
- Match bank feed transactions to QuickBooks activity.
- Resolve or document exceptions before month-end review.

MONTH-END CLOSE CHECKLIST
- Close readiness: 84%.
- AR/AP review active.
- Supporting schedules and documentation require final update.
- Controller review package should be prepared before close.

1099 TRACKER
- 7 vendors require W-9 / threshold review.
- Maintain 1099 process and prepare year-end readiness.
- Flag missing vendor tax documentation.

BEST NEXT COURSE OF ACTION
Prioritize AP validation and bank reconciliation exceptions first, complete 1099 vendor review, then package month-end support for Controller review.

$1,250/MO VALUE POSITION
Most teams pay $5K–$7K/month for someone to manage this manually. TSM delivers it as a system that monitors, flags, organizes, and reports the work for $1,250/month.`;

  const summary=document.getElementById('summary');
  if(summary) summary.textContent = report;

  localStorage.setItem('tsm_finops_report', JSON.stringify({
    ts:new Date().toISOString(),
    title:'TSM Financial Operations Accounting Ops Report',
    summary:report
  }));

  alert('Accounting Ops report built and saved.');
}

function saveFinOpsMainReport(){
  const txt = document.getElementById('summary')?.textContent || 'FinOps report saved.';
  localStorage.setItem('tsm_finops_report', JSON.stringify({
    ts:new Date().toISOString(),
    title:'TSM Financial Operations Executive Report',
    summary:txt
  }));
  alert('Saved FinOps Main report.');
}

function exportFinOpsReport(){
  const txt = document.getElementById('summary')?.textContent || '';
  const w = window.open('', '_blank');
  w.document.write(`<pre style="font-family:monospace;white-space:pre-wrap;line-height:1.5">${txt.replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]))}</pre>`);
  w.document.title = 'TSM Financial Operations Report';
  w.document.close();
  setTimeout(()=>w.print(),500);
}
</script>


