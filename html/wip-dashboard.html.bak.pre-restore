},
{
  id:"ENC-8750",
  title:"Payer Adjudication",
  percent:90,
  expected:6100,
  collected:5490,
  gap:-610,
  risk:"LOW",
  narrative:"Payer processing active."
}
];

window.TSM_MESH_CONTROLLER = true;

window.initializeWIPDashboard = function(){

  const matrix = document.querySelector('#wipMatrix');
  const entities = document.querySelector('#activeEntities');
  const flags = document.querySelector('#activeFlags');

  if(matrix){
    matrix.innerHTML = window.WIP_ENTITIES.map(e => `
      <div class="wip-row">
        <div>${e.id}</div>
        <div>${e.title}</div>
        <div>${e.percent}%</div>
        <div>$${e.expected.toLocaleString()}</div>
        <div class="risk-${e.risk.toLowerCase()}">${e.risk}</div>
      </div>
    `).join('');
  }

  if(entities){
    entities.innerHTML = window.WIP_ENTITIES.map(e => `
      <div class="entity-card">
        <b>${e.title}</b><br>
        ${e.percent}% stage · Risk ${e.risk}
      </div>
    `).join('');
  }

  if(flags){
    flags.innerHTML = `
      <div class="flag critical">Prior Auth Risk</div>
      <div class="flag high">Claim Scrubbing Hold</div>
      <div class="flag med">Coding Review Queue</div>
    `;
  }

  console.log("TSM WIP HYDRATION ONLINE");
};

window.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => {
    if(window.initializeWIPDashboard){
      window.initializeWIPDashboard();
    }
  }, 250);
});
</script>


<script id="wip-narrative-format-final">
(function(){
  if(window.__WIP_NARRATIVE_FORMAT_FINAL__) return;
  window.__WIP_NARRATIVE_FORMAT_FINAL__ = true;

  function findNarrativeBox(){
    return document.querySelector("#narrativeOutput")
      || document.querySelector("[data-narrative-output]")
      || [...document.querySelectorAll("pre,div")]
        .find(el => (el.textContent || "").includes("BNCA SYNTHESIS"));
  }

  const oldRun = window.runNarrative;
  window.runNarrative = async function(){
    if(typeof oldRun === "function"){
      await oldRun();
    }

    setTimeout(()=>{
      const box=findNarrativeBox();
      if(!box) return;

      box.style.whiteSpace="pre-wrap";
      box.style.lineHeight="1.55";
      box.style.fontSize="12px";
      box.style.padding="14px";
      box.style.border="1px solid rgba(0,255,198,.18)";
      box.style.borderRadius="12px";
      box.style.background="#06111b";

      let t=box.textContent || "";
      t=t
        .replace(/(BNCA SYNTHESIS)/g,"$1\n\n")
        .replace(/(TOP ISSUE)/g,"\n$1\n")
        .replace(/(WHY IT MATTERS)/g,"\n$1\n")
        .replace(/(BEST NEXT ACTIONS)/g,"\n$1\n")
        .replace(/(OWNER LANE)/g,"\n$1\n")
        .replace(/(CONTROLLER)/g,"\n$1\n")
        .replace(/(ENTERPRISE RISKS)/g,"\n$1\n")
        .replace(/(HITL DECISION)/g,"\n$1\n")
        .replace(/(STRATEGIST RELAY)/g,"\n$1\n")
        .replace(/(CONFIDENCE)/g,"\n$1\n")
        .replace(/\n{3,}/g,"\n\n");

      box.textContent=t.trim();
    },500);
  };

  console.log("WIP narrative formatter online");
})();
</script>




















<script id="tsm-set-sector">
(function() {
  var PANELS = {
    healthcare: 'wip-healthcare',
    insurance:  'wip-insurance',
    finops:     'wip-finops',
  };
  var ACTIVE = {
    construction: 'active-construction',
    healthcare:   'active-healthcare',
    insurance:    'active-insurance',
    finops:       'active-finops',
  };

  function setSector(name) {
    // Hide all side panels
    Object.values(PANELS).forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });

    // Construction content: always show main + charts
    var main   = document.querySelector('.main');
    var charts = document.getElementById('charts-section');
    if (main)   main.style.display   = (name === 'construction') ? '' : 'none';
    if (charts) charts.style.display = (name === 'construction') ? '' : 'none';

    // Show target panel for non-construction
    if (PANELS[name]) {
      var target = document.getElementById(PANELS[name]);
      if (target) target.style.display = 'block';
    }

    // Update button states
    document.querySelectorAll('.sector-btn').forEach(function(btn) {
      Object.values(ACTIVE).forEach(function(cls) { btn.classList.remove(cls); });
    });
    var activeBtn = document.getElementById('btn-' + name);
    if (activeBtn && ACTIVE[name]) activeBtn.classList.add(ACTIVE[name]);

    // URL
    try {
      var url = new URL(window.location.href);
      url.searchParams.set('sector', name);
      history.replaceState(null, '', url.toString());
    } catch(e) {}
    console.log('WIP sector selected:', name);
  }

  window.setSector    = setSector;
  window.switchSector = setSector;

  document.addEventListener('DOMContentLoaded', function() {
    var param = new URLSearchParams(window.location.search).get('sector');
    setSector(param || 'construction');
  });
})();
</script>

</body>