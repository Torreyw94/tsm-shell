<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Universal WIP Intelligence · TSM Sovereign Mesh</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#040810;--surf:#080f1c;--surf2:#0c1525;--b1:rgba(0,229,255,.07);--b2:rgba(0,229,255,.15);
  --cyan:#00e5ff;--green:#00ff88;--amber:#ffb300;--red:#ff4455;--purple:#a855f7;--gold:#f5c842;
  --muted:#2a4a6a;--text:#90b8d8;--white:#e0f0ff;
  --mono:'JetBrains Mono',monospace;--head:'Barlow Condensed',sans-serif;--body:'Barlow',sans-serif;
  /* sector themes */
  --s-color:var(--cyan);
}
body.sector-healthcare{--s-color:#00ff88}
body.sector-insurance{--s-color:#a855f7}
body.sector-finops{--s-color:#f5c842}
body.sector-construction{--s-color:#ffb300}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--body);font-size:13px;min-height:100vh}

/* TOPBAR */
.tb{position:sticky;top:0;z-index:200;background:rgba(4,8,16,.97);backdrop-filter:blur(12px);border-bottom:1px solid var(--b2);display:flex;align-items:center;justify-content:space-between;padding:.5rem 1.2rem;gap:1rem}
.tb-brand{font-family:var(--mono);font-size:.55rem;letter-spacing:.2em;color:var(--s-color);transition:color .4s}
.tb-nav{display:flex;gap:.3rem;flex-wrap:wrap}
.tb-link{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;color:var(--muted);padding:.28rem .55rem;border:1px solid transparent;text-decoration:none;transition:all .2s;cursor:pointer;background:transparent}
.tb-link:hover{color:var(--s-color);border-color:var(--b2)}
.tb-status{font-family:var(--mono);font-size:.48rem;letter-spacing:.1em;color:var(--green);display:flex;align-items:center;gap:.4rem;flex-shrink:0}
.tb-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}

/* HERO */
.hero{padding:2.5rem 1.2rem 1.5rem;max-width:1200px;margin:0 auto}
.hero-eye{font-family:var(--mono);font-size:.48rem;letter-spacing:.2em;color:var(--s-color);margin-bottom:.8rem;transition:color .4s}
.hero-title{font-family:var(--head);font-size:clamp(2rem,5vw,3.8rem);font-weight:900;color:var(--white);line-height:.92;margin-bottom:.6rem}
.hero-title em{color:var(--s-color);font-style:normal;transition:color .4s}

/* SECTOR SWITCHER */
.sector-bar{display:flex;gap:0;border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:2rem;width:fit-content}
.sector-btn{font-family:var(--mono);font-size:.52rem;letter-spacing:.1em;padding:.45rem 1.1rem;border:none;background:transparent;color:var(--muted);cursor:pointer;border-right:1px solid var(--b2);transition:all .25s;text-transform:uppercase}
.sector-btn:last-child{border-right:none}
.sector-btn.active-construction{background:rgba(255,179,0,.12);color:var(--amber)}
.sector-btn.active-healthcare{background:rgba(0,255,136,.1);color:var(--green)}
.sector-btn.active-insurance{background:rgba(168,85,247,.1);color:var(--purple)}

/* MAIN GRID */
.main{max-width:1200px;margin:0 auto;padding:0 1.2rem 2rem;display:grid;grid-template-columns:1fr 320px;gap:1rem}
@media(max-width:900px){.main{grid-template-columns:1fr}}

/* WIP MATRIX */
.wip-matrix{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.wm-head{background:var(--surf2);padding:.6rem 1rem;border-bottom:1px solid var(--b2);display:flex;justify-content:space-between;align-items:center}
.wm-title{font-family:var(--mono);font-size:.55rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.wm-badge{font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;padding:.15rem .5rem;border:1px solid;border-radius:2px}
.wip-table{width:100%;border-collapse:collapse}
.wip-table th{font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;color:var(--muted);padding:.5rem .8rem;border-bottom:1px solid var(--b1);text-align:left;font-weight:400;text-transform:uppercase}
.wip-table td{padding:.55rem .8rem;border-bottom:1px solid var(--b1);font-size:.72rem}
.wip-table tr:last-child td{border-bottom:none}
.wip-table tr:hover td{background:var(--surf2)}
.cell-label{font-family:var(--mono);font-size:.55rem;color:var(--text)}
.cell-value{font-size:.8rem;font-weight:600;color:var(--white);font-family:var(--mono)}
.cell-pct{font-size:.75rem;font-weight:700;font-family:var(--mono)}
.cell-good{color:var(--green)}
.cell-warn{color:var(--amber)}
.cell-bad{color:var(--red)}
.cell-bar-wrap{width:120px;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;display:inline-block;vertical-align:middle;margin-left:.5rem}
.cell-bar{height:100%;border-radius:2px;transition:width .6s}
.bar-good{background:var(--green)}
.bar-warn{background:var(--amber)}
.bar-bad{background:var(--red)}

/* WIP CARDS */
.wip-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.75rem;margin-bottom:1rem}
.wc{background:var(--surf);border:1px solid var(--b1);border-radius:4px;padding:.9rem;position:relative;overflow:hidden}
.wc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--s-color);opacity:.6;transition:background .4s}
.wc-label{font-family:var(--mono);font-size:.42rem;letter-spacing:.12em;color:var(--muted);margin-bottom:.3rem}
.wc-value{font-family:var(--head);font-size:1.6rem;font-weight:800;color:var(--white);line-height:1}
.wc-sub{font-family:var(--mono);font-size:.48rem;color:var(--muted);margin-top:.25rem}
.wc-delta{font-family:var(--mono);font-size:.5rem;margin-top:.35rem}
.delta-up{color:var(--green)}
.delta-down{color:var(--red)}
.delta-warn{color:var(--amber)}

/* ALERT FEED */
.alert-feed{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.af-head{background:var(--surf2);padding:.5rem .8rem;border-bottom:1px solid var(--b2);font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.af-item{padding:.5rem .8rem;border-bottom:1px solid var(--b1);display:flex;gap:.6rem;align-items:flex-start}
.af-item:last-child{border-bottom:none}
.af-sev{font-family:var(--mono);font-size:.45rem;letter-spacing:.06em;padding:.1rem .3rem;border:1px solid;flex-shrink:0;margin-top:1px}
.sev-crit{color:var(--red);border-color:var(--red)}
.sev-high{color:var(--amber);border-color:var(--amber)}
.sev-med{color:var(--cyan);border-color:var(--cyan)}
.af-text{font-size:.65rem;color:var(--text);line-height:1.5}
.af-text strong{color:var(--white)}

/* AI NARRATIVE */
.ai-panel{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.ap-head{background:var(--surf2);padding:.55rem .8rem;border-bottom:1px solid var(--b2);display:flex;justify-content:space-between;align-items:center}
.ap-title{font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.ap-run{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;padding:.28rem .7rem;background:var(--s-color);color:#040810;border:none;cursor:pointer;font-weight:700;transition:opacity .2s}
.ap-run:hover{opacity:.85}
.ap-run:disabled{opacity:.4;cursor:not-allowed}
.ap-body{padding:.7rem .8rem;min-height:120px;font-size:.68rem;color:var(--text);line-height:1.7;white-space:pre-wrap;font-family:var(--mono)}
.ap-placeholder{color:var(--muted);font-style:italic}

/* ACTION RAIL */
.action-rail{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.ar-head{background:var(--surf2);padding:.5rem .8rem;border-bottom:1px solid var(--b2);font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.ar-btn{display:block;width:100%;text-align:left;padding:.55rem .8rem;border:none;border-bottom:1px solid var(--b1);background:transparent;color:var(--text);font-size:.68rem;cursor:pointer;font-family:var(--body);transition:all .2s}
.ar-btn:last-child{border-bottom:none}
.ar-btn:hover{background:var(--surf2);color:var(--white)}
.ar-btn::before{content:'⚡ ';color:var(--s-color);font-size:.55rem;transition:color .4s}

/* SCHEMA VIEWER */
.schema-panel{background:var(--surf);border:1px solid var(--b1);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.sp-head{background:var(--surf2);padding:.5rem .8rem;border-bottom:1px solid var(--b1);font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--muted)}
.sp-body{padding:.6rem .8rem;font-family:var(--mono);font-size:.6rem;color:var(--text);line-height:1.7;overflow-x:auto;max-height:200px;overflow-y:auto}
.sp-key{color:var(--cyan)}
.sp-val{color:var(--green)}
.sp-num{color:var(--amber)}
.sp-str{color:var(--purple)}

/* SECTOR ENTITIES */
.entity-list{display:flex;flex-direction:column;gap:.5rem;margin-bottom:1rem}
.entity{background:var(--surf);border:1px solid var(--b1);border-radius:4px;padding:.7rem .9rem;cursor:pointer;transition:all .2s;border-left:3px solid var(--b1)}
.entity.selected{border-left-color:var(--s-color);background:var(--surf2)}
.entity:hover{border-left-color:var(--b2)}
.entity-id{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;color:var(--muted)}
.entity-name{font-size:.78rem;font-weight:600;color:var(--white);margin:.15rem 0}
.entity-meta{font-family:var(--mono);font-size:.48rem;color:var(--muted)}
.entity-risk{float:right;font-family:var(--mono);font-size:.65rem;font-weight:700}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes stream{from{opacity:0;transform:translateY(2px)}to{opacity:1;transform:none}}
.streaming .ap-body span{animation:stream .1s ease forwards}
</style>

<style id="tsm-chart-css">
.charts-section{max-width:1200px;margin:0 auto;padding:0 1.2rem 2rem}
.charts-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
.charts-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1rem}
@media(max-width:900px){.charts-grid-2,.charts-grid-3{grid-template-columns:1fr}}
.chart-card{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden}
.chart-head{background:var(--surf2);padding:.5rem .9rem;border-bottom:1px solid var(--b2);display:flex;justify-content:space-between;align-items:center}
.chart-label{font-family:var(--mono);font-size:.48rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.chart-sub{font-family:var(--mono);font-size:.42rem;color:var(--muted)}
.chart-body{padding:.8rem;position:relative}
.chart-insight{background:rgba(0,0,0,.2);border-left:2px solid var(--s-color);padding:.4rem .6rem;margin:.6rem 0 0;font-size:.6rem;color:var(--text);font-family:var(--mono);line-height:1.5;transition:border-color .4s}
.chart-insight strong{color:var(--white)}

/* HEATMAP */
.heatmap-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.5rem;padding:.8rem}
.hm-job{border-radius:3px;padding:.7rem .8rem;position:relative;min-height:70px}
.hm-green{background:rgba(0,255,136,.12);border:1px solid rgba(0,255,136,.3)}
.hm-yellow{background:rgba(255,179,0,.1);border:1px solid rgba(255,179,0,.3)}
.hm-red{background:rgba(255,68,85,.12);border:1px solid rgba(255,68,85,.3)}
.hm-id{font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;color:var(--muted)}
.hm-name{font-size:.72rem;font-weight:600;color:var(--white);margin:.15rem 0}
.hm-stat{font-family:var(--mono);font-size:.55rem}
.hm-green .hm-stat{color:#00ff88}
.hm-yellow .hm-stat{color:#ffb300}
.hm-red .hm-stat{color:#ff4455}

/* JOB HEALTH TILES */
.health-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;padding:.8rem}
.health-tile{background:var(--surf2);border-radius:3px;padding:.6rem;text-align:center}
.ht-label{font-family:var(--mono);font-size:.4rem;letter-spacing:.1em;color:var(--muted);margin-bottom:.2rem}
.ht-value{font-family:var(--mono);font-size:1rem;font-weight:700;line-height:1}
.ht-sub{font-family:var(--mono);font-size:.42rem;color:var(--muted);margin-top:.15rem}
.risk-pill{display:inline-block;font-family:var(--mono);font-size:.5rem;letter-spacing:.08em;padding:.2rem .5rem;border-radius:2px;margin-top:.3rem}
.risk-low{background:rgba(0,255,136,.15);color:#00ff88}
.risk-med{background:rgba(255,179,0,.15);color:#ffb300}
.risk-high{background:rgba(255,68,85,.15);color:#ff4455}
</style>





<style id="tsm-sector-styles">
/* ── Injected sector panels — match Charts B-F aesthetic ── */
#wip-healthcare, #wip-finops, #wip-insurance {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1.5rem 1.2rem 2rem;
}
#wip-insurance .wip-sector-inner,
#wip-healthcare .wip-sector-inner,
#wip-finops .wip-sector-inner {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
/* Make the injected insurance section use the chart-card style */
#wip-insurance {
  max-width: 1200px;
  margin: 0 auto;
  padding: 1.5rem 1.2rem;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
#wip-insurance .wip-kpi-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px,1fr));
  gap: 10px;
}
#wip-insurance .wip-kpi {
  background: var(--surface, #111418);
  border: 1px solid var(--b2, #1e2530);
  border-left: 3px solid var(--kc, #f4a800);
  border-radius: 4px;
  padding: 12px 14px;
}
#wip-insurance .wip-kpi-val {
  font-family: var(--mono, monospace);
  font-size: 22px;
  font-weight: 600;
  color: var(--kc, #f4a800);
  line-height: 1;
}
#wip-insurance .wip-kpi-lbl {
  font-family: var(--mono, monospace);
  font-size: 10px;
  color: var(--muted, #4a5a6a);
  text-transform: uppercase;
  letter-spacing: .07em;
  margin-top: 4px;
}
#wip-insurance .wip-kpi-sub {
  font-size: 11px;
  color: var(--muted, #4a5a6a);
  margin-top: 2px;
}
#wip-insurance .wip-flags {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
#wip-insurance .wip-flag {
  padding: 8px 12px;
  border-radius: 3px;
  font-size: 12px;
  line-height: 1.5;
}
#wip-insurance .wip-flag.red    { background: rgba(255,61,87,.1);  border: 1px solid rgba(255,61,87,.25);  color: #ff3d57; }
#wip-insurance .wip-flag.yellow { background: rgba(255,179,0,.1);  border: 1px solid rgba(255,179,0,.25);  color: #ffb300; }
#wip-insurance .wip-flag.blue   { background: rgba(0,212,255,.08); border: 1px solid rgba(0,212,255,.2);   color: #00d4ff; }
#wip-insurance .wip-matrix-wrap { overflow-x: auto; }
#wip-insurance .wip-matrix-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
#wip-insurance .wip-matrix-title {
  font-family: var(--mono, monospace);
  font-size: 10px;
  color: var(--muted, #4a5a6a);
  text-transform: uppercase;
  letter-spacing: .1em;
}
#wip-insurance .wip-flag-count {
  font-family: var(--mono, monospace);
  font-size: 10px;
  padding: 2px 8px;
  background: rgba(255,61,87,.12);
  border: 1px solid rgba(255,61,87,.3);
  color: #ff3d57;
  border-radius: 2px;
}
#wip-insurance .wip-matrix-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--mono, monospace);
  font-size: 11px;
  min-width: 700px;
}
#wip-insurance .wip-matrix-table th {
  background: rgba(0,212,255,.06);
  color: var(--muted, #4a5a6a);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: .07em;
  padding: 7px 8px;
  text-align: right;
  border-bottom: 1px solid var(--b2, #2a3340);
  white-space: nowrap;
}
#wip-insurance .wip-matrix-table th:first-child,
#wip-insurance .wip-matrix-table th:nth-child(2) { text-align: left; }
#wip-insurance .wip-matrix-table td {
  padding: 7px 8px;
  border-bottom: 1px solid var(--b1, #1e2530);
  text-align: right;
  color: var(--text, #c8d4e0);
  font-size: 11px;
}
#wip-insurance .wip-matrix-table td:first-child,
#wip-insurance .wip-matrix-table td:nth-child(2) { text-align: left; color: var(--muted, #4a5a6a); }
#wip-insurance .wip-matrix-table tr:hover td { background: rgba(255,255,255,.02); }
#wip-insurance .pct-bar {
  display: inline-block;
  width: 50px;
  height: 3px;
  background: var(--b2, #1e2530);
  border-radius: 2px;
  vertical-align: middle;
  margin-left: 4px;
  position: relative;
  overflow: hidden;
}
#wip-insurance .pct-bar span {
  display: block;
  height: 100%;
  border-radius: 2px;
}
#wip-insurance .td-red    { color: #ff3d57 !important; }
#wip-insurance .td-yellow { color: #ffb300 !important; }
#wip-insurance .td-green  { color: #00e676 !important; }
#wip-insurance .status-red    { color: #ff3d57; font-weight: 600; }
#wip-insurance .status-yellow { color: #ffb300; font-weight: 600; }
#wip-insurance .status-green  { color: #00e676; font-weight: 600; }
#wip-insurance .wip-surety-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
#wip-insurance .wip-surety-card {
  background: rgba(244,168,0,.05);
  border: 1px solid rgba(244,168,0,.2);
  border-radius: 4px;
  padding: 12px 14px;
}
#wip-insurance .wip-surety-title {
  font-family: var(--mono, monospace);
  font-size: 10px;
  color: #f4a800;
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: 8px;
}
#wip-insurance .wip-surety-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5px 0;
  border-bottom: 1px solid rgba(244,168,0,.08);
  font-size: 11px;
}
#wip-insurance .wip-surety-row:last-child { border-bottom: none; }
#wip-insurance .wip-surety-row span:first-child { color: var(--muted, #4a5a6a); }
#wip-insurance .wip-surety-row .ok   { color: #00e676; font-family: var(--mono,monospace); }
#wip-insurance .wip-surety-row .risk { color: #ff3d57; font-family: var(--mono,monospace); }
#wip-insurance .wip-surety-row .warn { color: #ffb300; font-family: var(--mono,monospace); }
@media(max-width:700px) {
  #wip-insurance .wip-surety-grid { grid-template-columns: 1fr; }
}
</style>

</head>
<body class="sector-construction">

<!-- TOPBAR -->
<div class="tb">
  <div class="tb-brand" id="tb-brand">TSM · SOVEREIGN MESH · WIP INTELLIGENCE</div>
  <nav class="tb-nav">
    <a class="tb-link" href="/construction-suite/construction-pro.html">CONSTRUCTION ↗</a>
    <a class="tb-link" href="/finops-suite/financial-ui.html">FINOPS ↗</a>
    <a class="tb-link" href="/healthcare/index.html">HEALTHCARE ↗</a>
  </nav>

<!-- TSM HUB LINK PATCH — tsm-hub-link-patch -->
<style>
.tsm-hub-links-bar{display:flex;gap:.75rem;padding:.6rem 2rem;background:#070c10;border-bottom:1px solid #1e2530;flex-wrap:wrap;align-items:center}
.tsm-hub-link{font-family:'Share Tech Mono',monospace;font-size:.48rem;letter-spacing:.12em;padding:.3rem .8rem;border:1px solid #1e2530;color:#4a5a6a;text-decoration:none;text-transform:uppercase;transition:all .15s}
.tsm-hub-link:hover{color:#00d4ff;border-color:#00d4ff}
.tsm-hub-link.construction:hover{color:#00d4b8;border-color:#00d4b8}
.tsm-hub-link.finops:hover{color:#3a8cf0;border-color:#3a8cf0}
.tsm-hub-link.healthcare:hover{color:#00e87a;border-color:#00e87a}
.tsm-hub-link.insurance:hover{color:#f4a800;border-color:#f4a800}
</style>
<div class="tsm-hub-links-bar">
  <span style="font-family:monospace;font-size:.48rem;color:#304858;letter-spacing:.1em">SUITE HUBS ↗</span>
