<!DOCTYPE html>
<html lang="en">
<head>
<script>
(function(){
  document.addEventListener('contextmenu',function(e){e.preventDefault();return false;});
  document.addEventListener('keydown',function(e){
    if(e.key==='F12'){e.preventDefault();return false;}
    if(e.ctrlKey&&e.shiftKey&&['I','J','C','i','j','c'].includes(e.key)){e.preventDefault();return false;}
    if(e.ctrlKey&&['U','u'].includes(e.key)){e.preventDefault();return false;}
  });
  var t=160;setInterval(function(){if(window.outerWidth-window.innerWidth>t||window.outerHeight-window.innerHeight>t){document.body.innerHTML='';window.location.reload();}},1000);
})();
</script>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>TSM | Healthcare Command v3</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#070d12;--bg2:#0b1520;--bg3:#0f1e2e;
  --panel:#0d1a26;--panel2:#0a1620;
  --border:#1a3048;--border2:#1e3a55;
  --green:#00ff9d;--blue:#00c8ff;--purple:#b06aff;
  --orange:#ff9500;--red:#ff4060;--yellow:#ffd600;
  --text:#c8dff0;--dim:#4a6880;--bright:#e8f4ff;
  --mono:'Share Tech Mono',monospace;
  --ui:'Rajdhani',sans-serif;
  --body:'Exo 2',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:var(--body);font-size:13px;display:flex;flex-direction:column;}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.022) 2px,rgba(0,0,0,.022) 4px);pointer-events:none;z-index:9999;}

/* TICKER */
.ticker{background:#04090f;border-bottom:1px solid var(--border);padding:4px 0;overflow:hidden;white-space:nowrap;flex-shrink:0;}
.ticker-inner{display:inline-block;animation:tick 60s linear infinite;font-family:var(--mono);font-size:10px;color:var(--yellow);letter-spacing:.06em;}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* KPI BAR */
.kpi-bar{display:grid;grid-template-columns:repeat(7,1fr);background:#07101c;border-bottom:1px solid var(--border);flex-shrink:0;}
.kpi-cell{padding:5px 10px;border-right:1px solid var(--border);}
.kpi-cell:last-child{border-right:none;}
.kpi-lbl{font-family:var(--mono);font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:1px;}
.kpi-val{font-family:var(--mono);font-size:12px;font-weight:700;}
.kpi-sub{font-size:9px;color:var(--dim);}

/* TOPBAR */
.topbar{height:36px;background:linear-gradient(90deg,#071420,#0a1e32);border-bottom:1px solid var(--border2);display:flex;align-items:center;padding:0 14px;gap:0;flex-shrink:0;position:relative;}
.topbar::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);opacity:.4;}
.logo{font-family:var(--ui);font-weight:700;font-size:15px;letter-spacing:3px;color:var(--blue);text-shadow:0 0 12px rgba(0,200,255,.5);}
.logo span{color:var(--bright);}
.tb-div{width:1px;height:20px;background:var(--border2);margin:0 12px;}
.tb-sub{font-family:var(--body);font-size:10px;color:var(--dim);letter-spacing:1px;}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:7px;}
.pill{display:flex;align-items:center;gap:4px;padding:2px 8px;border-radius:3px;font-family:var(--ui);font-size:10px;font-weight:600;letter-spacing:1px;border:1px solid;}
.pill.g{color:var(--green);border-color:rgba(0,255,157,.3);background:rgba(0,255,157,.06);}
.pill.b{color:var(--blue);border-color:rgba(0,200,255,.3);background:rgba(0,200,255,.06);}
.pill.p{color:var(--purple);border-color:rgba(176,106,255,.3);background:rgba(176,106,255,.06);}
.dot{width:6px;height:6px;border-radius:50%;}
.dot.g{background:var(--green);box-shadow:0 0 6px var(--green);animation:blink 1.5s infinite;}
.dot.b{background:var(--blue);box-shadow:0 0 6px var(--blue);}
.dot.p{background:var(--purple);box-shadow:0 0 6px var(--purple);}
.clock{font-family:var(--mono);font-size:11px;color:var(--dim);min-width:72px;text-align:right;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* TABBAR */
.tabbar{display:flex;align-items:stretch;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0;height:32px;}
.tab{display:flex;align-items:center;gap:6px;padding:0 15px;font-family:var(--ui);font-size:11px;font-weight:600;letter-spacing:1px;color:var(--dim);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;text-transform:uppercase;}
.tab:hover{color:var(--text);background:rgba(0,200,255,.04);}
.tab.active{color:var(--blue);border-bottom-color:var(--blue);background:rgba(0,200,255,.05);}
.tab-badge{font-family:var(--mono);font-size:9px;padding:1px 5px;border-radius:2px;background:rgba(255,64,96,.2);color:var(--red);}

/* VIEWS */
.view{display:none;flex:1;overflow:hidden;min-height:0;}
.view.active{display:flex;}

/* ══ OVERVIEW ══════════════════════════════════════════ */
#v-overview{flex-direction:row;}

/* Left sidebar */
.ov-sidebar{width:155px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;}
.sb-sec{padding:6px 12px 2px;font-family:var(--mono);font-size:8px;color:var(--dim);letter-spacing:2px;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:7px;padding:5px 12px;cursor:pointer;font-family:var(--ui);font-size:12px;font-weight:500;color:var(--dim);border-left:2px solid transparent;transition:all .15s;}
.nav-item:hover{color:var(--text);background:rgba(0,200,255,.04);}
.nav-item.active{color:var(--blue);border-left-color:var(--blue);background:rgba(0,200,255,.07);}
.nav-icon{font-size:12px;width:14px;text-align:center;}
.nav-badge{margin-left:auto;font-family:var(--mono);font-size:9px;color:var(--red);background:rgba(255,64,96,.15);padding:1px 4px;border-radius:2px;}
.nav-dot{margin-left:auto;width:5px;height:5px;border-radius:50%;}
.nav-dot.g{background:var(--green);box-shadow:0 0 4px var(--green);}
.nav-dot.o{background:var(--orange);box-shadow:0 0 4px var(--orange);}
.sb-stats{margin-top:auto;padding:8px 12px;border-top:1px solid var(--border);}
.sr{display:flex;justify-content:space-between;font-family:var(--mono);font-size:9px;padding:2px 0;}
.sr .lbl{color:var(--dim);}
.sr .val{color:var(--green);}
.sr .val.w{color:var(--orange);}
.sr .val.a{color:var(--red);}

/* Center */
.ov-center{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0;}

/* Deploy bar */
.deploy-bar{background:#07101c;border-bottom:1px solid var(--border);padding:7px 12px;flex-shrink:0;}
.deploy-lbl{font-family:var(--mono);font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.12em;margin-bottom:5px;}
.node-pills{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:7px;}
.npill{font-family:var(--mono);font-size:9px;padding:2px 8px;border:1px solid;border-radius:2px;cursor:pointer;transition:all .15s;font-weight:700;letter-spacing:.06em;opacity:.45;}
.npill.on{opacity:1;}
.npill-medical{color:#00c8ff;border-color:#00c8ff;}
.npill-medical.on{background:rgba(0,200,255,.12);}
.npill-pharmacy{color:#b06aff;border-color:#b06aff;}
.npill-pharmacy.on{background:rgba(176,106,255,.12);}
.npill-insurance{color:#00b8d9;border-color:#00b8d9;}
.npill-insurance.on{background:rgba(0,184,217,.12);}
.npill-financial{color:#ffd600;border-color:#ffd600;}
.npill-financial.on{background:rgba(255,214,0,.1);}
.npill-legal{color:#ff9500;border-color:#ff9500;}
.npill-legal.on{background:rgba(255,149,0,.1);}
.npill-vendors{color:#ff4060;border-color:#ff4060;}
.npill-vendors.on{background:rgba(255,64,96,.1);}
.npill-compliance{color:#00ff9d;border-color:#00ff9d;}
.npill-compliance.on{background:rgba(0,255,157,.08);}
.npill-billing{color:#ffb347;border-color:#ffb347;}
.npill-billing.on{background:rgba(255,179,71,.1);}
.npill-taxprep{color:#e879f9;border-color:#e879f9;}
.npill-taxprep.on{background:rgba(232,121,249,.1);}
.npill-grants{color:#60a5fa;border-color:#60a5fa;}
.npill-grants.on{background:rgba(96,165,250,.1);}

.query-row{display:flex;gap:6px;margin-bottom:6px;}
.query-input{flex:1;background:#081018;border:1px solid var(--border);border-radius:3px;color:var(--text);padding:6px 10px;font-family:var(--mono);font-size:11px;outline:none;transition:border-color .2s;}
.query-input:focus{border-color:var(--yellow);}
.deploy-btn{background:linear-gradient(135deg,rgba(255,214,0,.2),rgba(255,149,0,.1));border:1px solid var(--yellow);color:var(--yellow);font-family:var(--mono);font-size:10px;font-weight:700;padding:6px 16px;cursor:pointer;letter-spacing:.08em;transition:all .2s;border-radius:2px;}
.deploy-btn:hover{background:linear-gradient(135deg,rgba(255,214,0,.35),rgba(255,149,0,.2));}
.deploy-btn:disabled{opacity:.4;cursor:not-allowed;}
.synth-btn{background:linear-gradient(135deg,rgba(176,106,255,.2),rgba(0,200,255,.1));border:1px solid var(--purple);color:var(--purple);font-family:var(--mono);font-size:10px;font-weight:700;padding:6px 16px;cursor:pointer;letter-spacing:.08em;transition:all .2s;border-radius:2px;}
.synth-btn:hover{background:linear-gradient(135deg,rgba(176,106,255,.35),rgba(0,200,255,.2));}
.action-pills{display:flex;gap:4px;flex-wrap:wrap;}
.apill{background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--dim);font-size:9px;padding:3px 9px;cursor:pointer;transition:all .2s;font-family:var(--mono);letter-spacing:.04em;border-radius:2px;}
.apill:hover{background:rgba(255,255,255,.08);color:var(--text);border-color:rgba(255,255,255,.2);}

/* Node grid */
.node-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);flex:1;overflow:hidden;}
.nc{background:var(--panel);padding:10px;display:flex;flex-direction:column;gap:5px;position:relative;overflow:hidden;cursor:pointer;transition:background .15s;animation:fadeUp .4s ease both;}
.nc:hover{background:#111e2d;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.nc:nth-child(1){animation-delay:.05s}.nc:nth-child(2){animation-delay:.08s}.nc:nth-child(3){animation-delay:.11s}
.nc:nth-child(4){animation-delay:.14s}.nc:nth-child(5){animation-delay:.17s}.nc:nth-child(6){animation-delay:.20s}
.nc:nth-child(7){animation-delay:.23s}.nc:nth-child(8){animation-delay:.26s}.nc:nth-child(9){animation-delay:.29s}
.nc:nth-child(10){animation-delay:.32s}
.nc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.nc-medical::before{background:linear-gradient(90deg,#00c8ff,#0070ff);}
.nc-pharmacy::before{background:linear-gradient(90deg,#b06aff,#7030ff);}
.nc-insurance::before{background:linear-gradient(90deg,#00b8d9,#007a99);}
.nc-financial::before{background:linear-gradient(90deg,#ffd600,#ff9500);}
.nc-legal::before{background:linear-gradient(90deg,#ff9500,#ff6000);}
.nc-vendors::before{background:linear-gradient(90deg,#ff4060,#cc0040);}
.nc-compliance::before{background:linear-gradient(90deg,#00ff9d,#00cc70);}
.nc-billing::before{background:linear-gradient(90deg,#ffb347,#ff6000);}
.nc-taxprep::before{background:linear-gradient(90deg,#e879f9,#a020c0);}
.nc-grants::before{background:linear-gradient(90deg,#60a5fa,#2563eb);}

.nc-hdr{display:flex;justify-content:space-between;align-items:center;}
.nc-live{font-family:var(--mono);font-size:8px;display:flex;align-items:center;gap:3px;}
.nc-live.lv{color:var(--green);}
.nc-live.fb{color:var(--yellow);}
.nc-live.rn{color:var(--blue);animation:blink .8s infinite;}
.nc-port{font-family:var(--mono);font-size:8px;color:var(--dim);}
.nc-name{font-family:var(--ui);font-weight:800;font-size:14px;color:var(--bright);letter-spacing:.5px;text-transform:uppercase;}
.nc-desc{font-size:9px;color:var(--dim);line-height:1.4;}
.nc-bar-bg{height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}
.nc-bar-fill{height:100%;border-radius:2px;transition:width 1.2s ease;width:0%;}
.nc-medical .nc-bar-fill{background:linear-gradient(90deg,#00c8ff,#0070ff);box-shadow:0 0 5px rgba(0,200,255,.5);}
.nc-pharmacy .nc-bar-fill{background:linear-gradient(90deg,#b06aff,#7030ff);}
.nc-insurance .nc-bar-fill{background:linear-gradient(90deg,#00b8d9,#007a99);}
.nc-financial .nc-bar-fill{background:linear-gradient(90deg,#ffd600,#ff9500);}
.nc-legal .nc-bar-fill{background:linear-gradient(90deg,#ff9500,#ff6000);}
.nc-vendors .nc-bar-fill{background:linear-gradient(90deg,#ff4060,#cc0040);}
.nc-compliance .nc-bar-fill{background:linear-gradient(90deg,#00ff9d,#00cc70);box-shadow:0 0 5px rgba(0,255,157,.5);}
.nc-billing .nc-bar-fill{background:linear-gradient(90deg,#ffb347,#ff6000);}
.nc-taxprep .nc-bar-fill{background:linear-gradient(90deg,#e879f9,#a020c0);}
.nc-grants .nc-bar-fill{background:linear-gradient(90deg,#60a5fa,#2563eb);}

.nc-output{font-family:var(--mono);font-size:8px;color:var(--dim);line-height:1.5;flex:1;overflow:hidden;max-height:72px;}
.nc-output.active{color:var(--text);}
.nc-footer{display:flex;justify-content:space-between;align-items:center;margin-top:auto;}
.nc-open-btn{background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--dim);font-family:var(--mono);font-size:8px;padding:3px 8px;cursor:pointer;transition:all .2s;border-radius:2px;}
.nc-open-btn:hover{background:rgba(255,255,255,.09);color:var(--text);}
.nc-stat{font-family:var(--mono);font-size:8px;color:var(--dim);}
.nc-stat.lv{color:var(--green);}
.nc-stat.fb{color:var(--yellow);}
.nc-stat.rn{color:var(--blue);animation:blink .8s infinite;}

/* Right sidebar — Sovereign */
.ov-right{width:220px;flex-shrink:0;background:var(--panel);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;}
.sov-hdr{padding:10px 12px;border-bottom:1px solid var(--border);background:rgba(0,0,0,.3);}
.sov-title{font-family:var(--ui);font-size:13px;font-weight:700;color:var(--purple);letter-spacing:.05em;}
.sov-sub{font-size:8px;color:var(--dim);margin-top:2px;text-transform:uppercase;letter-spacing:.08em;line-height:1.4;}
.sov-node-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:3px;padding:8px 10px;border-bottom:1px solid var(--border);}
.sov-nbtn{border:1px solid;padding:4px 5px;font-family:var(--mono);font-size:8px;font-weight:700;cursor:pointer;letter-spacing:.05em;transition:all .15s;border-radius:2px;text-align:center;opacity:.4;}
.sov-nbtn.on{opacity:1;}
.sov-section{padding:8px 12px;border-bottom:1px solid var(--border);flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px;}
.sov-sec-title{font-family:var(--mono);font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;}
.synth-out{font-family:var(--mono);font-size:9px;color:var(--text);line-height:1.6;white-space:pre-wrap;flex:1;overflow-y:auto;}
.conf-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:3px;}
.conf-item{background:rgba(255,255,255,.03);padding:4px 6px;border-radius:3px;}
.conf-lbl{font-size:8px;color:var(--dim);}
.conf-val{font-family:var(--mono);font-size:10px;font-weight:700;color:var(--green);}

/* ══ LOWER SECTION (matrix + strategist) ══ */
.ov-lower{display:flex;flex-shrink:0;height:200px;border-top:1px solid var(--border);overflow:hidden;}
.matrix-panel{width:260px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);padding:10px 12px;overflow-y:auto;}
.panel-title{font-family:var(--mono);font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;}
.mrow{display:flex;align-items:center;gap:6px;margin-bottom:5px;}
.mlbl{font-family:var(--mono);font-size:8px;color:var(--dim);width:70px;flex-shrink:0;}
.mbar-bg{flex:1;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;}
.mbar-fill{height:100%;border-radius:2px;transition:width 1s ease;}
.mpct{font-family:var(--mono);font-size:9px;width:30px;text-align:right;color:var(--text);}
.strat-panel{flex:1;background:var(--panel);display:flex;flex-direction:column;overflow:hidden;}
.strat-hdr{padding:8px 14px;border-bottom:1px solid var(--border);background:rgba(0,0,0,.2);}
.strat-title{font-family:var(--ui);font-weight:700;font-size:13px;color:var(--purple);}
.strat-sub{font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;}
.ctx-tabs{display:flex;gap:2px;padding:6px 10px;border-bottom:1px solid var(--border);flex-wrap:wrap;}
.ctx-tab{font-family:var(--mono);font-size:9px;padding:2px 8px;border:1px solid var(--border);color:var(--dim);cursor:pointer;border-radius:2px;transition:all .15s;}
.ctx-tab:hover{color:var(--text);}
.ctx-tab.active{color:var(--purple);border-color:rgba(176,106,255,.5);background:rgba(176,106,255,.08);}
.bnca-wrap{flex:1;overflow-y:auto;padding:8px 12px;display:flex;flex-direction:column;gap:6px;}
.bnca-intro{font-family:var(--mono);font-size:9px;color:var(--dim);padding-bottom:6px;border-bottom:1px solid var(--border);}
.bnca-item{display:flex;gap:8px;animation:fadeUp .4s ease both;}
.bnca-n{font-family:var(--mono);font-size:9px;color:var(--dim);flex-shrink:0;padding-top:2px;}
.bnca-tag{font-family:var(--mono);font-size:8px;padding:1px 5px;border-radius:2px;font-weight:700;}
.bnca-tag.u{background:rgba(255,64,96,.2);color:var(--red);}
.bnca-tag.v{background:rgba(255,149,0,.2);color:var(--orange);}
.bnca-tag.gr{background:rgba(0,255,157,.1);color:var(--green);}
.bnca-txt{font-size:10px;color:var(--text);margin-top:3px;line-height:1.4;}
.term-wrap{padding:6px 12px;border-top:1px solid var(--border);display:flex;gap:6px;align-items:center;flex-shrink:0;}
.term-prompt{font-family:var(--mono);font-size:10px;color:var(--purple);}
.term-in{flex:1;background:#050c15;border:1px solid var(--border);border-radius:3px;color:var(--text);padding:5px 8px;font-family:var(--mono);font-size:10px;outline:none;}
.term-in:focus{border-color:var(--purple);}
.run-btn{background:rgba(176,106,255,.15);border:1px solid rgba(176,106,255,.4);color:var(--purple);font-family:var(--mono);font-size:9px;padding:5px 10px;cursor:pointer;border-radius:2px;transition:all .2s;}
.run-btn:hover{background:rgba(176,106,255,.3);}

/* ══ HOW TO ══ */
#v-howto{flex-direction:column;overflow-y:auto;padding:24px 32px;}
.howto-header{margin-bottom:24px;}
.howto-h1{font-family:var(--ui);font-size:28px;font-weight:700;color:var(--bright);letter-spacing:2px;}
.howto-h1 span{color:var(--blue);}
.howto-sub{font-size:13px;color:var(--dim);margin-top:6px;max-width:600px;line-height:1.6;}
.steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;}
.step-card{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:16px;transition:border-color .2s;}
.step-card:hover{border-color:var(--border2);}
.step-num{font-family:var(--mono);font-size:9px;color:var(--dim);letter-spacing:2px;margin-bottom:8px;}
.step-icon{font-size:24px;margin-bottom:8px;}
.step-title{font-family:var(--ui);font-size:15px;font-weight:700;color:var(--bright);margin-bottom:6px;}
.step-desc{font-size:11px;color:var(--dim);line-height:1.6;margin-bottom:8px;}
.step-tip{font-family:var(--mono);font-size:9px;color:var(--blue);background:rgba(0,200,255,.06);border:1px solid rgba(0,200,255,.15);border-radius:3px;padding:5px 8px;line-height:1.5;}
.howto-note{background:rgba(0,200,255,.05);border:1px solid rgba(0,200,255,.2);border-radius:6px;padding:14px;display:flex;gap:10px;font-size:11px;color:var(--dim);line-height:1.6;}
.ni{font-size:18px;}

/* ══ DOC UPLOAD ══ */
#v-upload{flex-direction:column;overflow-y:auto;padding:20px 28px;}
.upload-header{margin-bottom:18px;}
.upload-h1{font-family:var(--ui);font-size:24px;font-weight:700;color:var(--bright);letter-spacing:2px;}
.upload-h1 span{color:var(--green);}
.upload-sub{font-size:12px;color:var(--dim);margin-top:4px;line-height:1.5;}
.upload-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.drop-zone{border:2px dashed var(--border2);border-radius:8px;padding:28px;text-align:center;cursor:pointer;transition:all .2s;background:var(--panel);}
.drop-zone:hover,.drop-zone.drag{border-color:var(--green);background:rgba(0,255,157,.03);}
.drop-icon{font-size:32px;margin-bottom:8px;}
.drop-title{font-family:var(--ui);font-size:16px;font-weight:700;color:var(--bright);margin-bottom:4px;}
.drop-sub{font-size:11px;color:var(--dim);margin-bottom:12px;}
.drop-types{display:flex;gap:4px;justify-content:center;flex-wrap:wrap;margin-bottom:14px;}
.dtype{font-family:var(--mono);font-size:9px;padding:2px 7px;border:1px solid var(--border2);border-radius:2px;color:var(--dim);}
#file-input{display:none;}
.upload-btn{background:rgba(0,255,157,.1);border:1px solid rgba(0,255,157,.3);color:var(--green);font-family:var(--ui);font-size:12px;font-weight:600;padding:7px 18px;cursor:pointer;border-radius:3px;transition:all .2s;}
.upload-btn:hover{background:rgba(0,255,157,.2);}
.analyze-row{display:flex;align-items:center;gap:10px;margin-top:10px;}
.analyze-btn{background:linear-gradient(135deg,rgba(0,255,157,.15),rgba(0,200,255,.1));border:1px solid rgba(0,255,157,.4);color:var(--green);font-family:var(--mono);font-size:11px;padding:8px 20px;cursor:pointer;border-radius:3px;transition:all .2s;letter-spacing:.05em;}
.analyze-btn:disabled{opacity:.3;cursor:not-allowed;}
.analyze-btn:not(:disabled):hover{background:linear-gradient(135deg,rgba(0,255,157,.3),rgba(0,200,255,.2));}
.analyze-note{font-family:var(--mono);font-size:10px;color:var(--dim);}
.file-queue{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:14px;}
.fq-title{font-family:var(--mono);font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;}
.fq-empty{font-size:11px;color:var(--dim);text-align:center;padding:20px;}
.fq-item{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(26,48,72,.5);}
.fq-icon{font-size:16px;}
.fq-info{flex:1;min-width:0;}
.fq-name{font-family:var(--mono);font-size:10px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fq-meta{font-size:9px;color:var(--dim);}
.fq-prog{height:2px;background:rgba(255,255,255,.06);border-radius:1px;overflow:hidden;margin-top:3px;}
.fq-prog-fill{height:100%;background:linear-gradient(90deg,var(--green),var(--blue));transition:width .5s;width:0%;}
.fq-status{font-family:var(--mono);font-size:9px;}
.fq-status.ready{color:var(--green);}
.fq-status.proc{color:var(--yellow);}
.fq-remove{color:var(--red);cursor:pointer;font-size:12px;padding:0 4px;}

/* ══ ASK AI ══ */
#v-askai{flex-direction:row;}
.ai-sidebar{width:210px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);padding:12px;display:flex;flex-direction:column;gap:6px;overflow-y:auto;}
.ai-sb-title{font-family:var(--mono);font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.12em;margin-bottom:4px;}
.ai-prompt-btn{display:flex;align-items:flex-start;gap:6px;padding:8px;background:var(--panel);border:1px solid var(--border);border-radius:4px;cursor:pointer;transition:all .15s;font-size:11px;color:var(--dim);line-height:1.4;}
.ai-prompt-btn:hover{border-color:var(--border2);color:var(--text);background:var(--panel2);}
.pi{font-size:13px;flex-shrink:0;}
.ai-model-badge{margin-top:auto;background:rgba(176,106,255,.08);border:1px solid rgba(176,106,255,.2);border-radius:4px;padding:8px;font-family:var(--mono);font-size:9px;color:var(--purple);text-align:center;line-height:1.6;}
.ai-model-badge span{color:var(--bright);font-weight:700;}
.ai-main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.chat-window{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;}
.msg{display:flex;gap:10px;}
.msg-avatar{font-size:18px;flex-shrink:0;margin-top:2px;}
.msg-body{flex:1;min-width:0;}
.msg-label{font-family:var(--mono);font-size:8px;color:var(--dim);letter-spacing:.1em;margin-bottom:4px;}
.msg-bubble{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:10px 12px;font-size:12px;color:var(--text);line-height:1.6;}
.msg.user .msg-label{color:var(--blue);}
.msg.user .msg-bubble{background:rgba(0,200,255,.06);border-color:rgba(0,200,255,.2);}
.typing-indicator{display:flex;gap:4px;align-items:center;padding:10px 12px;}
.typing-dot{width:7px;height:7px;border-radius:50%;background:var(--purple);animation:tdot .9s infinite;}
.typing-dot:nth-child(2){animation-delay:.15s;}
.typing-dot:nth-child(3){animation-delay:.3s;}
@keyframes tdot{0%,100%{opacity:.3;transform:scale(.8)}50%{opacity:1;transform:scale(1)}}
.ai-input-row{padding:10px 14px;border-top:1px solid var(--border);display:flex;gap:8px;flex-shrink:0;}
.ai-textarea{flex:1;background:#050c15;border:1px solid var(--border);border-radius:4px;color:var(--text);padding:8px 10px;font-family:var(--body);font-size:12px;resize:none;outline:none;min-height:36px;max-height:120px;line-height:1.5;}
.ai-textarea:focus{border-color:var(--purple);}
.ai-send{background:linear-gradient(135deg,rgba(176,106,255,.25),rgba(0,200,255,.15));border:1px solid rgba(176,106,255,.5);color:var(--purple);font-family:var(--mono);font-size:10px;font-weight:700;padding:8px 16px;cursor:pointer;border-radius:4px;transition:all .2s;white-space:nowrap;}
.ai-send:hover{background:linear-gradient(135deg,rgba(176,106,255,.4),rgba(0,200,255,.25));}
.ai-send:disabled{opacity:.35;cursor:not-allowed;}

/* ══ AUDIT CATEGORIES ══ */
#v-audits{flex-direction:column;overflow-y:auto;padding:16px 24px;}
.audit-h1{font-family:var(--ui);font-size:24px;font-weight:700;color:var(--bright);letter-spacing:2px;margin-bottom:4px;}
.audit-h1 span{color:var(--red);}
.audit-sub{font-size:12px;color:var(--dim);margin-bottom:16px;}
.audit-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.audit-card{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:14px;cursor:pointer;transition:all .2s;overflow:hidden;}
.audit-card:hover{border-color:var(--border2);}
.audit-card.open{border-color:rgba(255,64,96,.4);}
.audit-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.audit-icon{font-size:22px;}
.audit-roi-val{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--green);text-align:right;}
.audit-roi-lbl{font-size:9px;color:var(--dim);text-align:right;}
.audit-title{font-family:var(--ui);font-size:15px;font-weight:700;color:var(--bright);margin-bottom:5px;}
.audit-desc{font-size:11px;color:var(--dim);line-height:1.5;margin-bottom:8px;}
.audit-tags{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;}
.atag{font-family:var(--mono);font-size:8px;padding:2px 6px;border:1px solid var(--border2);border-radius:2px;color:var(--dim);}
.audit-expand{display:none;border-top:1px solid var(--border);padding-top:10px;margin-top:4px;}
.audit-card.open .audit-expand{display:block;}
.ae-title{font-family:var(--mono);font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px;}
.ae-list{display:flex;flex-direction:column;gap:5px;}
.ae-item{font-size:11px;color:var(--text);line-height:1.4;padding-left:10px;border-left:2px solid var(--border2);}
.audit-cta{margin-top:10px;font-family:var(--mono);font-size:9px;color:var(--red);cursor:pointer;}
.audit-cta:hover{color:var(--orange);}

/* ══ STATUS BAR ══ */
.statusbar{height:22px;background:#04090f;border-top:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:0;flex-shrink:0;overflow:hidden;}
.sb{font-family:var(--mono);font-size:9px;color:var(--dim);white-space:nowrap;}
.sb .hi{color:var(--green);}
.sb .w{color:var(--orange);}
.sb-sep{color:var(--border2);margin:0 10px;}

/* ══ MODAL ══ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:1000;display:none;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--panel);border:1px solid var(--border2);border-radius:8px;width:680px;max-height:78vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.8);}
.modal-hdr{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,.3);}
.modal-title{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--text);}
.modal-close{background:none;border:none;color:var(--dim);cursor:pointer;font-size:18px;}
.modal-close:hover{color:var(--red);}
.modal-body{flex:1;overflow-y:auto;padding:14px 16px;}
.modal-out{font-family:var(--mono);font-size:10px;color:var(--text);line-height:1.8;white-space:pre-wrap;}
.modal-in-row{padding:10px 16px;border-top:1px solid var(--border);display:flex;gap:8px;}
.modal-in{flex:1;background:#050c15;border:1px solid var(--border);border-radius:4px;color:var(--text);padding:7px 10px;font-family:var(--mono);font-size:10px;outline:none;}
.modal-in:focus{border-color:var(--yellow);}
.modal-send{background:var(--yellow);border:none;color:#07101c;font-weight:700;padding:7px 14px;border-radius:4px;cursor:pointer;font-family:var(--mono);font-size:10px;}

/* RELAY FAB */
.relay-fab{position:fixed;bottom:30px;right:20px;z-index:9000;padding:9px 16px;background:linear-gradient(135deg,#f0b400,#b8860b);color:#000;border:none;border-radius:20px;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.08em;cursor:pointer;box-shadow:0 4px 20px rgba(240,180,0,.35);display:flex;align-items:center;gap:6px;transition:all .2s;}
.relay-fab:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(240,180,0,.5);}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:#1a3050;border-radius:2px;}
</style>
</head>
<body>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-inner">CLAIMS BACKLOG — 247 PENDING ADJUDICATIONS &nbsp;//&nbsp; DENIAL RATE — 18.4% VS TARGET 9% &nbsp;//&nbsp; PAYOR AUTH NOTICE — HIGH PRIOR-AUTH FRICTION &nbsp;//&nbsp; COMPLIANCE WATCH — DOCUMENTATION GAPS FLAGGED &nbsp;//&nbsp; PHARMACY WATCH — DEA + INTERACTION REVIEW PENDING &nbsp;//&nbsp; GRANTS / TAX PREP — DEADLINE PREP WINDOW OPEN &nbsp;//&nbsp; REVENUE CYCLE — BILLING LAG 14 DAYS AVG &nbsp;//&nbsp; LEGAL — CONTRACT RENEWAL QUEUE 3 PENDING &nbsp;//&nbsp; VENDOR — SUPPLY CHAIN RISK LEVEL ELEVATED &nbsp;//&nbsp; NODES ONLINE — 10 / 10 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;CLAIMS BACKLOG — 247 PENDING ADJUDICATIONS &nbsp;//&nbsp; DENIAL RATE — 18.4% VS TARGET 9% &nbsp;//&nbsp; PAYOR AUTH NOTICE — HIGH PRIOR-AUTH FRICTION &nbsp;//&nbsp; COMPLIANCE WATCH — DOCUMENTATION GAPS FLAGGED &nbsp;//&nbsp; PHARMACY WATCH — DEA + INTERACTION REVIEW PENDING &nbsp;//&nbsp; GRANTS / TAX PREP — DEADLINE PREP WINDOW OPEN &nbsp;//&nbsp; REVENUE CYCLE — BILLING LAG 14 DAYS AVG &nbsp;//&nbsp; LEGAL — CONTRACT RENEWAL QUEUE 3 PENDING &nbsp;//&nbsp; VENDOR — SUPPLY CHAIN RISK LEVEL ELEVATED &nbsp;//&nbsp; NODES ONLINE — 10 / 10</div>
</div>

<!-- KPI BAR -->
<div class="kpi-bar">
  <div class="kpi-cell"><div class="kpi-lbl">Revenue at Risk</div><div class="kpi-val" style="color:#ff4060">$2.1M</div><div class="kpi-sub">active rev-cycle value</div></div>
  <div class="kpi-cell"><div class="kpi-lbl">Claims Pending</div><div class="kpi-val" style="color:#ffd600">247</div><div class="kpi-sub">adjudication queue</div></div>
  <div class="kpi-cell"><div class="kpi-lbl">Compliance Score</div><div class="kpi-val" style="color:#00ff9d">84%</div><div class="kpi-sub">HIPAA + CMS + OIG</div></div>
  <div class="kpi-cell"><div class="kpi-lbl">Denial Rate</div><div class="kpi-val" style="color:#ff9500">18.4%</div><div class="kpi-sub">above target window</div></div>
  <div class="kpi-cell"><div class="kpi-lbl">Nodes Live</div><div class="kpi-val" style="color:#00c8ff">10 / 10</div><div class="kpi-sub">deploy-ready AI mesh</div></div>
  <div class="kpi-cell"><div class="kpi-lbl">Action Window</div><div class="kpi-val" style="color:#b06aff">72 HRS</div><div class="kpi-sub">recommended escalation</div></div>
  <div class="kpi-cell"><div class="kpi-lbl">Priority Date</div><div class="kpi-val" style="color:#00c8ff">APR 15</div><div class="kpi-sub">payer + compliance milestone</div></div>
</div>

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo">TSM <span>|</span></div>
  <span style="font-family:var(--ui);font-weight:700;font-size:14px;color:var(--bright);letter-spacing:2px;margin-left:6px;">HEALTHCARE COMMAND</span>
  <div class="tb-div"></div>
  <div class="tb-sub">◌ TRIPARTITE HEALTH INTELLIGENCE SYSTEM · v3.0</div>
  <div class="tb-right">
    <div class="pill g"><div class="dot g"></div> STRATEGIST ONLINE</div>
    <div class="pill b"><div class="dot b"></div> 10-NODE FLEET</div>
    <div class="pill p"><div class="dot p"></div> GROQ LLAMA-3.3-70B</div>
    <div class="clock" id="clock">--:--:-- UTC</div>
  </div>
</div>

<!-- TABBAR -->
<div class="tabbar">
  <div class="tab active" data-view="v-overview"><span class="ti">◉</span> Overview</div>
  <div class="tab" data-view="v-howto"><span class="ti">📖</span> How To Use</div>
  <div class="tab" data-view="v-upload"><span class="ti">📂</span> Doc Uploader</div>
  <div class="tab" data-view="v-askai"><span class="ti">🧠</span> Ask AI</div>
  <div class="tab" data-view="v-audits"><span class="ti">🔍</span> Audit Categories <span class="tab-badge">6</span></div>
</div>

<!-- ══ VIEW: OVERVIEW ══ -->
<div class="view active" id="v-overview">

  <!-- Left sidebar -->
  <div class="ov-sidebar">
    <div class="sb-sec">Portfolio</div>
    <div class="nav-item active"><span class="nav-icon">◉</span> Overview <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">⬡</span> Health Triad <div class="nav-dot g"></div></div>
    <div class="sb-sec" style="margin-top:4px;">Playbooks</div>
    <div class="nav-item" onclick="setQuery(this.dataset.q)" data-q="Review denial exposure, claims backlog, compliance drift, and produce the best next course of action across the full healthcare command."><span class="nav-icon">🎯</span> Claim Recovery <div class="nav-dot g"></div></div>
    <div class="nav-item" onclick="setQuery(this.dataset.q)" data-q="Conduct a comprehensive audit sweep — identify compliance gaps, documentation failures, and billing irregularities."><span class="nav-icon">🔍</span> Audit Sweep <span class="nav-badge">236k</span></div>
    <div class="nav-item" onclick="setQuery(this.dataset.q)" data-q="Analyze margin performance across all service lines, identify cost drivers, and recommend optimization paths."><span class="nav-icon">📊</span> Margin Review</div>
    <div class="nav-item" onclick="setQuery(this.dataset.q)" data-q="Review all payer contracts for underpayment risk, reimbursement rate gaps, and renegotiation windows."><span class="nav-icon">📋</span> Payer Contracts</div>
    <div class="nav-item" onclick="setQuery(this.dataset.q)" data-q="Assess vendor supply chain risks, contract compliance, and critical dependency exposure across all vendors."><span class="nav-icon">📦</span> Vendor Risk <span class="nav-badge">2</span></div>
    <div class="nav-item" onclick="setQuery(this.dataset.q)" data-q="Analyze cash flow patterns, AR aging, collections efficiency, and liquidity risk."><span class="nav-icon">💰</span> Cash Flow</div>
    <div class="sb-sec" style="margin-top:4px;">Sector Nodes</div>
    <div class="nav-item"><span class="nav-icon">🩺</span> Medical <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">💊</span> Pharmacy <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">🛡</span> Insurance <span class="nav-badge">247</span></div>
    <div class="nav-item"><span class="nav-icon">💰</span> Financial <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">⚖️</span> Legal <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">📦</span> Vendors <div class="nav-dot o"></div></div>
    <div class="nav-item"><span class="nav-icon">✅</span> Compliance <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">🧾</span> Billing <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">🧮</span> Tax Prep <div class="nav-dot g"></div></div>
    <div class="nav-item"><span class="nav-icon">🏛</span> Grants <div class="nav-dot g"></div></div>
    <div class="sb-stats">
      <div class="sr"><span class="lbl">COMPLIANCE</span><span class="val">84%</span></div>
      <div class="sr"><span class="lbl">CLAIMS PEND</span><span class="val w">247</span></div>
      <div class="sr"><span class="lbl">DEA FLAGS</span><span class="val a">3</span></div>
      <div class="sr"><span class="lbl">RISK SCORE</span><span class="val">MED</span></div>
      <div class="sr"><span class="lbl">NODES</span><span class="val">10 / 10</span></div>
      <div class="sr"><span class="lbl">LAST SYNTH</span><span class="val" id="last-synth">—</span></div>
    </div>
  </div>

  <!-- Center -->
  <div class="ov-center">

    <!-- Deploy bar -->
    <div class="deploy-bar">
      <div class="deploy-lbl">Deploy Query to Nodes</div>
      <div class="node-pills">
        <div class="npill npill-medical on" data-node="medical" onclick="togglePill(this)">MEDICAL</div>
        <div class="npill npill-pharmacy on" data-node="pharmacy" onclick="togglePill(this)">PHARMACY</div>
        <div class="npill npill-insurance on" data-node="insurance" onclick="togglePill(this)">INSURANCE</div>
        <div class="npill npill-financial on" data-node="financial" onclick="togglePill(this)">FINANCIAL</div>
        <div class="npill npill-legal on" data-node="legal" onclick="togglePill(this)">LEGAL</div>
        <div class="npill npill-vendors on" data-node="vendors" onclick="togglePill(this)">VENDORS</div>
        <div class="npill npill-compliance on" data-node="compliance" onclick="togglePill(this)">COMPLIANCE</div>
        <div class="npill npill-billing on" data-node="billing" onclick="togglePill(this)">BILLING</div>
        <div class="npill npill-taxprep on" data-node="taxprep" onclick="togglePill(this)">TAX PREP</div>
        <div class="npill npill-grants on" data-node="grants" onclick="togglePill(this)">GRANTS</div>
      </div>
      <div class="query-row">
        <input class="query-input" id="main-query" value="Review denial exposure, claims backlog, compliance drift, and produce the best next course of action across the full healthcare command.">
        <button class="deploy-btn" id="deploy-btn" onclick="deployNodes()">DEPLOY</button>
        <button class="synth-btn" id="synth-btn" onclick="synthesize()">SYNTHESIZE</button>
      </div>
      <div class="action-pills">
        <div class="apill" onclick="deployNodes('Upload and analyze clinical compliance document for HIPAA gaps and documentation failures')">UPLOAD DOCUMENT</div>
        <div class="apill" onclick="deployNodes('Run full cross-node analysis: denial trends, compliance posture, revenue cycle health, and recommended actions')">FULL ANALYSIS</div>
        <div class="apill" onclick="deployNodes('Extract all key metrics, KPIs, risk indicators, and financial data across all nodes')">EXTRACT</div>
        <div class="apill" onclick="deployNodes('Scan all nodes for compliance gaps, HIPAA violations, documentation failures, and audit exposure')">COMPLIANCE SCAN</div>
        <div class="apill" onclick="deployNodes('Extract financial performance data: revenue, collections, AR aging, margin analysis')">FINANCIAL EXTRACT</div>
        <div class="apill" onclick="synthesize()">EXEC SUMMARY</div>
      </div>
    </div>

    <!-- Node grid -->
    <div class="node-grid" id="node-grid">
      <div class="nc nc-medical" onclick="openNode('medical')">
        <div class="nc-hdr"><div class="nc-live lv"><div class="dot g"></div> LIVE</div><div class="nc-port">PORT 5006</div></div>
        <div class="nc-name">Medical</div>
        <div class="nc-desc">CPT Billing · Clinical Compliance · Audit</div>
        <div class="nc-bar-bg"><div class="nc-bar-fill" id="bar-medical" style="width:88%"></div></div>
        <div class="nc-output" id="out-medical">Waiting for deploy.</div>
        <div class="nc-footer"><button class="nc-open-btn">OPEN APP</button><div class="nc-stat" id="stat-medical">88% · READY</div></div>
      </div>
      <div class="nc nc-pharmacy" onclick="openNode('pharmacy')">
        <div class="nc-hdr"><div class="nc-live lv"><div class="dot g"></div> LIVE</div><div class="nc-port">PORT 5007</div></div>
        <div class="nc-name">Pharmacy</div>
