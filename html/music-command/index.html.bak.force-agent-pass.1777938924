<div id="tsm-smart-assistant">
  <div id="tsm-assistant-header">
    <span id="tsm-assistant-title">🤖 TSM Assistant</span>
    <button id="tsm-assistant-toggle" onclick="tsmAssistantToggle()">▼</button>
  </div>
  <div id="tsm-assistant-body">
    <div id="tsm-assistant-msg">👋 Welcome! Start by clicking <strong>1 · DNA</strong> above to set your artist style. This makes every AI output sound like you.</div>
    <div id="tsm-assistant-actions">
      <button class="tsm-ast-btn" onclick="switchTab('dna');tsmAssistantUpdate('dna')">Go to Artist DNA →</button>
    </div>
  </div>
</div>

<script id="tsm-assistant-engine">
(function(){
  let collapsed = false;

  window.tsmAssistantToggle = function() {
    collapsed = !collapsed;
    document.getElementById('tsm-assistant-body').style.display = collapsed ? 'none' : 'block';
    document.getElementById('tsm-assistant-toggle').textContent = collapsed ? '▲' : '▼';
  };

  const STATES = {
    dna: {
      msg: '🧬 Fill in your <strong>Style</strong>, <strong>Influences</strong>, and <strong>Vocab</strong> fields. The more detail you add, the more the AI sounds like you. Hit <strong>Save DNA Profile</strong> when done.',
      actions: [{ label: 'Done → Go to Draft', fn: "switchTab('draft');tsmAssistantUpdate('draft_empty')" }]
    },
    draft_empty: {
      msg: '✏️ <strong>Paste your lyrics</strong> into the text area below. Even 2 lines works. Then hit <strong>Run Agent Pass</strong> to get 3 AI-generated options.',
      actions: [{ label: 'Load Demo to Try', fn: "loadDemoContent();tsmAssistantUpdate('draft_ready')" }]
    },
    draft_ready: {
      msg: '▶️ Lyrics are in! Hit <strong>Run Agent Pass</strong> to generate 3 different versions. The AI will analyze structure, hook strength, and cadence.',
      actions: [{ label: 'Run Agent Pass', fn: "runDraftAnalysis();tsmAssistantUpdate('options_shown')" }]
    },
    options_shown: {
      msg: '👆 <strong>Click the option card</strong> that hits hardest. Each one is a different take on your lyrics. Once selected, you can Save it, Load it to Draft, or Refine it in Revision.',
      actions: [
        { label: 'Save Best to Bank', fn: "saveToBank('draft');tsmAssistantUpdate('saved')" },
        { label: 'Refine in Revision', fn: "sendToRevision();tsmAssistantUpdate('revision')" }
      ]
    },
    saved: {
      msg: '💾 Saved! Now use the <strong>⚡ button</strong> bottom-right to place ad-libs or build a bridge. Or go to <strong>Revision Mode</strong> to tighten specific lines.',
      actions: [
        { label: '⚡ Place Ad-libs', fn: "placeAdlibs();tsmAssistantUpdate('adlibs')" },
        { label: 'Refine in Revision', fn: "switchTab('revision');tsmAssistantUpdate('revision')" }
      ]
    },
    revision: {
      msg: '✂️ In <strong>Revision Mode</strong>: ① Paste current draft in box 1 ② Tell AI what to change in box 2 ③ Protect your best lines in box 3 ④ Hit <strong>Run Revision</strong>.',
      actions: [{ label: 'Run Revision Now', fn: "runRevision();tsmAssistantUpdate('revised')" }]
    },
    revised: {
      msg: '✅ Revised! Pick the version you like. Then either <strong>Save to Bank</strong> or use the <strong>⚡ Generate Hook</strong> to craft a catchier hook.',
      actions: [
        { label: 'Save to Bank', fn: "saveToBank('rev');tsmAssistantUpdate('saved')" },
        { label: 'Generate Hook', fn: "generateHook();tsmAssistantUpdate('hook')" }
      ]
    },
    adlibs: {
      msg: '🎤 Ad-libs placed! Review them and keep what fits your delivery. Now go to <strong>Song Bank</strong> to review everything saved, then <strong>Export TXT</strong> when ready.',
      actions: [
        { label: 'View Song Bank', fn: "switchTab('songbank');tsmAssistantUpdate('bank')" },
        { label: 'Export Song', fn: "exportCurrentMusicSession()" }
      ]
    },
    bank: {
      msg: '🗂️ Your saved pieces are here. Click <strong>Load</strong> on any card to bring it back for more work. When your full song is ready, go to <strong>Studio Tools → Export TXT</strong>.',
      actions: [
        { label: 'Go to Studio Tools', fn: "switchTab('studio');tsmAssistantUpdate('studio')" }
      ]
    },
    studio: {
      msg: '🎛️ Final polish time! Use <strong>Rhyme Engine</strong> for rhyme schemes, <strong>Syllable Counter</strong> to match flow, or <strong>Ad-lib Placer</strong> for performance markers. Then hit <strong>Export TXT</strong>.',
      actions: [
        { label: 'Export My Song', fn: "exportCurrentMusicSession()" },
        { label: 'Start New Song', fn: "switchTab('draft');document.getElementById('draft-input').value='';tsmAssistantUpdate('draft_empty')" }
      ]
    },
    hook: {
      msg: '🎣 Hook generated! Compare it to your original. If it\'s stronger, <strong>Save to Bank</strong>. Then build a bridge or go to <strong>Studio Tools</strong> to finalize.',
      actions: [
        { label: 'Build Bridge', fn: "buildBridge();tsmAssistantUpdate('saved')" },
        { label: 'Export Song', fn: "exportCurrentMusicSession()" }
      ]
    }
  };

  window.tsmAssistantUpdate = function(action) {
    const state = STATES[action];
    if (!state) return;
    if (window.showAssistant) window.showAssistant(state.msg, state.actions);
  };

  window.tsmAssistantUpdate('draft_empty');
})();
</script>
<script id="tsm-callgroq-fix">
// Override callGroq to route correctly based on context
const _baseCallGroq = window.callGroq;
window.callGroq = async function(systemPrompt, userPrompt, loadingId, callback) {
  const loading = document.getElementById(loadingId);
  if (loading) { loading.classList.add('show'); }
  try {
    // Route revision calls to revision endpoint
    const isRevision = loadingId === 'rev-loading';
    const isGenerate = loadingId === 'gen-loading';
    
    let url, body;
    if (isRevision) {
      url = '/api/music/revision/generate';
      const current = document.getElementById('rev-current')?.value || userPrompt;
      const style = document.getElementById('rev-format')?.value || '';
      const mood = document.getElementById('rev-options-text')?.value || '';
      body = { lyrics: current, style, mood, prompt: userPrompt };
    } else {
      url = '/api/music/agent-pass';
      body = { prompt: userPrompt || systemPrompt || document.getElementById('draft-input')?.value || '' };
    }

    const resp = await fetch(url, {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)});
    const data = await resp.json();

    if (loading) loading.classList.remove('show');

    // Handle structured options
    if (data.options && data.options.length > 0) {
      showDraftOutput && showDraftOutput(data);
      tsmAssistantUpdate && tsmAssistantUpdate('options_shown');
      return;
    }

    const text = data.revised || data.output || data.text || data.result || '';
    callback(text);
    updateSessionTime && updateSessionTime();
  } catch(e) {
    if (loading) loading.classList.remove('show');
    callback('Error: ' + e.message);
  }
};



</script>
<script id="tsm-rev-display-fix">
// Fix revision output display — server returns {revised} not {options}
const _origRunRevision = window.runRevision;
window.runRevision = async function() {
  const current = document.getElementById('rev-current')?.value?.trim();
  const edit = document.getElementById('rev-edit')?.value?.trim();
  const protect = document.getElementById('rev-protect')?.value?.trim();
  const options = document.getElementById('rev-options-text')?.value?.trim();
  const agent = document.getElementById('rev-agent')?.value || 'ZAY';
  if (!current) { showNotif('Add your draft first'); return; }
  
  const loading = document.getElementById('rev-loading');
  if (loading) loading.classList.add('show');
  
  const resp = await fetch('/api/music/revision/run', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ lyrics: current, edit, protect, options, agent })
  });
  const data = await resp.json();
  if (loading) loading.classList.remove('show');
  
  const out = document.getElementById('rev-output');
  const opts = document.getElementById('rev-out-options');
  if (out) out.style.display = 'block';
  
  const revised = data.revised || data.output || data.text || '';
  if (opts) opts.innerHTML = `
    <div style="grid-column:1/-1">
      <div class="option-card" style="border-color:#14f195">
        <div class="option-label" style="color:#14f195">✅ Revised Version</div>
        <div class="option-text">${revised.replace(/\n/g,'<br>')}</div>
      </div>
      ${data.decision ? `<div style="margin-top:8px;font-size:11px;color:rgba(255,255,255,.5);padding:6px 10px;border-left:2px solid rgba(124,58,237,.4)">Decision: ${data.decision}</div>` : ''}
    </div>
  `;
  STATE.lastOutput.rev = revised;
  tsmAssistantUpdate && tsmAssistantUpdate('revised');
  out?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
};



</script>
<script id="tsm-generate-fix">
// Fix runGenerate to bypass callGroq and call agent-pass directly
const _origRunGenerate = window.runGenerate;
window.runGenerate = async function() {
  const type = document.getElementById('gen-type')?.value || 'Hook Options';
  const tone = document.getElementById('gen-tone')?.value || 'Triumphant';
  const concept = document.getElementById('gen-concept')?.value?.trim();
  const ref = document.getElementById('gen-ref')?.value?.trim();
  if (!concept) { showNotif('Add a concept or starting point'); return; }

  const loading = document.getElementById('gen-loading');
  if (loading) loading.classList.add('show');

  const prompt = `Generate ${type} with tone: ${tone}. Concept: ${concept}. ${ref ? 'Match this voice/style: ' + ref : ''} Return 3 distinct options as JSON. Each option.text must contain real lyric lines, minimum 4 lines, never placeholders, never "lyrics here", never bracket instructions. Format: {"options":[{"label":"Option 1: Raw confession","text":"line 1\\nline 2\\nline 3\\nline 4"},{"label":"Option 2: Street anthem","text":"line 1\\nline 2\\nline 3\\nline 4"},{"label":"Option 3: Live performance","text":"line 1\\nline 2\\nline 3\\nline 4"}]}`;

  const resp = await fetch('/api/music/agent-pass', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ prompt })
  });
  const data = await resp.json();
  if (loading) loading.classList.remove('show');

  const out = document.getElementById('gen-output');
  const opts = document.getElementById('gen-out-options');
  const content = document.getElementById('gen-out-content');
  if (out) out.style.display = 'block';
  document.getElementById('gen-out-status') && (document.getElementById('gen-out-status').textContent = '✓ ' + type);

  if (data.options && data.options.length > 0) {
    if (content) content.innerHTML = '';
    if (opts) opts.innerHTML = data.options.map((o, i) => `
      <div class="option-card" onclick="selectOption(${i},'gen')">
        <div class="option-label">${o.label}</div>
        <div class="option-text">${o.text}</div>
      </div>`).join('');
    STATE.lastOutput.gen = JSON.stringify(data.options);
  } else {
    const text = data.output || data.response || '';
    if (content) content.textContent = text;
    STATE.lastOutput.gen = text;
  }
  tsmAssistantUpdate && tsmAssistantUpdate('generate');
  out?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
};



</script>
