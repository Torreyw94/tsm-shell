#tsm-assistant-toggle { background: none; border: none; color: rgba(255,255,255,.4); cursor: pointer; font-size: 14px; }
#tsm-assistant-body { padding: 12px 14px; }
#tsm-assistant-msg { color: rgba(255,255,255,.9); line-height: 1.6; margin-bottom: 10px; }
