    actions: [
      { label: 'Export Song Now', fn: "exportCurrentMusicSession()" }
    ]
  }
];

// Build lookup
const STATE_MAP = {};
FLOW.forEach(s => STATE_MAP[s.id] = s);

  window.tsmAssistantUpdate = function(action) {
    const state = STATE_MAP[action];
    if (!state) return;
    if (window.showAssistant) window.showAssistant(state.msg, state.actions);
