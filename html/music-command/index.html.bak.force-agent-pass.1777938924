  <div id="tsm-dock-response" style="display:none;background:#08010f;border-top:1px solid #2a1a4a;padding:10px 16px;font-size:12px;color:#ccc;line-height:1.6;max-height:100px;overflow-y:auto"></div>
  <div id="tsm-producer-inline" style="display:none;background:#0b0618;border-top:1px solid #a855f7;padding:8px 16px;font-size:11px;color:#f5e8ff;align-items:center;gap:12px;flex-wrap:wrap"></div>
  <div style="display:flex;flex-direction:row;align-items:center;background:#08010f;border-top:2px solid #2a1a4a;min-height:50px;padding:0 12px;gap:8px">
    <span style="color:#a855f7;font-weight:900;font-size:11px;white-space:nowrap">🎤 ZAY</span>
    <input id="tsm-dock-input" type="text" placeholder="Ask anything — next step, improve a line, rate my draft..."
      style="flex:1;background:#1a0933;border:1px solid #a855f7;border-radius:6px;padding:6px 10px;color:#f5e8ff;font-size:11px;min-width:0"
      onkeydown="if(event.key==='Enter') window.tsmDockSend()"
    />
    <button onclick="window.tsmDockSend()" style="background:#a855f7;color:white;border:0;border-radius:6px;padding:6px 12px;font-weight:900;cursor:pointer">→</button>
    <button onclick="window.tsmDockQuick('What should I do next?')" style="background:#1a0933;color:#00f59f;border:1px solid #00f59f;border-radius:6px;padding:5px 8px;font-size:10px;cursor:pointer;white-space:nowrap">Next?</button>
    <button onclick="window.tsmDockQuick('Rate my current draft and tell me what to improve')" style="background:#1a0933;color:#ffc857;border:1px solid #ffc857;border-radius:6px;padding:5px 8px;font-size:10px;cursor:pointer;white-space:nowrap">Rate</button>
    <button onclick="window.tsmToggleAssistant()" style="background:#1a0933;color:#00e0ff;border:1px solid #00e0ff;border-radius:6px;padding:5px 8px;font-size:10px;cursor:pointer;white-space:nowrap">🧠 Coach</button>
    <button onclick="document.getElementById('tsm-action-popup').classList.toggle('open')" style="background:linear-gradient(135deg,#7c3aed,#14f195);color:#000;border:0;border-radius:6px;padding:5px 10px;font-weight:900;cursor:pointer;font-size:11px;white-space:nowrap">⚡ Actions</button>
  </div>
</div>
