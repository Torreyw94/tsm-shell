<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TSM · Staff Accountant Copilot</title>
<style>
body{background:#02070d;color:#d9f3ff;font-family:monospace;margin:0}
.wrap{max-width:1200px;margin:auto;padding:30px}
h1{color:#00f59f}
.card{border:1px solid #00f59f;padding:20px;border-radius:12px;margin-bottom:20px}
button{background:#00f59f;color:#001018;border:0;padding:12px 16px;border-radius:8px;font-weight:bold;cursor:pointer}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.output{white-space:pre-wrap;background:#04121a;padding:15px;border-radius:10px;margin-top:15px}
</style>
</head>
<body>
<div class="wrap">

<h1>🧠 Staff Accountant Copilot</h1>

<div class="card">
<h3>1. What are you working on?</h3>
<select id="workflow">
<option>AP Aging</option>
<option>AR Collections</option>
<option>Bank Reconciliation</option>
<option>Month-End Close</option>
<option>1099 / Tax</option>
<option>Audit / Compliance</option>
</select>
</div>

<div class="card">
<h3>2. Add context (optional)</h3>
<textarea id="context" style="width:100%;height:100px"></textarea>
</div>

<div class="card">
<button onclick="runCopilot()">🚀 Run Full Analysis</button>
<div id="status"></div>
</div>

<div class="card">
<h3>📊 Copilot Output</h3>
<div id="output" class="output">Waiting...</div>
</div>

</div>

<script>
async function runCopilot(){
  const wf = document.getElementById("workflow").value;
  const ctx = document.getElementById("context").value;

  document.getElementById("status").innerText = "Running multi-node chain...";

  try{

    const res = await fetch("/api/finops/multi-report",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        workflows:[wf],
        context:ctx
      })
    });

    const data = await res.json();

    if(!data.ok) throw new Error(data.error);

    document.getElementById("output").innerText =
      "PRIORITY ACTIONS:\n\n" +
      data.priority_rank.map(x =>
        `${x.rank}. ${x.issue}\n→ ${x.impact}\n`
      ).join("\n") +

      "\n\nBNCA:\n" + data.combined_bnca +

      "\n\nCONTROLLER NOTE:\n" + data.controller_note;

  }catch(e){
    document.getElementById("output").innerText =
      "⚠️ Fallback Mode\n\n" +
      "1. Review AP + AR risk exposure\n" +
      "2. Prioritize reconciliation gaps\n" +
      "3. Prepare controller summary\n\n" +
      e.message;
  }

  document.getElementById("status").innerText = "Complete";
}
</script>

</body>
</html>
