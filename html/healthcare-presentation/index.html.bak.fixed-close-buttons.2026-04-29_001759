            padding:13px 16px;
            border-radius:9px;
            font-weight:900;
            cursor:pointer;
          ">OPEN HC MAIN STRATEGIST</button>
        </div>

        <div style="margin-top:16px;color:#8fb0c8;font-size:12px;line-height:1.5">
          Say: “That’s exactly what your team gets on day one. Most teams start with prior auth and denials.”
        </div>
      </div>
    `;
  };

  window.hideClosingLock = function(){
    const el = document.getElementById("closingLock");
    if(el) el.style.display = "none";
  };

  window.startHealthcarePilot = function(){
    localStorage.setItem("tsm_healthcare_pilot_intent", JSON.stringify({
      ts:new Date().toISOString(),
      suite:"healthcare",
      option:"30-day pilot",
      workflows:["prior authorization","denials","compliance","executive BNCA"],
      price:"$1,750/month"
    }));
    alert("Pilot path captured: 30-day healthcare pilot · prior auth + denials + compliance.");
  };

  window.bookHealthcareWalkthrough = function(){
    alert("Next step: technical walkthrough with healthcare operations, billing, compliance, and leadership.");
  };

  // Hook into Auto Demo completion without exposing internal logic
  const hook = setInterval(() => {
    if(typeof window.startAutoDemo === "function" && !window.__closingLockHooked){
      window.__closingLockHooked = true;

      const originalStart = window.startAutoDemo;
      window.startAutoDemo = function(){
        originalStart();
        setTimeout(() => {
          try { window.showClosingLock(); } catch(e){}
        }, 44500);
      };

      clearInterval(hook);
    }
  }, 500);
})();
</script>

