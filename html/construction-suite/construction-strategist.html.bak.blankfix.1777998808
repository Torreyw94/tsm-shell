        <div class="alert-item warn">
          <div class="alert-icon">◈</div>
          <div>
            <div class="alert-text">Steel delivery window narrow — confirm Gate 2 staging</div>
            <div class="alert-time">5h ago</div>
          </div>
        </div>
        <div class="alert-item info">
          <div class="alert-icon">ℹ</div>
          <div>
            <div class="alert-text">Q2 investor report template available in Document Hub</div>
