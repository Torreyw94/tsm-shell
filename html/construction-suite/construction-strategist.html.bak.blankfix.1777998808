  </div><!-- /sidebar -->

</main>

<footer>
  <span>Construction Suite · Main Strategist v2.6</span>
  <span>All data is project-specific and confidential</span>
</footer>

<!-- AI ASSISTANT -->
<button class="ai-fab" id="aiFab" title="Construction AI Assistant">
  🏗
  <span class="fab-badge">AI</span>
</button>

<div class="ai-drawer" id="aiDrawer">
  <div class="ai-drawer-head">
    <div class="ai-avatar">🏗</div>
    <div>
      <div class="ai-drawer-title">Construction Assistant</div>
      <div class="ai-drawer-sub">Powered by TSM Neural Core · Llama 3</div>
    </div>
    <button class="ai-close" id="aiClose">✕</button>
  </div>

  <div class="ai-messages" id="aiMessages">
    <div class="msg ai">
      <div class="msg-dot">🏗</div>
      <div class="msg-bubble">Hey — I'm your construction strategist AI. Ask me about schedules, risk, budget, crew planning, or anything on this project.</div>
    </div>
  </div>

  <div class="ai-suggestions" id="aiSuggestions">
    <span class="ai-chip" onclick="sendChip(this)">What's my biggest risk right now?</span>
    <span class="ai-chip" onclick="sendChip(this)">How do I reduce budget variance?</span>
    <span class="ai-chip" onclick="sendChip(this)">MEP inspection checklist</span>
    <span class="ai-chip" onclick="sendChip(this)">Steel erection safety tips</span>
  </div>

  <div class="ai-input-row">
    <input class="ai-input" id="aiInput" placeholder="Ask anything construction…" autocomplete="off"/>
    <button class="ai-send" id="aiSend">➤</button>
  </div>
</div>

<script>
  // Live date
  const d = new Date();
  document.getElementById('hdate').textContent =
    d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'}).toUpperCase();

  // Animate bars on load
  document.querySelectorAll('.strat-bar').forEach(b => {
    const w = b.style.width;
    b.style.width = '0';
    setTimeout(() => b.style.width = w, 300);
  });

  // ── AI ASSISTANT ──
  const fab      = document.getElementById('aiFab');
  const drawer   = document.getElementById('aiDrawer');
  const closeBtn = document.getElementById('aiClose');
  const input    = document.getElementById('aiInput');
  const sendBtn  = document.getElementById('aiSend');
  const msgs     = document.getElementById('aiMessages');

  const SYSTEM = `You are a senior construction project strategist and site advisor embedded in a Construction Suite dashboard.
You specialize in: project scheduling, budget management, risk assessment, subcontractor coordination, permitting, MEP systems, safety compliance (OSHA), and construction best practices.
Keep answers concise, practical, and actionable. Use bullet points for lists. When relevant, reference phases: Foundation, Structure, Envelope, Systems.`;

  let history = [];
  let busy = false;

  fab.addEventListener('click', () => drawer.classList.toggle('open'));
  closeBtn.addEventListener('click', () => drawer.classList.remove('open'));

  input.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
  sendBtn.addEventListener('click', send);

  function sendChip(el) {
    input.value = el.textContent;
    send();
    document.getElementById('aiSuggestions').style.display = 'none';
  }

  function appendMsg(role, text) {
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    div.innerHTML = `
      <div class="msg-dot">${role === 'ai' ? '🏗' : '👤'}</div>
      <div class="msg-bubble">${text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}</div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return div;
  }

  function showTyping() {
    const div = document.createElement('div');
    div.className = 'msg ai'; div.id = 'typing';
    div.innerHTML = `<div class="msg-dot">🏗</div><div class="msg-bubble"><div class="ai-typing"><span></span><span></span><span></span></div></div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  async function send() {
    const text = input.value.trim();
    if (!text || busy) return;
    busy = true; input.value = '';
    sendBtn.disabled = true;

    appendMsg('user', text);
    history.push({ role: 'user', content: text });
    showTyping();

    try {
      const res = await fetch('https://tsm-shell.fly.dev/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history, system: SYSTEM })
      });

      const data = await res.json();
      const reply = data.reply || data.content || data.message || 'No response received.';

      document.getElementById('typing')?.remove();
      appendMsg('ai', reply);
      history.push({ role: 'assistant', content: reply });
    } catch (err) {
      document.getElementById('typing')?.remove();
      appendMsg('ai', '⚠ Could not reach the AI backend. Check that /api/chat is running on your Fly server.');
    }

    busy = false;
    sendBtn.disabled = false;
    input.focus();
  }
</script>
</body>
</html>
