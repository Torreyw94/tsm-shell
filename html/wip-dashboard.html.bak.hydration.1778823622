// ── STATE ────────────────────────────────────────────────────────
let currentSector = 'construction';
let selectedEntity = null;

// ── SECTOR SWITCH ────────────────────────────────────────────────
function setSector(s) {
  currentSector = s;
  selectedEntity = null;
  const data = SECTORS[s];
  document.body.className = data.bodyClass;
  document.documentElement.style.setProperty('--s-color', data.color);

  // Update sector buttons
  ['construction','healthcare','insurance','finops'].forEach(k => {
    const b = document.getElementById('btn-'+k);
    b.className = 'sector-btn' + (k === s ? ' active-'+k : '');
  });

  document.getElementById('sector-label').textContent = data.label;
  document.getElementById('hero-eye').textContent = '// UNIVERSAL WIP INTELLIGENCE · ' + data.label.toUpperCase();
  document.getElementById('tb-brand').textContent = 'TSM · SOVEREIGN MESH · ' + data.label.toUpperCase();

  renderKPIs(data);
  renderTable(data);
  renderAlerts(data);
  renderEntities(data);
  renderActions(data);
  resetNarrative();
}

function renderKPIs(data) {
  document.getElementById('kpi-cards').innerHTML = data.kpis.map(k => `
    <div class="wc">
      <div class="wc-label">${k.label}</div>
      <div class="wc-value">${k.value}</div>
      <div class="wc-sub">${k.sub}</div>
      <div class="wc-delta ${k.cls}">${k.delta}</div>
    </div>`).join('');
}

function renderTable(data) {
  const th = data.tableHeaders.map(h => `<th>${h}</th>`).join('');
  const rows = data.tableRows.map(r => {
    const pct = r[1];
    const barCls = pct >= 80 ? 'bar-good' : pct >= 50 ? 'bar-warn' : 'bar-bad';
    const varCls = r[4].startsWith('-') || r[4].includes('FLAG') ? 'cell-bad' : r[4].startsWith('+') && r[4].includes('over') ? 'cell-warn' : 'cell-good';
    const statusCls = r[5] === 'good' ? 'cell-good' : r[5] === 'warn' ? 'cell-warn' : 'cell-bad';
    return `<tr>
      <td class="cell-label">${r[0]}</td>
      <td><span class="cell-pct ${barCls === 'bar-good' ? 'cell-good' : barCls === 'bar-warn' ? 'cell-warn' : 'cell-bad'}">${pct}%</span><span class="cell-bar-wrap"><span class="cell-bar ${barCls}" style="width:${pct}%"></span></span></td>
      <td class="cell-value">${r[2]}</td>
      <td class="cell-value">${r[3]}</td>
      <td class="${varCls}" style="font-family:var(--mono);font-size:.65rem">${r[4]}</td>
      <td><span class="${statusCls}" style="font-family:var(--mono);font-size:.5rem;letter-spacing:.06em">${r[5].toUpperCase()}</span></td>
    </tr>`;
  }).join('');
  document.getElementById('wip-table').innerHTML = `<thead><tr>${th}</tr></thead><tbody>${rows}</tbody>`;
}

function renderAlerts(data) {
  document.getElementById('alert-items').innerHTML = data.alerts.map(a => `
    <div class="af-item">
      <span class="af-sev ${a.cls}">${a.sev}</span>
      <span class="af-text">${a.text}</span>
    </div>`).join('');
}

function renderEntities(data) {
  document.getElementById('entity-list').innerHTML = data.entities.map((e,i) => `
    <div class="entity" id="ent-${i}" onclick="selectEntity(${i})">
      <span class="entity-risk ${e.riskCls}" style="float:right;font-family:var(--mono);font-size:.65rem;font-weight:700">${e.risk}</span>
      <div class="entity-id">${e.id}</div>
      <div class="entity-name">${e.name}</div>
      <div class="entity-meta">${e.meta}</div>
    </div>`).join('');
}

function renderActions(data) {
  document.getElementById('action-btns').innerHTML = data.actions.map(a => `
    <button class="ar-btn" onclick="runAction('${a}')">${a}</button>`).join('');
}

function selectEntity(i) {
  const data = SECTORS[currentSector];
  selectedEntity = data.entities[i];
  document.querySelectorAll('.entity').forEach((e,j) => e.classList.toggle('selected', i===j));
  renderSchema(selectedEntity, data);
  resetNarrative();
}

function renderSchema(e, data) {
  const schema = {
    entity_metadata: { entity_id: e.id, sector: currentSector, logic_engine: 'auditops-v2-strategist' },
    financial_core: {
      total_value: data.kpis[0].value,
      percent_complete: parseInt(e.meta.match(/(\d+)%/)?.[1]||'0'),
      risk_score: parseInt(e.risk),
    },
    risk_indicators: { risk_score: parseInt(e.risk), alert_flags: ['UPCODE-DETECT-V2','WIP-VARIANCE'], narrative: '(pending AI generation)' }
  };
  const json = JSON.stringify(schema, null, 2)
    .replace(/"([^"]+)":/g, '<span class="sp-key">"$1"</span>:')
    .replace(/: "([^"]+)"/g, ': <span class="sp-str">"$1"</span>')
    .replace(/: (\d+)/g, ': <span class="sp-num">$1</span>');
  document.getElementById('schema-body').innerHTML = json;
}

function resetNarrative() {
  document.getElementById('ap-body').innerHTML = '<span class="ap-placeholder">Select an entity and click GENERATE to produce a CFO-ready AI narrative for this sector.</span>';
}

async function runNarrative() {
  if (!selectedEntity) {
    const e = SECTORS[currentSector].entities[0];
    selectedEntity = e;
    document.getElementById('ent-0').classList.add('selected');
    renderSchema(e, SECTORS[currentSector]);
  }
  const btn = document.getElementById('ap-run-btn');
  const body = document.getElementById('ap-body');
  btn.disabled = true;
  btn.textContent = 'RUNNING…';
  body.textContent = '';

  const prompt = SECTORS[currentSector].narrativePrompt(selectedEntity);

  try {
    const res = await fetch('/api/groq/stream', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'llama-3.3-70b-versatile',
        max_tokens: 400,
        messages: [
          { role: 'system', content: 'You are the TSM Sovereign Mesh WIP Strategist. Produce executive-level financial analysis. Be specific with numbers. Format with clear section labels.' },
          { role: 'user', content: prompt }
        ]
      })
    });

    if (!res.ok) {
      // fallback to non-streaming
      const d = await res.json();
      body.textContent = d.content || d.error || 'Error contacting AI engine.';
      return;
    }

    const reader = res.body.getReader();
    const dec = new TextDecoder();
    let full = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      for (const line of dec.decode(value).split('\n')) {
        if (!line.startsWith('data: ')) continue;
        const d = line.slice(6).trim();
        if (d === '[DONE]') break;
        try {
          const delta = JSON.parse(d).choices?.[0]?.delta?.content || '';
          full += delta;
          body.textContent = full + '▌';
          body.scrollTop = body.scrollHeight;
        } catch {}
      }
    }
    body.textContent = full;
  } catch (err) {
    body.textContent = 'Stream error: ' + err.message;
  } finally {
    btn.disabled = false;
    btn.textContent = '⚡ GENERATE';
  }
}

function runAction(action) {
  const body = document.getElementById('ap-body');
  body.textContent = `[ACTION] ${action}\n\nInitiating via TSM Sovereign Mesh…\nRouting to: ${currentSector.toUpperCase()} node\nStatus: Processing…`;
  // Could trigger specific actions here
}

// ── INIT ─────────────────────────────────────────────────────────
setSector('construction');
</script>

