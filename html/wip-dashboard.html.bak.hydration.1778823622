<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script id="tsm-wip-charts">
// ── CHART INSTANCES ──────────────────────────────────────────────
let _cB=null, _cC=null, _cD=null;

const CHART_DATA = {
  construction: {
