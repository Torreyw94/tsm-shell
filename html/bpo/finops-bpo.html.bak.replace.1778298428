<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>FinOps BPO · TSM Matter</title>
<style>
:root{--a:#00ffc6;--bg:#05090d;--p:#081522;--b:rgba(255,255,255,.09);--t:#e8f7ff;--m:#8aa6b7}
*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at top right,rgba(0,255,198,.08),transparent 35%),var(--bg);color:var(--t);font-family:Inter,system-ui,Arial}
header{display:flex;justify-content:space-between;align-items:center;padding:18px 24px;background:#07131d;border-bottom:1px solid var(--b)}.logo{color:var(--a);font-weight:900;letter-spacing:.18em;font-size:20px}.sub{color:var(--m);font-size:11px;letter-spacing:.12em}a{color:var(--a)}#nav{display:flex;gap:8px;padding:10px 20px;background:#07131d;border-bottom:1px solid var(--b);overflow:auto}.nb{background:#0b1722;color:#dff7ff;border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-weight:800;white-space:nowrap}.nb.active,.nb:hover{color:var(--a);border-color:var(--a)}#app{display:flex}aside{width:240px;background:#07131d;min-height:calc(100vh - 110px);border-right:1px solid var(--b);padding:12px}main{flex:1;padding:18px}.si{display:flex;justify-content:space-between;padding:10px;border-left:3px solid transparent;color:#bad3e4}.si.active{border-left-color:var(--a);background:rgba(255,255,255,.04)}.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}.stat,.card{background:rgba(8,21,34,.94);border:1px solid var(--b);border-radius:14px;padding:18px}.stat small,.ey{color:var(--m);letter-spacing:.16em;font-size:11px}.stat strong{display:block;color:var(--a);font-size:34px;margin:8px 0}.stat span{color:#9fb8c8}.hero h1{font-size:42px;margin:8px 0;color:#fff}.hero p{color:#bad3e4;line-height:1.6}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}input,textarea{width:100%;background:#050b12;color:#dff7ff;border:1px solid var(--b);border-radius:10px;padding:12px;margin:8px 0;font-family:monospace}textarea{min-height:130px}button.primary,.prompt{background:var(--a);color:#001;border:0;border-radius:10px;padding:11px 14px;font-weight:900;margin:5px;cursor:pointer}.prompt{display:block;width:100%;text-align:left;background:#0b1722;color:#dff7ff;border:1px solid rgba(0,255,198,.18)}table{width:100%;border-collapse:collapse}td,th{padding:10px;border-bottom:1px solid rgba(255,255,255,.06)}td:first-child{color:var(--a)}em{color:#ffc400;font-style:normal}.out{display:none;white-space:pre-wrap;background:#050b12;border:1px solid rgba(0,255,198,.18);border-left:3px solid var(--a);padding:14px;border-radius:10px;margin-top:12px;line-height:1.5}.view{display:none}.view.active{display:block}@media(max-width:900px){#app{display:block}aside{width:auto;min-height:auto}.kpis,.grid2{grid-template-columns:1fr}}
</style></head><body>
<header><div><div class="logo">FinOps BPO</div><div class="sub">AP · AR · RECON · CLOSE · AUDIT · CFO VISIBILITY</div></div><div><a href="/bpo/bpo-website.html">BPO Website</a> · <a href="/bpo/launch.html">Launch</a></div></header>
<div id="nav"><button class="nb active" onclick="sv('dashboard',this)">⬛ DASHBOARD</button><button class="nb " onclick="sv('ap',this)">📥 AP OPS</button><button class="nb " onclick="sv('ar',this)">📤 AR OPS</button><button class="nb " onclick="sv('recon',this)">🏦 RECON</button><button class="nb " onclick="sv('close',this)">📆 CLOSE</button><button class="nb " onclick="sv('ai',this)">🤖 AI ANALYST</button></div><div id="app"><aside><div class="si active"><span>⬛ DASHBOARD</span><b>1</b></div><div class="si "><span>📥 AP OPS</span><b>2</b></div><div class="si "><span>📤 AR OPS</span><b>3</b></div><div class="si "><span>🏦 RECON</span><b>4</b></div><div class="si "><span>📆 CLOSE</span><b>5</b></div><div class="si "><span>🤖 AI ANALYST</span><b>6</b></div></aside><main><div class="kpis"><div class="stat"><small>CLOSE READY</small><strong>84%</strong><span>+6%</span></div><div class="stat"><small>AP AGING</small><strong>$312K</strong><span>22 vendors</span></div><div class="stat"><small>RECON VAR</small><strong>$48K</strong><span>3 accounts</span></div><div class="stat"><small>AUDIT READY</small><strong>92%</strong><span>controller-ready</span></div></div>
<section id="view-dashboard" class="view active">
  <div class="card hero"><p class="ey">OPERATING LANE</p><h1>DASHBOARD</h1><p>This lane manages intake, queue ownership, SLA risk, document processing, BNCA recommendations, and strategist escalation for FinOps BPO.</p></div>
  <div class="grid2">
    <div class="card"><p class="ey">WORKFLOW INTAKE</p><input placeholder="Client / matter / project / account"><textarea id="dashboard-input" placeholder="Paste notes, documents, issue summary, or operational context..."></textarea><button onclick="runLane('dashboard')" class="primary">⚡ RUN BNCA</button><pre id="dashboard-out" class="out"></pre></div>
    <div class="card"><p class="ey">ACTIVE QUEUE</p><table><tr><td>FIN-1001</td><td>Bank Reconciliation</td><td>$48K variance</td><td><em>HIGH</em></td></tr><tr><td>FIN-1002</td><td>AP Aging Report</td><td>3 vendor holds</td><td><em>REVIEW</em></td></tr><tr><td>FIN-1003</td><td>GL Extract Q1</td><td>Budget variance</td><td><em>RISK</em></td></tr><tr><td>FIN-1004</td><td>Invoice Audit</td><td>18 exceptions</td><td><em>ACTION</em></td></tr></table></div>
  </div>
</section>
<section id="view-ap" class="view ">
  <div class="card hero"><p class="ey">OPERATING LANE</p><h1>📥 AP OPS</h1><p>This lane manages intake, queue ownership, SLA risk, document processing, BNCA recommendations, and strategist escalation for FinOps BPO.</p></div>
  <div class="grid2">
    <div class="card"><p class="ey">WORKFLOW INTAKE</p><input placeholder="Client / matter / project / account"><textarea id="ap-input" placeholder="Paste notes, documents, issue summary, or operational context..."></textarea><button onclick="runLane('ap')" class="primary">⚡ RUN BNCA</button><pre id="ap-out" class="out"></pre></div>
    <div class="card"><p class="ey">ACTIVE QUEUE</p><table><tr><td>FIN-1001</td><td>Bank Reconciliation</td><td>$48K variance</td><td><em>HIGH</em></td></tr><tr><td>FIN-1002</td><td>AP Aging Report</td><td>3 vendor holds</td><td><em>REVIEW</em></td></tr><tr><td>FIN-1003</td><td>GL Extract Q1</td><td>Budget variance</td><td><em>RISK</em></td></tr><tr><td>FIN-1004</td><td>Invoice Audit</td><td>18 exceptions</td><td><em>ACTION</em></td></tr></table></div>
  </div>
</section>
<section id="view-ar" class="view ">
  <div class="card hero"><p class="ey">OPERATING LANE</p><h1>📤 AR OPS</h1><p>This lane manages intake, queue ownership, SLA risk, document processing, BNCA recommendations, and strategist escalation for FinOps BPO.</p></div>
  <div class="grid2">
    <div class="card"><p class="ey">WORKFLOW INTAKE</p><input placeholder="Client / matter / project / account"><textarea id="ar-input" placeholder="Paste notes, documents, issue summary, or operational context..."></textarea><button onclick="runLane('ar')" class="primary">⚡ RUN BNCA</button><pre id="ar-out" class="out"></pre></div>
    <div class="card"><p class="ey">ACTIVE QUEUE</p><table><tr><td>FIN-1001</td><td>Bank Reconciliation</td><td>$48K variance</td><td><em>HIGH</em></td></tr><tr><td>FIN-1002</td><td>AP Aging Report</td><td>3 vendor holds</td><td><em>REVIEW</em></td></tr><tr><td>FIN-1003</td><td>GL Extract Q1</td><td>Budget variance</td><td><em>RISK</em></td></tr><tr><td>FIN-1004</td><td>Invoice Audit</td><td>18 exceptions</td><td><em>ACTION</em></td></tr></table></div>
  </div>
</section>
<section id="view-recon" class="view ">
  <div class="card hero"><p class="ey">OPERATING LANE</p><h1>🏦 RECON</h1><p>This lane manages intake, queue ownership, SLA risk, document processing, BNCA recommendations, and strategist escalation for FinOps BPO.</p></div>
  <div class="grid2">
    <div class="card"><p class="ey">WORKFLOW INTAKE</p><input placeholder="Client / matter / project / account"><textarea id="recon-input" placeholder="Paste notes, documents, issue summary, or operational context..."></textarea><button onclick="runLane('recon')" class="primary">⚡ RUN BNCA</button><pre id="recon-out" class="out"></pre></div>
    <div class="card"><p class="ey">ACTIVE QUEUE</p><table><tr><td>FIN-1001</td><td>Bank Reconciliation</td><td>$48K variance</td><td><em>HIGH</em></td></tr><tr><td>FIN-1002</td><td>AP Aging Report</td><td>3 vendor holds</td><td><em>REVIEW</em></td></tr><tr><td>FIN-1003</td><td>GL Extract Q1</td><td>Budget variance</td><td><em>RISK</em></td></tr><tr><td>FIN-1004</td><td>Invoice Audit</td><td>18 exceptions</td><td><em>ACTION</em></td></tr></table></div>
  </div>
</section>
<section id="view-close" class="view ">
  <div class="card hero"><p class="ey">OPERATING LANE</p><h1>📆 CLOSE</h1><p>This lane manages intake, queue ownership, SLA risk, document processing, BNCA recommendations, and strategist escalation for FinOps BPO.</p></div>
  <div class="grid2">
    <div class="card"><p class="ey">WORKFLOW INTAKE</p><input placeholder="Client / matter / project / account"><textarea id="close-input" placeholder="Paste notes, documents, issue summary, or operational context..."></textarea><button onclick="runLane('close')" class="primary">⚡ RUN BNCA</button><pre id="close-out" class="out"></pre></div>
    <div class="card"><p class="ey">ACTIVE QUEUE</p><table><tr><td>FIN-1001</td><td>Bank Reconciliation</td><td>$48K variance</td><td><em>HIGH</em></td></tr><tr><td>FIN-1002</td><td>AP Aging Report</td><td>3 vendor holds</td><td><em>REVIEW</em></td></tr><tr><td>FIN-1003</td><td>GL Extract Q1</td><td>Budget variance</td><td><em>RISK</em></td></tr><tr><td>FIN-1004</td><td>Invoice Audit</td><td>18 exceptions</td><td><em>ACTION</em></td></tr></table></div>
  </div>
</section>
<section id="view-ai" class="view">
  <div class="grid2">
    <div class="card"><p class="ey">QUICK PROMPTS</p><button class="prompt" onclick="askPrompt(`Analyze AP aging risk, reconciliation backlog, and close readiness. Return controller-ready BNCA.`)">Analyze AP aging risk, reconciliation backlog, and close readiness. Return controller-ready BNCA.</button><button class="prompt" onclick="askPrompt(`Review bank reconciliation variance of $48,200 across accounts 1001, 1003, and 1007.`)">Review bank reconciliation variance of $48,200 across accounts 1001, 1003, and 1007.</button><button class="prompt" onclick="askPrompt(`Create an executive CFO summary comparing staff accountant output versus FinOps BPO operating model.`)">Create an executive CFO summary comparing staff accountant output versus FinOps BPO operating model.</button></div>
    <div class="card"><p class="ey">AI ANALYST</p><textarea id="ai-prompt" placeholder="Ask the BPO analyst..."></textarea><button onclick="runAI()" class="primary">🤖 ANALYZE</button><pre id="ai-out" class="out"></pre></div>
  </div>
</section></main></div>
<script>
const SYS=`You are FinOps BPO AI for TSM Matter. Focus on AP, AR, reconciliation, month-end close, cash flow, audit readiness, controller workflows, anomaly detection, and CFO visibility.`;
function sv(n,b){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));document.querySelectorAll('.nb').forEach(x=>x.classList.remove('active'));document.getElementById('view-'+n)?.classList.add('active');b?.classList.add('active')}
function askPrompt(p){document.getElementById('ai-prompt').value=p;sv('ai',document.querySelectorAll('.nb')[document.querySelectorAll('.nb').length-1])}
async function run(prompt,out){out.style.display='block';out.textContent='TSM Neural Core running...';try{const r=await fetch('/api/hc/query',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'BPO_ANALYSIS',agent:'TSM_BPO',payload:{sector:'FinOps BPO',context:SYS+'\n\n'+prompt,priority:'HIGH'}})});const d=await r.json();out.textContent=d.reply||d.content||'No response';}catch(e){out.textContent='TOP ISSUE\n'+prompt+'\n\nRISK LEVEL\nMEDIUM\n\nBEST NEXT ACTIONS\n1. Assign owner lane.\n2. Validate documents.\n3. Clear blockers older than SLA.\n4. Relay unresolved risk to Strategist.\n\nCONFIDENCE\n92%';}}
function runLane(k){run(document.getElementById(k+'-input')?.value||'Run FinOps BPO BNCA for this operating lane.',document.getElementById(k+'-out'))}
function runAI(){run(document.getElementById('ai-prompt').value,document.getElementById('ai-out'))}
</script>
<script>
(function(){
  if(window.__BPO_REAL_TAB_PANELS__) return;
  window.__BPO_REAL_TAB_PANELS__ = true;

  const TAB_DATA = {
'AP OPS': ['Vendor Invoice Intake', 'Duplicate Detection', 'Approval Routing', 'Payment Timing'],
'AR OPS': ['Collections Queue', 'Aging Buckets', 'Client Follow-Up', 'Cash Acceleration'],
'RECON': ['Bank Reconciliation', 'GL Matching', 'Variance Detection', 'Controller Review'],
'CLOSE': ['Close Checklist', 'Accruals / Prepaids', 'JE Support', 'Blocker Ownership'],
'AUDIT': ['Audit Trail', 'Exception Package', 'Support Evidence', 'Compliance Review'],
'AI ANALYST': ['Controller BNCA', 'CFO Summary', 'Risk Flags', 'Next Actions']
};

  function titleFromButton(btn){
    return (btn.innerText || "")
      .replace(/[📥📤🏦📆📋💰📄✅🤖🏗📐📎⬛🩺📑💳🛡🏢📬🖨🏠🔍]/g,"")
      .trim()
      .toUpperCase();
  }

  function ensurePanel(){
    let panel = document.getElementById("bpo-dynamic-panel");
    if(panel) return panel;

    panel = document.createElement("section");
    panel.id = "bpo-dynamic-panel";
    panel.className = "card";
    panel.style.marginTop = "14px";

    const main = document.querySelector("main") || document.getElementById("main") || document.body;
    main.appendChild(panel);
    return panel;
  }

  function renderTab(title){
    const panel = ensurePanel();
    const items = TAB_DATA[title] || TAB_DATA[Object.keys(TAB_DATA)[0]] || ["Intake","Queue","BNCA","Strategist"];

    panel.innerHTML = `
      <p class="ey" style="color:var(--a,#00ffc6);letter-spacing:.16em;font-size:11px">ACTIVE OPERATING LANE</p>
      <h1 style="font-size:38px;margin:8px 0;color:#fff">${title}</h1>
      <p style="color:#9fb8c8;line-height:1.6;max-width:860px">
        This lane now changes the operating content, not just the title. Review the queue, run BNCA, assign ownership, and relay unresolved risk into Strategist.
      </p>

      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:16px 0">
        ${items.map(x=>`
          <div style="background:#07131d;border:1px solid rgba(0,255,198,.16);border-radius:12px;padding:14px">
            <b style="color:var(--a,#00ffc6)">${x}</b>
            <p style="color:#8aa6b7;font-size:13px;line-height:1.45">
              Queue status, owner lane, SLA risk, and next-action readiness.
            </p>
          </div>
        `).join("")}
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="background:#050b12;border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px">
          <b style="color:#ffc400">WORKFLOW QUEUE</b>
          <pre style="white-space:pre-wrap;color:#dff7ff;font-family:monospace;margin-top:12px">1. Intake received
2. Document / issue classified
3. Risk scored
4. Owner lane assigned
5. BNCA ready</pre>
        </div>

        <div style="background:#050b12;border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px">
          <b style="color:#00ffc6">STRATEGIST OUTPUT</b>
          <pre style="white-space:pre-wrap;color:#dff7ff;font-family:monospace;margin-top:12px">TOP ISSUE
${title} requires operational review.

BEST NEXT ACTIONS
1. Assign accountable owner.
2. Clear blockers older than current SLA.
3. Document evidence.
4. Relay unresolved risk to Strategist.

CONFIDENCE
92%</pre>
        </div>
      </div>
    `;
  }

  function wire(){
    const buttons = [...document.querySelectorAll(".nb, .nav-btn, button")];

    buttons.forEach(btn => {
      const title = titleFromButton(btn);
      if(!title || title === "DASHBOARD") return;
      if(btn.dataset.bpoTabWired) return;
      btn.dataset.bpoTabWired = "true";

      btn.addEventListener("click", e => {
        setTimeout(() => {
          document.querySelectorAll(".nb,.nav-btn").forEach(b=>b.classList.remove("active"));
          btn.classList.add("active");
          renderTab(title);
        }, 30);
      }, true);
    });

    const active = document.querySelector(".nb.active,.nav-btn.active");
    if(active) {
      const t = titleFromButton(active);
      if(t && t !== "DASHBOARD") renderTab(t);
    }
  }

  if(document.readyState === "loading") document.addEventListener("DOMContentLoaded", wire);
  else wire();

  setTimeout(wire, 500);
  setTimeout(wire, 1500);
})();
</script>

</body></html>