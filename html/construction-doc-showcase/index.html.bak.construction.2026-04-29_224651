<script>
const SAMPLES={
  'bank-recon':{label:'Bank Reconciliation Q1',content:'Bank reconciliation Q1. Outstanding checks: $22,400. Deposits in transit: $8,100. Variance: $48,200 across accounts 1001,1003,1007. NSF items: 3. Clearing items older than 90 days flagged.'},
  'ap-aging':{label:'AP Aging Report',content:'AP aging. Current: $88,400. 31-60d: $74,200. 61-90d: $51,800. 91-180d: $63,400. 180+d: $34,200. Total: $312,000. Top vendors: MedSupply $44K, StaffPro $38K, LabCore $29K. 3 vendors on credit hold.'},
  'denial-report':{label:'Claims Denial Report',content:'Denial rate: 18.4%. Claims pending: 247. Denial reasons: prior auth 41%, missing docs 28%, eligibility 19%, coding 12%. Top payers: BCBS 31, UHC 28, Aetna 22. Revenue at risk: $186,000.'},
  'gl-extract':{label:'GL Extract Q1',content:'Revenue: $2.4M actual vs $2.8M budget (-14.3%). COGS: $1.1M. OpEx: $890K. Net income: $410K. Variance: Clinical -$180K, Admin -$82K, Facilities +$14K. AR days: 47. Collections: 91.2%.'},
  'audit-finding':{label:'HIPAA Audit Finding',content:'Open findings: 3. Critical: PHI access log gaps — 14 records no audit trail. High: 2 expired BAAs. Medium: Security training 74% vs 100% required. Remediation deadline: 45 days.'},
  'variance-report':{label:'Operations Variance',content:'Staffing: -12% vs budget (18 FTE gap). Intake: 31/day vs 40 target. No-show: 9.2%. OT hours: 340. Bottlenecks: front desk 31 pending, intake backlog 18.'}
};
let currentMode='sample', selectedSampleId=null, selectedFile=null;

function setMode(m){
  currentMode=m; selectedSampleId=null; selectedFile=null;
  document.getElementById('procBtn').disabled=true;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('mode-'+m).classList.add('active');
  document.getElementById('panel-sample').style.display=m==='sample'?'':'none';
  document.getElementById('panel-actual').style.display=m==='actual'?'':'none';
  resetOutput();
}
function selectSample(el,id){
  document.querySelectorAll('.sample-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected'); selectedSampleId=id;
  document.getElementById('procBtn').disabled=false;
}
const fi=document.getElementById('fileInput');
const dz=document.getElementById('dropZone');
fi.addEventListener('change',e=>{if(e.target.files[0])setFile(e.target.files[0])});
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('drag-over')});
dz.addEventListener('dragleave',()=>dz.classList.remove('drag-over'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('drag-over');if(e.dataTransfer.files[0])setFile(e.dataTransfer.files[0])});
function setFile(f){selectedFile=f;dz.classList.add('has-file');document.getElementById('dropFileName').textContent='📎 '+f.name+' ('+(f.size/1024).toFixed(1)+' KB)';document.getElementById('procBtn').disabled=false;}
function setPipe(step){document.querySelectorAll('.pipe-dot').forEach((d,i)=>{if(i<step)d.className='pipe-dot done';else if(i===step)d.className='pipe-dot active';else d.className='pipe-dot'});}
function pipeAll(){document.querySelectorAll('.pipe-dot').forEach(d=>d.className='pipe-dot done');}
function resetOutput(){document.getElementById('outBody').textContent='> Select a document and press PROCESS to begin.';document.getElementById('outBody').className='out-body';document.getElementById('outStatus').textContent='READY';document.getElementById('pushBtn').classList.remove('visible');document.getElementById('saveBtn')?.classList.remove('visible');lastReport=null;document.querySelectorAll('.kpi-card').forEach(k=>k.classList.remove('visible'));document.querySelectorAll('.pipe-dot').forEach(d=>d.className='pipe-dot');}
function showKPIs(o){document.getElementById('kv-risk').textContent=o.risk;document.getElementById('kv-flag').textContent=o.flags;document.getElementById('kv-action').textContent=o.actions;document.getElementById('kv-conf').textContent=o.conf;document.querySelectorAll('.kpi-card').forEach(k=>k.classList.add('visible'));}
function delay(ms){return new Promise(r=>setTimeout(r,ms));}
function pushToStrategist(){location.href='/html/hc-strategist/index.html?v=doc-upload-'+Date.now();}


function readFileText(file){
  return new Promise((resolve, reject)=>{
    const ext = file.name.split('.').pop().toLowerCase();
    if(['txt','csv'].includes(ext)){
      const r = new FileReader();
      r.onload = e => resolve(e.target.result.slice(0, 3000));
      r.onerror = () => resolve('[unreadable]');
      r.readAsText(file);
    } else if(ext === 'pdf'){
      // Send to tsm-core for extraction
      const fd = new FormData();
      fd.append('doc', file);
      fetch('/api/finops/upload-doc', {method:'POST', body:fd})
        .then(r=>r.json())
        .then(d=>resolve(d.text||d.summary||d.report?.summary||'[PDF processed — no text extracted]'))
        .catch(()=>resolve('[PDF uploaded — text extraction unavailable]'));
    } else {
      // Excel/Word — send to tsm-core, fallback to filename-based analysis
      const fd = new FormData();
      fd.append('doc', file);
      fetch('/api/finops/upload-doc', {method:'POST', body:fd})
        .then(r=>r.json())
        .then(d=>resolve(d.text||d.summary||d.report?.summary||`[${ext.toUpperCase()} file processed]`))
        .catch(()=>resolve(`[${ext.toUpperCase()} file — ${(file.size/1024).toFixed(1)}KB — ready for analysis]`));
    }
  });
}

async function processDoc(){
  const btn=document.getElementById('procBtn');
  btn.disabled=true; resetOutput();
  const ob=document.getElementById('outBody');
  const os=document.getElementById('outStatus');

  if(currentMode==='actual'&&selectedFile){
    ob.className='out-body thinking'; ob.textContent='> Uploading to FinOps node chain...'; os.textContent='UPLOADING'; setPipe(0);
    try{
      // Read file contents for AI analysis
      await delay(400); setPipe(1); ob.textContent='> Reading file...'; os.textContent='PARSING';
      const fileText = await readFileText(selectedFile);
      await delay(400); setPipe(2); ob.textContent='> AI node chain analyzing...'; os.textContent='ANALYZING';
      await runAI(selectedFile.name, fileText, ob, os);
    }catch(e){
      await runAI(selectedFile.name, null, ob, os);
    }
    btn.disabled=false; return;
  }
  if(!selectedSampleId){btn.disabled=false;return;}
  const s=SAMPLES[selectedSampleId];
  await runAI(s.label,s.content,ob,os);
  btn.disabled=false;
}

async function runAI(label,content,ob,os){
  ob.className='out-body thinking'; ob.textContent='> Ingesting...'; os.textContent='INGESTING'; setPipe(0);
  await delay(500); setPipe(1); ob.textContent='> Parsing structure...'; os.textContent='PARSING';
  await delay(600); setPipe(2); ob.textContent='> TSM AI node chain analyzing...'; os.textContent='ANALYZING';
  const prompt=content
    ?`You are a TSMatter financial and operational analyst AI. Analyze this document:\n\nDocument: ${label}\nContent: ${content}\n\nReturn in this exact format:\nDOCUMENT SUMMARY\n[2-3 sentences]\n\nKEY FINDINGS\n• [finding 1]\n• [finding 2]\n• [finding 3]\n\nRISK LEVEL: [LOW/MEDIUM/HIGH/CRITICAL]\n[one sentence why]\n\nFLAGS: [number]\n\nBEST NEXT COURSE OF ACTION\n1. [action]\n2. [action]\n3. [action]\n\nCONFIDENCE: [XX%]`
    :`You are a TSMatter analyst. File uploaded: "${label}". Generate a realistic analysis in TSMatter terminal style with: DOCUMENT SUMMARY, KEY FINDINGS (3 bullets), RISK LEVEL, FLAGS count, BEST NEXT COURSE OF ACTION (3 steps), CONFIDENCE %.`;
  try{
    const res=await fetch('https://tsm-core.fly.dev/ask',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({app:'doc-showcase',messages:[{role:'user',content:prompt}]})});
    const data=await res.json();
    const text=data.reply||'No response.';
    await delay(400); setPipe(3); os.textContent='GENERATING BNCA';
    await delay(400); pipeAll();
    ob.className='out-body'; ob.textContent=text; os.textContent='COMPLETE';
    const rm=text.match(/RISK LEVEL[:\s]+([A-Z]+)/i);
    const fm=text.match(/FLAGS[:\s]+(\d+)/i);
    const cm=text.match(/CONFIDENCE[:\s]+(\d+%)/i);
    const am=(text.match(/^\d+\./gm)||[]).length;
    showKPIs({risk:rm?rm[1]:'HIGH',flags:fm?fm[1]:'3',actions:am||3,conf:cm?cm[1]:'88%'});
    document.getElementById('pushBtn').classList.add('visible');
    document.getElementById('saveBtn').classList.add('visible');
    lastReport={label,summary:text,risk:rm?rm[1]:'HIGH',flags:fm?fm[1]:'3',actions:am||3,conf:cm?cm[1]:'88%'};
    window.__FINOPS_UPLOADED_REPORT__={summary:text,label};
  }catch(e){
    pipeAll(); ob.className='out-body';
    ob.textContent='> Analysis complete (offline mode).\n\nDocument: '+label+'\n\nConnect to live AI endpoint for full analysis.\n\nBEST NEXT COURSE OF ACTION\n1. Verify tsm-core.fly.dev connectivity\n2. Re-run with active session\n3. Push to strategist for manual review';
    os.textContent='OFFLINE';
    showKPIs({risk:'—',flags:'—',actions:'3',conf:'—'});
    document.getElementById('pushBtn').classList.add('visible');
  }
}

const HC_STORAGE_KEY='tsm_hc_reports';
let lastReport=null;

function saveReport(){
  if(!lastReport)return;
  try{
    const reports=JSON.parse(localStorage.getItem(HC_STORAGE_KEY)||'[]');
    reports.unshift({...lastReport,id:Date.now(),saved:new Date().toLocaleString()});
    localStorage.setItem(HC_STORAGE_KEY,JSON.stringify(reports.slice(0,20)));
    const t=document.getElementById('saveToast');t.style.display='block';setTimeout(()=>t.style.display='none',2500);
    loadSavedReports();
  }catch(e){}
}
function loadSavedReports(){
  try{
    const reports=JSON.parse(localStorage.getItem(HC_STORAGE_KEY)||'[]');
    const panel=document.getElementById('savedPanel');const list=document.getElementById('savedList');
    if(!reports.length){panel.classList.remove('visible');return;}
    panel.classList.add('visible');
    list.innerHTML=reports.map(r=>`<div class="saved-item" onclick="loadSaved(${r.id})"><div class="saved-item-title">${r.label}</div><div class="saved-item-meta">${r.saved} · Risk: ${r.risk||'—'} · Conf: ${r.conf||'—'}</div></div>`).join('');
  }catch(e){}
}
function loadSaved(id){
  try{
    const reports=JSON.parse(localStorage.getItem(HC_STORAGE_KEY)||'[]');
    const r=reports.find(x=>x.id===id);if(!r)return;
    document.getElementById('outBody').textContent=r.summary;
    document.getElementById('outStatus').textContent='SAVED REPORT';
    showKPIs({risk:r.risk||'—',flags:r.flags||'—',actions:r.actions||'—',conf:r.conf||'—'});
    pipeAll();document.getElementById('pushBtn').classList.add('visible');
  }catch(e){}
}
loadSavedReports();

</script>
