      <div class="sample-card" onclick="selectSample(this,'ap-aging')"><div class="sc-type">BILLING</div><div class="sc-name">AP Aging Report</div><div class="sc-desc">180-day aging · 22 vendors · $312K outstanding</div></div>
      <div class="sample-card" onclick="selectSample(this,'denial-report')"><div class="sc-type">INSURANCE</div><div class="sc-name">Denial Report</div><div class="sc-desc">18.4% denial rate · prior auth friction · 247 claims pending</div></div>
      <div class="sample-card" onclick="selectSample(this,'gl-extract')"><div class="sc-type">FINANCIAL</div><div class="sc-name">GL Extract</div><div class="sc-desc">Q1 extract · revenue vs budget variance by cost center</div></div>
      <div class="sample-card" onclick="selectSample(this,'audit-finding')"><div class="sc-type">COMPLIANCE</div><div class="sc-name">Audit Finding</div><div class="sc-desc">HIPAA gap · 3 open findings · Joint Commission prep</div></div>
