<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>TSM · DOC INTELLIGENCE SHOWCASE</title>
<script src="/html/shared/tsm-zero-trust.js">
const HC_STORAGE_KEY='tsm_hc_reports';
let lastReport=null;

function saveReport(){
  if(!lastReport)return;
  try{
    const reports=JSON.parse(localStorage.getItem(HC_STORAGE_KEY)||'[]');
    reports.unshift({...lastReport,id:Date.now(),saved:new Date().toLocaleString()});
    localStorage.setItem(HC_STORAGE_KEY,JSON.stringify(reports.slice(0,20)));
    const t=document.getElementById('saveToast');t.style.display='block';setTimeout(()=>t.style.display='none',2500);
    loadSavedReports();
  }catch(e){}
}
function loadSavedReports(){
  try{
    const reports=JSON.parse(localStorage.getItem(HC_STORAGE_KEY)||'[]');
    const panel=document.getElementById('savedPanel');const list=document.getElementById('savedList');
    if(!reports.length){panel.classList.remove('visible');return;}
    panel.classList.add('visible');
    list.innerHTML=reports.map(r=>`<div class="saved-item" onclick="loadSaved(${r.id})"><div class="saved-item-title">${r.label}</div><div class="saved-item-meta">${r.saved} · Risk: ${r.risk||'—'} · Conf: ${r.conf||'—'}</div></div>`).join('');
  }catch(e){}
}
function loadSaved(id){
  try{
    const reports=JSON.parse(localStorage.getItem(HC_STORAGE_KEY)||'[]');
    const r=reports.find(x=>x.id===id);if(!r)return;
    document.getElementById('outBody').textContent=r.summary;
    document.getElementById('outStatus').textContent='SAVED REPORT';
    showKPIs({risk:r.risk||'—',flags:r.flags||'—',actions:r.actions||'—',conf:r.conf||'—'});
    pipeAll();document.getElementById('pushBtn').classList.add('visible');
  }catch(e){}
}
loadSavedReports();

</script>
<style>
:root{--bg:#0a0f0a;--g:#00ff88;--a:#ffaa00;--b:#00aaff;--r:#ff4444;--dim:#0d150d;--dim2:#0b120b;--border:#1e3a1e;--text:#e0ffe0;--muted:#556655}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Courier New',monospace;font-size:13px}
.hdr{display:flex;justify-content:space-between;align-items:center;padding:12px 20px;border-bottom:1px solid var(--border);background:var(--dim2)}
.hdr-title{font-size:15px;font-weight:700;letter-spacing:3px;color:var(--g)}
.hdr-sub{font-size:10px;color:var(--muted);letter-spacing:1px;margin-top:2px}
.back-btn{padding:5px 14px;background:var(--dim2);border:1px solid var(--border);color:var(--muted);font-family:inherit;font-size:10px;font-weight:700;border-radius:4px;cursor:pointer}
.back-btn:hover{border-color:var(--g);color:var(--g)}
main{max-width:960px;margin:0 auto;padding:24px 20px 100px}
.mode-row{display:flex;gap:10px;margin-bottom:24px}
.mode-btn{flex:1;padding:12px;border:1px solid var(--border);background:var(--dim);color:var(--muted);font-family:inherit;font-size:11px;font-weight:700;letter-spacing:1px;border-radius:6px;cursor:pointer;text-align:center;transition:all .2s}
.mode-btn.active{border-color:var(--g);color:var(--g);background:#0d1f0d}
.drop-zone{border:2px dashed var(--border);border-radius:8px;padding:40px;text-align:center;cursor:pointer;transition:all .2s;background:var(--dim);margin-bottom:16px}
.drop-zone.drag-over{border-color:var(--g);background:#0d1f0d}
.drop-zone.has-file{border-color:var(--a);border-style:solid}
.drop-icon{font-size:32px;margin-bottom:12px}
.drop-title{font-size:13px;font-weight:700;letter-spacing:2px;color:var(--g);margin-bottom:6px}
.drop-sub{font-size:11px;color:var(--muted)}
.drop-file-name{font-size:12px;color:var(--a);margin-top:10px;font-weight:700}
input[type=file]{display:none}
.sample-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-bottom:20px}
.sample-card{padding:12px;border:1px solid var(--border);border-radius:6px;background:var(--dim);cursor:pointer;transition:all .2s}
.sample-card:hover,.sample-card.selected{border-color:var(--g);background:#0d1f0d}
.sample-card.selected{border-color:var(--a)}
.sc-type{font-size:9px;font-weight:700;letter-spacing:2px;color:var(--a);margin-bottom:4px}
.sc-name{font-size:12px;color:var(--g);font-weight:700;margin-bottom:4px}
.sc-desc{font-size:10px;color:var(--muted);line-height:1.5}
.pipeline{display:flex;align-items:center;gap:0;margin:20px 0;overflow-x:auto;padding:4px 0}
.pipe-step{display:flex;flex-direction:column;align-items:center;min-width:100px}
.pipe-dot{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:14px;background:var(--dim);transition:all .4s}
.pipe-dot.active{border-color:var(--g);background:#0d1f0d;box-shadow:0 0 10px #00ff8844}
.pipe-dot.done{border-color:var(--a);background:#1a1200}
.pipe-label{font-size:9px;color:var(--muted);margin-top:4px;text-align:center;letter-spacing:1px}
.pipe-arrow{color:var(--border);font-size:16px;padding:0 4px;margin-bottom:16px}
.action-row{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap}
.proc-btn{padding:10px 24px;background:#0d1f0d;border:1px solid var(--g);color:var(--g);font-family:inherit;font-size:11px;font-weight:700;letter-spacing:2px;border-radius:4px;cursor:pointer}
.proc-btn:disabled{opacity:.4;cursor:not-allowed}
.push-btn{padding:10px 24px;background:#1a1200;border:1px solid var(--a);color:var(--a);font-family:inherit;font-size:11px;font-weight:700;letter-spacing:2px;border-radius:4px;cursor:pointer;display:none}
.push-btn.visible{display:block}
.save-btn{padding:10px 24px;background:#0d150d;border:1px solid var(--g);color:var(--g);font-family:inherit;font-size:11px;font-weight:700;letter-spacing:2px;border-radius:4px;cursor:pointer;display:none}
.save-btn.visible{display:block}
.saved-panel{margin-top:20px;border:1px solid var(--border);border-radius:6px;background:var(--dim);overflow:hidden;display:none}
.saved-panel.visible{display:block}
.saved-hdr{padding:8px 14px;background:var(--dim2);border-bottom:1px solid var(--border);font-size:10px;font-weight:700;letter-spacing:2px;color:var(--g)}
.saved-list{padding:12px;display:flex;flex-direction:column;gap:8px;max-height:280px;overflow-y:auto}
.saved-item{padding:10px;border:1px solid var(--border);border-radius:4px;background:var(--dim2);cursor:pointer}
.saved-item:hover{border-color:var(--g)}
.saved-item-title{font-size:11px;color:var(--g);font-weight:700;margin-bottom:2px}
.saved-item-meta{font-size:10px;color:var(--muted)}
.save-toast{position:fixed;top:20px;right:20px;background:#0d1f0d;border:1px solid var(--g);color:var(--g);padding:10px 18px;border-radius:4px;font-size:11px;font-weight:700;letter-spacing:1px;z-index:999;display:none}
.output-panel{border:1px solid var(--border);border-radius:6px;background:var(--dim);overflow:hidden}
.out-hdr{padding:8px 14px;background:var(--dim2);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.out-hdr-label{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--g)}
.out-status{font-size:10px;color:var(--muted)}
.out-body{padding:16px;min-height:140px;font-size:12px;color:#99cc99;line-height:1.7;white-space:pre-wrap}
.out-body.thinking{color:var(--a);animation:pulse .8s infinite alternate}
@keyframes pulse{from{opacity:.5}to{opacity:1}}
@keyframes zt-blink{0%,100%{opacity:1}50%{opacity:.3}}
.kpi-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-top:16px}
.kpi-card{padding:12px;border:1px solid var(--border);border-radius:6px;background:var(--dim);text-align:center;display:none}
.kpi-card.visible{display:block}
.kpi-val{font-size:22px;font-weight:700;color:var(--g)}
.kpi-lbl{font-size:9px;color:var(--muted);letter-spacing:1px;margin-top:2px}
.section-label{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--muted);margin-bottom:10px}
.divider{border:none;border-top:1px solid var(--border);margin:20px 0}
</style>
</head>
<body>
<div class="save-toast" id="saveToast">✅ REPORT SAVED</div>
<div class="hdr">
