      <button class="ai-btn" onclick="Q('Improve NPSG.03.04.01 medication safety score from 87% to 95%','jc-btn','jc-res')">Medication Safety</button>
      <button class="ai-btn" onclick="Q('Address 3 medical records findings to improve RC.02.01.01 compliance','jc-btn','jc-res')">Medical Records Fix</button>
    </div>
    <div class="ai-row">
