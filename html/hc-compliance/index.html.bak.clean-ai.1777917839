</div>

<!-- ═══ TAB: OIG ═══ -->
<div id="tab-oig">
  <div class="sec" style="margin-top:16px">
    <div class="sec-hdr">OIG COMPLIANCE PROGRAM</div>
    <div class="stat-grid">
      <div class="stat-box"><div class="stat-val red">47</div><div class="stat-lbl">Staff Exclusion Checks Overdue</div></div>
      <div class="stat-box"><div class="stat-val green">0</div><div class="stat-lbl">Active OIG Investigations</div></div>
      <div class="stat-box"><div class="stat-val green">94%</div><div class="stat-lbl">Compliance Hotline Response Rate</div></div>
    </div>
    <table><thead><tr><th>REQUIREMENT</th><th>FREQUENCY</th><th>LAST CHECK</th><th>STATUS</th><th>STAFF AFFECTED</th><th>RISK</th></tr></thead>
    <tbody>
      <tr><td>OIG Exclusion List</td><td>Monthly</td><td>Jan 15</td><td><span class="badge br">OVERDUE</span></td><td>47 unscreened</td><td>HIGH</td></tr>
      <tr><td>SAM.gov Debarment</td><td>Monthly</td><td>Mar 01</td><td><span class="badge bg">CURRENT</span></td><td>All staff</td><td>LOW</td></tr>
      <tr><td>State Medicaid Exclusion</td><td>Monthly</td><td>Feb 01</td><td><span class="badge ba">DUE SOON</span></td><td>All staff</td><td>MED</td></tr>
      <tr><td>Compliance Training</td><td>Annual</td><td>Dec 2024</td><td><span class="badge bg">CURRENT</span></td><td>All staff</td><td>LOW</td></tr>
      <tr><td>Hotline Monitoring</td><td>Quarterly</td><td>Mar 01</td><td><span class="badge bg">CURRENT</span></td><td>N/A</td><td>LOW</td></tr>
    </tbody></table>
  </div>
  <div class="ai-box">
    <div class="ai-hdr">&#9889; AI ANALYSIS</div>
    <div class="ai-row">
      <button class="ai-btn" onclick="Q('Create OIG exclusion screening plan for 47 unscreened staff — timeline and process','oig-btn','oig-res')">Exclusion Screening</button>
      <button class="ai-btn" onclick="Q('Design comprehensive OIG compliance program with 7 core elements','oig-btn','oig-res')">Compliance Program</button>
      <button class="ai-btn" onclick="Q('Conduct OIG compliance risk assessment for our healthcare operations','oig-btn','oig-res')">Risk Assessment</button>
    </div>
    <div class="ai-row">
      <input id="oig-inp" class="ai-inp" type="text" placeholder="OIG compliance query..." onkeydown="if(event.key==='Enter')Q(this.value,'oig-btn','oig-res')">
      <button class="ask-btn" id="oig-btn" onclick="Q(document.getElementById('oig-inp').value,'oig-btn','oig-res')">&#9654; ASK</button>
    </div>
    <div id="oig-res" class="ai-res">&gt; AI ready.</div>
  </div>
</div>

<!-- ═══ TAB: AI ANALYSIS ═══ -->
<div id="tab-ai">
  <div class="ai-box" style="margin-top:16px">
    <div class="ai-hdr">&#9889; DEEP AI ANALYSIS</div>
    <div class="ai-row">
      <input id="ai-inp" class="ai-inp" type="text" placeholder="Enter detailed compliance query..." onkeydown="if(event.key==='Enter')Q(this.value,'ai-btn','ai-res')">
      <button class="ask-btn" id="ai-btn" onclick="Q(document.getElementById('ai-inp').value,'ai-btn','ai-res')">&#9654; ASK</button>
    </div>
    <div id="ai-res" class="ai-res">&gt; AI Analysis ready.</div>
  </div>
</div>

<!-- ═══ TAB: PRESETS ═══ -->
<div id="tab-presets">
  <div class="sec" style="margin-top:16px">
    <div class="sec-hdr">PRESET LIBRARY &mdash; Click any to load into AI</div>
    <div class="pr-grid">
      <div class="pr-card" onclick="loadAI('Draft CMS penalty response documentation for 2 active penalties — $24K exposure · include corrective action plan and timeline for remediation')"><div class="pr-card-title">Penalty Response</div><div class="pr-card-desc">CMS penalty documentation</div></div>
      <div class="pr-card" onclick="loadAI('Conduct HIPAA Security Risk Assessment review — identify 3 overdue remediation items, prioritize by OCR enforcement risk, and build corrective action plan')"><div class="pr-card-title">HIPAA SRA Review</div><div class="pr-card-desc">Security risk assessment</div></div>
      <div class="pr-card" onclick="loadAI('Review 6 open CMS Conditions of Participation items — identify 2 approaching survey window, build evidence package and mock survey preparation checklist')"><div class="pr-card-title">CoP Survey Prep</div><div class="pr-card-desc">CMS survey readiness</div></div>
      <div class="pr-card" onclick="loadAI('Build OIG exclusion verification process for new vendors — design monthly screening workflow and retroactive check for 3 unverified vendors')"><div class="pr-card-title">OIG Exclusion Check</div><div class="pr-card-desc">Vendor exclusion screening</div></div>
      <div class="pr-card" onclick="loadAI('Design HIPAA annual training completion push — identify 16% incomplete staff, build escalation path, and create training attestation tracking')"><div class="pr-card-title">Training Compliance</div><div class="pr-card-desc">HIPAA training completion</div></div>
      <div class="pr-card" onclick="loadAI('Build 90-day compliance posture improvement plan — HIPAA, CMS CoP, OIG, Joint Commission — prioritized by enforcement risk and deadline')"><div class="pr-card-title">90-Day Compliance Plan</div><div class="pr-card-desc">Full compliance roadmap</div></div>
    </div>
  </div>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="fn">&#9878;&#65039; COMPLIANCE NODE &nbsp; Ready &mdash; run analysis or relay to Strategist</div>
  <div class="fbtns">
    <button class="fbtn fbnca" onclick="Q('Run a full BNCA for HC COMPLIANCE COMMAND: top risks, compliance gaps, priority actions','dash-btn','dash-res');switchTab('dash',document.querySelector('.nav-btn'))">&#9889; RUN BNCA</button>
    <button class="fbtn frelay" onclick="window.open('https://hc-strategist.tsmatter.com','_blank')">&#128279; RELAY TO STRATEGIST</button>
  </div>
</div>

<!-- INTAKE FEED -->
<div id="intakeFeed_compliance" style="display:none;position:fixed;top:60px;right:20px;z-index:9999;width:360px;background:#0a140a;border:1px solid rgba(0,255,136,0.25);border-left:3px solid #00ff88;padding:16px 18px;border-radius:4px;box-shadow:0 4px 24px rgba(0,0,0,0.6)">
  <div style="font-family:'Courier New',monospace;font-size:9px;letter-spacing:3px;color:#00ff88;margin-bottom:10px">&#9670; HC COMPLIANCE INTAKE</div>
  <div id="intakeList_compliance" style="display:flex;flex-direction:column;gap:6px;max-height:280px;overflow-y:auto"></div>
</div>



<script>
// ── SINGLE TAB CONTROLLER ──
function switchTab(id, btn) {
  document.querySelectorAll('[id^="tab-"]').forEach(function(el) {
    el.style.setProperty('display', 'none', 'important');
  });
  var target = document.getElementById('tab-' + id);
  if (target) target.style.setProperty('display', 'block', 'important');
  document.querySelectorAll('.nav-btn').forEach(function(b) { b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
}
function loadAI(prompt) {
  var aiBtn = null;
  document.querySelectorAll('.nav-btn').forEach(function(b) {
    if ((b.getAttribute('onclick') || '').indexOf("'ai'") > -1) aiBtn = b;
  });
  switchTab('ai', aiBtn);
  var inp = document.getElementById('ai-inp');
  if (inp) inp.value = prompt;
  setTimeout(function() { Q(prompt, 'ai-btn', 'ai-res'); }, 50);
}
function loadPreset(p) { loadAI(p); }
async function Q(prompt, btnId, resId) {
    if (!prompt || !prompt.trim()) return;
    var btn = document.getElementById(btnId);
    var res = document.getElementById(resId);
    if (!btn || !res) return;
    btn.disabled = true;
    res.innerHTML = '<span style="display:inline-block;animation:spin 1s linear infinite">⟳</span> TSM Neural processing...';
    try {
      var r = await fetch('/api/hc/query', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          system: 'You are a healthcare compliance expert specializing in HIPAA, CMS regulations, OIG guidelines, and healthcare audit defense. Provide precise, actionable compliance intelligence.',
          message: prompt,
          stream: false,
          max_tokens: 1000
        })
      });
      var d = await r.json();
      var reply = d.response || d.content || (d.choices&&d.choices[0]&&d.choices[0].message&&d.choices[0].message.content) || 'No response';
      res.style.whiteSpace = 'pre-wrap';
      res.textContent = '> TSM NEURAL [' + new Date().toLocaleTimeString() + ']\n\n' +
        reply.replace(/\*\*(.+?)\*\*/g,'$1').replace(/\*(.+?)\*/g,'$1').replace(/#{1,3}\s*/g,'').trim();
    } catch(e) {
      res.textContent = '> TSM NEURAL ERROR: ' + e.message;
    }
    btn.disabled = false;
  }
window.Q = Q;
window.switchTab = switchTab;
window.loadAI = loadAI;
window.loadPreset = loadPreset;
window.addEventListener('load', function() {
  var first = document.querySelector('.nav-btn');
  if (first) {
    var m = (first.getAttribute('onclick') || '').match(/switchTab\('([^']+)'/);
    switchTab(m ? m[1] : 'dash', first);
  }
});
</script>

<script>
(function(){
  if(window.__TSM_NODE_AI__) return;
  window.__TSM_NODE_AI__ = true;

  const nodeName = location.pathname.split('/')[2].replace('hc-','').replace('/','');

  function getInput(){
    return document.querySelector('input, textarea');
  }

  function getOutput(){
    let el = document.querySelector('.tsm-ai-output');
    if(!el){
      el = document.createElement('div');
      el.className = 'tsm-ai-output';
      el.style.cssText = "margin-top:10px;padding:10px;border:1px solid rgba(0,255,170,.2);color:#bfffe6;font-size:12px;";
      document.body.appendChild(el);
    }
    return el;
  }

  async function run(){
    const input = getInput();
    if(!input) return;

    const msg = input.value || "Run analysis";

    const out = getOutput();
    out.innerHTML = "Running AI analysis...";

    try{
      const res = await fetch('/api/hc/node',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          node: nodeName,
          message: msg
        })
      });

      const data = await res.json();

      const actions = (data.bnca?.actions || []).slice(0,3);

      out.innerHTML = `
        <b style="color:#00ffc6;">AI ANALYSIS</b><br><br>
        <div style="color:#fff;margin-bottom:6px;">
          ${data.bnca?.priority || data.finding}
        </div>
        <div>
          ${actions.map(a => "• " + a).join("<br>")}
        </div>
        <div style="margin-top:8px;color:#ffc400;">
          Owner: ${data.bnca?.owner || 'Node Lead'} · ${data.bnca?.timeline || 'Today'}
        </div>
      `;

    }catch(e){
      out.innerHTML = "AI error";
    }
  }

  document.addEventListener('click', e=>{
    if(e.target && e.target.innerText && e.target.innerText.includes('ASK')){
      e.preventDefault();
      run();
    }
  });

})();
</script>

</body></html>