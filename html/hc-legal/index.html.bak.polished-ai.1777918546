<script>
(function(){
  function switchTab(id,btn){
    document.querySelectorAll('[id^="tab-"]').forEach(function(el){
      el.style.setProperty('display','none','important');
    });
    var t=document.getElementById('tab-'+id)||document.getElementById(id);
    if(t) t.style.setProperty('display','block','important');
    document.querySelectorAll('.nav-btn').forEach(function(b){b.classList.remove('active');});
    if(btn) btn.classList.add('active');
  }
  function loadAI(p){
    var aiBtn=null;
    document.querySelectorAll('.nav-btn').forEach(function(b){
      if((b.getAttribute('onclick')||'').indexOf("'ai'")>-1) aiBtn=b;
    });
    switchTab('ai',aiBtn);
    var inp=document.getElementById('ai-inp');
    if(inp){inp.value=p;inp.focus();}
    setTimeout(function(){if(window.Q)Q(p,'ai-btn','ai-res');},50);
  }
  function loadPreset(p){loadAI(p);}

  async function Q(prompt, btnId, resId) {
    if (!prompt || !prompt.trim()) return;
    var btn = document.getElementById(btnId);
    var res = document.getElementById(resId);
    if (!btn || !res) return;
    btn.disabled = true;
    res.innerHTML = '<span style="display:inline-block;animation:spin 1s linear infinite">⟳</span> TSM Neural processing...';
    try {
      var r = await fetch('/api/hc/query', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          system: 'You are a healthcare legal expert specializing in HIPAA, Stark Law, Anti-Kickback Statute, CMS regulations, and healthcare compliance. Provide precise, actionable legal intelligence with specific regulatory citations.',
          message: prompt,
          stream: false,
          max_tokens: 1000
        })
      });
      var d = await r.json();
      var reply = d.response || d.content || (d.choices&&d.choices[0]&&d.choices[0].message&&d.choices[0].message.content) || 'No response';
      res.style.whiteSpace = 'pre-wrap';
      res.textContent = '> TSM NEURAL [' + new Date().toLocaleTimeString() + ']\n\n' +
        reply.replace(/\*\*(.+?)\*\*/g,'$1').replace(/\*(.+?)\*/g,'$1').replace(/#{1,3}\s*/g,'').trim();
    } catch(e) {
      res.textContent = '> TSM NEURAL ERROR: ' + e.message;
    }
    btn.disabled = false;
  }
  window.Q=Q;
  window.switchTab=switchTab;
  window.loadAI=loadAI;
  window.loadPreset=loadPreset;
  document.addEventListener('DOMContentLoaded',function(){
    switchTab('dash',document.querySelector('.nav-btn'));
  });
})();
</script>



<script id="tsm-hc-node-ai-clean-output">
(function(){
  if(window.__TSM_HC_NODE_AI_CLEAN__) return;
  window.__TSM_HC_NODE_AI_CLEAN__ = true;

  const nodeName = location.pathname.split('/').filter(Boolean).find(x => x.startsWith('hc-'))?.replace('hc-','') || 'operations';

  function hideUnavailable(){
    document.querySelectorAll('*').forEach(el => {
      const txt = (el.textContent || '').trim();
      if(txt === 'AI unavailable'){
        el.style.display = 'none';
      }
    });
  }

  function findOutputBox(){
    const candidates = Array.from(document.querySelectorAll('div,pre,code,section,article'));

    let exact = candidates.find(el => (el.textContent || '').trim() === 'AI unavailable');
    if(exact) return exact;

    let neural = candidates.find(el => /TSM NEURAL|AI ready|AI unavailable/i.test(el.textContent || '') && (el.textContent || '').length < 600);
    if(neural) return neural;

    let existing = document.querySelector('.tsm-ai-output-clean');
    if(existing) return existing;

    const panels = candidates.filter(el => /AI ANALYSIS|DEEP AI ANALYSIS/i.test(el.textContent || '') && (el.textContent || '').length < 1800);
    if(panels[0]) return panels[0];

    let fallback = document.createElement('div');
    fallback.className = 'tsm-ai-output-clean';
    fallback.style.cssText = "margin:12px 0;padding:12px;border:1px solid rgba(0,255,170,.25);color:#bfffe6;font-size:12px;background:rgba(0,255,170,.04);";
    document.body.appendChild(fallback);
    return fallback;
  }

  function getPrompt(){
    const inputs = Array.from(document.querySelectorAll('input, textarea'));
    const active = inputs.find(i => (i.value || '').trim().length > 0);
    return active?.value || 'Run department AI analysis and return best next actions.';
  }

  function render(out, data){
    const actions = (data.bnca && data.bnca.actions ? data.bnca.actions : []).slice(0,3);
    out.classList.add('tsm-ai-output-clean');
    out.style.display = 'block';
    out.style.whiteSpace = 'normal';
    out.innerHTML = `
  <div style="color:#00ffc6;font-weight:800;margin-bottom:8px;letter-spacing:1px;">
    AI ANALYSIS
  </div>

  <div style="color:#ffffff;margin-bottom:10px;font-size:13px;line-height:1.5;">
    ${data.bnca?.priority || data.finding || 'Node analysis active.'}
  </div>

  <div style="color:#bfffe6;font-size:12px;line-height:1.6;">
    1. ${data.bnca?.actions?.[0] || ''}
    <br>2. ${data.bnca?.actions?.[1] || ''}
    <br>3. ${data.bnca?.actions?.[2] || ''}
  </div>

  <div style="margin-top:10px;color:#ffc400;font-size:11px;">
    Owner: ${data.bnca?.owner || 'Node Lead'} · ${data.bnca?.timeline || 'Today'}
  </div>
`;
  }

  async function run(){
    hideUnavailable();
    const out = findOutputBox();
    out.innerHTML = '<span style="color:#00ffc6;">TSM Neural processing...</span>';

    try{
      const res = await fetch('/api/hc/node', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          node: nodeName,
          message: getPrompt()
        })
      });

      const data = await res.json();
      render(out, data);
      hideUnavailable();
    }catch(e){
      out.innerHTML = '<span style="color:#ff4d6d;">AI connection issue. Backend node endpoint available from command center.</span>';
    }
  }

  document.addEventListener('click', function(e){
    const txt = (e.target && (e.target.innerText || e.target.textContent || '')).trim();
    if(/ASK|RUN BNCA|ANALYZE/i.test(txt)){
      e.preventDefault();
      run();
    }
  });

  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', hideUnavailable);
  else hideUnavailable();
})();
</script>

</body></html>