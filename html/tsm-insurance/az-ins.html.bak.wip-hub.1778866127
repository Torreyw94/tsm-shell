<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TSM Sovereign - AZ Insurance Ethics</title>
    <link rel="stylesheet" href="../../shared/styles.css">
    <style>
        .quiz-container { background: rgba(0, 20, 40, 0.8); border: 1px solid #00f2ff; padding: 20px; margin-top: 20px; }
        .question { color: #00f2ff; font-size: 1.1em; margin-bottom: 15px; }
        .option { display: block; padding: 10px; margin: 5px 0; background: rgba(0, 242, 255, 0.1); border: 1px solid #00f2ff; cursor: pointer; transition: 0.3s; }
        .option:hover { background: rgba(0, 242, 255, 0.3); }
        .feedback { margin-top: 15px; font-weight: bold; }
        .correct { color: #00ff88; }
        .incorrect { color: #ff0055; }
    </style>
</head>
<body>
    <div class="dashboard-header">
        <h1>Sovereign Mesh: Arizona Insurance CE</h1>
        <div id="compliance-status"></div>
    </div>

    <div class="quiz-container" id="quiz-box">
        <h2>10-Question Ethics Challenge</h2>
        <div id="question-area">
            <p>Initializing Ethics Module...</p>
        </div>
        <button onclick="loadQuestion()" id="next-btn" style="display:none; margin-top:10px;">Next Question</button>
    </div>

    <script src="../../shared/tsm-shared.js"></script>
    <script>
        const AZCompliance = {
            term: "2022-2026",
            requiredHours: 48,
            requiredEthics: 6,
            isExempt: false,
            calculateStatus: function(total, ethics) {
                const hLeft = Math.max(0, this.requiredHours - total);
                const eLeft = Math.max(0, this.requiredEthics - ethics);
                return `Status: ${hLeft === 0 && eLeft === 0 ? "READY FOR RENEWAL" : "INCOMPLETE (Need " + hLeft + "h total, " + eLeft + "h Ethics)"}`;
            }
        };

        const questions = [
            { q: "Under ARS § 20-287, in what capacity must a producer hold premium funds?", a: ["Fiduciary", "Personal", "Escrow", "Trustee"], c: 0, r: "Correct. Producers hold funds in a fiduciary capacity." },
            { q: "What is the maximum civil penalty for a willful violation of a Cease and Desist order by an individual?", a: ["$1,000", "$5,000", "$10,000", "$50,000"], c: 2, r: "Correct. Individuals face up to $10,000 per violation." },
            { q: "Arizona law requires insurance transaction records to be kept for how many years?", a: ["1 Year", "3 Years", "5 Years", "7 Years"], c: 1, r: "Correct. Records must be maintained for at least 3 years." },
            { q: "How many hours of Ethics CE are required for Arizona resident producers every term?", a: ["3 Hours", "6 Hours", "12 Hours", "48 Hours"], c: 1, r: "Correct. 6 of the 48 hours must be Ethics." },
            { q: "A producer who assists an insured in hiding sales data to lower premiums is committing:", a: ["Twisting", "Sliding", "Premium Fraud", "Coercion"], c: 2, r: "Correct. Misrepresenting exposure bases is fraud." },
            { q: "The Director may suspend a license for demonstrating 'untrustworthiness'. This falls under:", a: ["DIFI Discretion", "Statutory Discipline", "Common Law", "Admin Code"], c: 1, r: "Correct. Statutory authority allows discipline for untrustworthiness." },
            { q: "An Arizona producer license expires on:", a: ["Dec 31st", "Policy Anniversary", "Last day of birth month", "Jan 1st"], c: 2, r: "Correct. It follows your birth month every 4 years." },
            { q: "Using misrepresentation to induce a policyholder to drop an existing policy is called:", a: ["Rebating", "Twisting", "Defamation", "Boycotting"], c: 1, r: "Correct. Twisting is an unfair trade practice." },
            { q: "Who is exempt from the 48-hour CE requirement in Arizona?", a: ["Military", "CLU Holders", "Licensed since Jan 1, 1995", "Non-residents"], c: 2, r: "Correct. Continuous licensure since Jan 1, 1995 confers exemption." },
            { q: "If a producer moves within Arizona, they must notify the Director within:", a: ["10 Days", "30 Days", "60 Days", "90 Days"], c: 1, r: "Correct. Address changes must be reported within 30 days." }
        ];

        let currentQ = 0;
        function loadQuestion() {
            const qa = document.getElementById('question-area');
            const btn = document.getElementById('next-btn');
            btn.style.display = 'none';
            if(currentQ >= questions.length) {
                qa.innerHTML = "<h3>Ethics Module Complete!</h3><p>Ready for 2026 Renewal.</p>";
                return;
            }
            const q = questions[currentQ];
            let html = `<div class='question'>${currentQ + 1}. ${q.q}</div>`;
            q.a.forEach((opt, i) => {
                html += `<div class='option' onclick='checkAns(${i})'>${opt}</div>`;
            });
            qa.innerHTML = html;
        }

        function checkAns(idx) {
            const q = questions[currentQ];
            const qa = document.getElementById('question-area');
            const res = idx === q.c ? `<p class='correct'>${q.r}</p>` : `<p class='incorrect'>Incorrect. ${q.r}</p>`;
            qa.innerHTML += `<div class='feedback'>${res}</div>`;
            document.getElementById('next-btn').style.display = 'block';
            currentQ++;
        }

        document.getElementById('compliance-status').innerText = AZCompliance.calculateStatus(0, 0);
        window.onload = loadQuestion;
    </script>

<script id="tsm-universal-wip-ai">
(function(){

window.runSectorAI = async function(sector, question){

  const out =
    document.querySelector("#narrative-output") ||
    document.querySelector("#strategist-output") ||
    document.querySelector(".narrative") ||
    document.querySelector("#ai-output");

  if(out){
    out.innerHTML = "Running strategist synthesis...";
  }

  try{

    const res = await fetch("/api/wip/sector-ai",{
      method:"POST",
      headers:{ "Content-Type":"application/json" },
      body:JSON.stringify({
        sector,
        question
      })
    });

    const data = await res.json();

    if(out){
      out.innerHTML =
        "<pre style='white-space:pre-wrap;font-family:inherit'>" +
        (data.content || "No AI response") +
        "</pre>";
    }

    console.log("WIP strategist complete", data);

    return data;

  }catch(e){

    console.error(e);

    if(out){
      out.innerHTML = "AI route unavailable";
    }
  }
};

})();
</script>


<div style="
margin:20px;
padding:20px;
background:#07131d;
border:1px solid rgba(0,255,200,.2);
border-radius:16px;
">

<h2 style="color:#00ffc6">
Insurance Claims WIP Intelligence
</h2>

<div id="narrative-output"
style="
margin-top:16px;
padding:16px;
background:#051018;
border-radius:12px;
min-height:160px;
">
Insurance strategist awaiting synthesis...
</div>

<div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px">

<button onclick="runSectorAI('INSURANCE','Analyze claims leakage and policy variance')" style="background:#00ffc6;color:#001;font-weight:800;border:0;padding:10px 14px;border-radius:10px">
Run Claims BNCA
</button>

<button onclick="runSectorAI('INSURANCE','Generate insurance executive audit summary')" style="background:#ffd84d;color:#111;font-weight:800;border:0;padding:10px 14px;border-radius:10px">
Audit Summary
</button>

<button onclick="window.print()" style="background:#b56cff;color:white;font-weight:800;border:0;padding:10px 14px;border-radius:10px">
Export PDF
</button>

</div>
</div>

</body>
</html>
