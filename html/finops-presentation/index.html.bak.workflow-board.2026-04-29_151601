<script id="finops-role-mode-engine">
function setFinopsMode(mode){
  document.body.setAttribute("data-mode", mode);
  localStorage.setItem("finops_role_mode", mode);

  ["Operator","Controller","Executive"].forEach(x=>{
    const btn=document.getElementById("modeBtn"+x);
    if(btn) btn.classList.remove("active");
  });

  const key = mode.charAt(0).toUpperCase()+mode.slice(1);
  const active = document.getElementById("modeBtn"+key);
  if(active) active.classList.add("active");
}

(function(){
  const saved = localStorage.getItem("finops_role_mode") || "operator";
  setTimeout(()=>setFinopsMode(saved), 100);
})();
</script>

