function set(id,txt){document.getElementById(id).textContent=txt}

async function runCycle(){
  set('cmdOut',
`FINOPS CYCLE RUNNING

✓ Financial Intel: AP queue + AR risk analyzed
✓ Tax Intelligence: 1099 / W-9 readiness checked
✓ Compliance Shield: supporting docs reviewed
✓ Zero Trust: QuickBooks access risk checked
✓ Strategist: BNCA generated`);

  set('mainOut',
`SYSTEM RESULT:
→ 12 vendor invoices prioritized
→ 3 reconciliation issues flagged before month-end close
→ 7 vendors moved into 1099 readiness review
→ Controller report prepared

VALUE:
12–18 hours/month immediately saved.
$5K–$7K/month manual workload replaced by $1,750/month system.`);

  try{
    await fetch('/api/finops/report',{
      method:'POST',
      headers:{'content-type':'application/json'},
      body:JSON.stringify({
        title:'FinOps Presentation Cycle',
        summary:document.getElementById('mainOut').textContent,
        metrics:{apInvoices:12,reconItems:3,vendors1099:7,timeSaved:'12–18 hrs/month'}
      })
    });
  }catch(e){}
}

function pushMain(){
  localStorage.setItem('tsm_finops_report', JSON.stringify({
    ts:new Date().toISOString(),
    title:'FinOps Presentation Executive Output',
    summary:document.getElementById('mainOut').textContent || 'FinOps cycle pushed to Main Strategist.'
  }));
  location.href='/html/finops-main-strategist/index.html?v=from-finops-presentation';
}
</script>

