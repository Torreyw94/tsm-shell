  const el = document.createElement("div");
  el.id = "finopsExecutiveClose";
  el.style = `
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.76);
    backdrop-filter:blur(6px);
    z-index:100000;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:20px;
  `;

  el.innerHTML = `
    <div style="
      background:#02070d;
      border:1px solid #00e0ff;
      padding:26px;
      border-radius:16px;
      max-width:720px;
      width:94%;
      color:#d9f3ff;
      box-shadow:0 0 50px rgba(0,224,255,.25);
      font-family:ui-monospace,Menlo,monospace;
    ">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">
        <div>
