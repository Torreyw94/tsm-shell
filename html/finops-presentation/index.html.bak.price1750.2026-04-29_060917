  `;

  document.body.appendChild(el);
}

function startPilot(){
  showConfirm("Pilot Started", "We’ll deploy this against reconciliation, AP, 1099 readiness, and controller reporting.");
}

function bookWalkthrough(){
  showConfirm("Walkthrough Locked", "We’ll walk through AR, AP, bank reconciliation, close prep, tax readiness, and compliance live.");
}

function showConfirm(title, text){
  const old = document.getElementById("finopsConfirmModal");
  if(old) old.remove();

  const el = document.createElement("div");
  el.id = "finopsConfirmModal";
  el.style = `
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    background:#02070d;
    border:1px solid #00e0ff;
    padding:24px;
    border-radius:14px;
    z-index:100002;
    text-align:center;
    max-width:440px;
    width:90%;
    color:#d9f3ff;
    box-shadow:0 0 40px rgba(0,224,255,.3);
    font-family:ui-monospace,Menlo,monospace;
  `;

  el.innerHTML = `
    <div style="font-size:18px;font-weight:900;color:#00e0ff;margin-bottom:10px">${title}</div>
    <div style="font-size:13px;color:#8fb0c8;margin-bottom:18px;line-height:1.5">${text}</div>
    <button onclick="this.parentElement.remove()" style="
      background:#00e0ff;color:#001018;border:none;padding:10px 16px;border-radius:8px;font-weight:900;cursor:pointer">
      CONFIRMED
    </button>
  `;

  document.body.appendChild(el);
}

