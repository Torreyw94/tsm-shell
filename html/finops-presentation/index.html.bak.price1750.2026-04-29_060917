          <div style="font-size:28px;color:#00f59f;font-weight:900;margin-top:8px">12</div>
          <small>pending validation</small>
        </div>
        <div style="background:#061018;border:1px solid #123050;border-radius:12px;padding:14px">
          <b style="color:#00e0ff">Close Readiness</b>
          <div style="font-size:28px;color:#00f59f;font-weight:900;margin-top:8px">84%</div>
          <small>month-end package</small>
