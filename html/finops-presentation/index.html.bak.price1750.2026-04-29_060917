          <div style="font-size:24px;font-weight:900;margin-bottom:6px">
            Financial Operations Layer
          </div>
          <div style="font-size:13px;color:#8fb0c8;margin-bottom:16px">
            Accounting pressure converted into decision-ready action.
          </div>
        </div>
        <button onclick="document.getElementById('finopsExecutiveClose').remove()" style="
          background:transparent;color:#8fb0c8;border:1px solid #123050;border-radius:8px;padding:8px 10px;cursor:pointer">
          close
        </button>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:16px">
        <div style="background:#061018;border:1px solid #123050;border-radius:12px;padding:14px">
          <b style="color:#00e0ff">AR Risk</b>
          <div style="font-size:28px;color:#00f59f;font-weight:900;margin-top:8px">$18.4K</div>
          <small>collections priority</small>
