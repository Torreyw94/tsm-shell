<script>
const API = { ask:'/api/hc/ask', reports:'/api/hc/reports', nodes:'/api/hc/nodes' };
const DEFAULT_BNCA_QUERY = "Review claims pressure, prior auth delays, staffing throughput, compliance drift, and site-level operational blockers. Return the Best Next Course of Action for the office manager.";
const NODE_CONFIG = {
