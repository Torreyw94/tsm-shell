<script id="main-strategist-hc-consumer">
(function(){
  async function pullMainStrategist(){
    try{
      const data=await fetch('/api/main-strategist/hc-report').then(r=>r.json());
      const report=data.report;
      if(!report || !report.summary) return;
      let out=document.getElementById('synth-output') || document.getElementById('main-strategist-output') || document.getElementById('honor-hc-brief');
