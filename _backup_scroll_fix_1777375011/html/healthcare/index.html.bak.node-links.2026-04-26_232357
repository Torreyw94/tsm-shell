        document.body.appendChild(out);
      }
      out.textContent='MAIN STRATEGIST · HEALTHCARE BRIEF\n\n'+report.summary;
    }catch(e){}
  }
  pullMainStrategist();
  setInterval(pullMainStrategist,5000);
})();
</script>





