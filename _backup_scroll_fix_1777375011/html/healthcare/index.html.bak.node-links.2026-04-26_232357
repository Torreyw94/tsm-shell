<script id="banner-final-portal-js">
async function refreshBannerPortal(){
  try{
    const data = await fetch('/api/main-strategist/hc-report').then(r=>r.json());
    const relay = data.relay || {};
    const nodes = relay.nodes || {};
    const report = data.report || {};
    const keys = Object.keys(nodes);
    const doc = nodes['ghs-document-pipeline'];
    const q = doc?.metrics?.quality || 'partial';

    let protectedValue = 420000;
    let risk = 'WATCH';
    let riskClass = 'bpWatch';

    if(q === 'complete'){ protectedValue = 784000; risk='MODERATE'; riskClass='bpGood'; }
    if(q === 'incomplete'){ protectedValue = 180000; risk='HIGH'; riskClass='bpRisk'; }

    document.getElementById('bpLive').textContent = keys.length ? 'LIVE · AUTO REFRESH' : 'WAITING';
    document.getElementById('bpNodes').textContent = keys.length + ' / 12';
    document.getElementById('bpDoc').textContent = doc ? ((doc.metrics?.document || 'Doc') + ' ' + (doc.metrics?.version || '')) : '—';
    document.getElementById('bpRevenue').textContent = '$' + protectedValue.toLocaleString();
    const riskEl=document.getElementById('bpRisk');
    riskEl.textContent = risk;
    riskEl.className = 'bpVal ' + riskClass;

    const grid=document.getElementById('bpOfficeGrid');
    grid.innerHTML = keys.map(k=>{
      const n=nodes[k]||{};
      const m=n.metrics||{};
      const txt=(n.bnca||'').toLowerCase();
      let cls='bpGood', posture='STABLE';
      if(txt.includes('hold') || txt.includes('partial') || txt.includes('risk') || m.quality==='partial'){
        cls='bpWatch'; posture='WATCH';
      }
      if(txt.includes('do not submit') || txt.includes('high risk') || m.quality==='incomplete'){
        cls='bpRisk'; posture='RISK';
      }
      return `<div class="bpCard bpPulse">
        <b>${(n.node || k).toString().replace('HC ','')}</b>
        <div class="${cls}" style="font-size:20px;font-weight:900;margin:6px 0">${posture}</div>
        <div style="color:#8fb0c8;font-size:11px">${m.document || m.node || m.status || k}</div>
      </div>`;
    }).join('') || '<div class="bpCard">No node signals yet.</div>';

    document.getElementById('bpSummary').textContent =
      report.summary ||
      'No executive report yet. Run the GHS presentation, send to HC Strategist, then push to Main Strategist.';
  }catch(e){
    document.getElementById('bpLive').textContent = 'OFFLINE';
  }
}
refreshBannerPortal();
setInterval(refreshBannerPortal,5000);
</script>

