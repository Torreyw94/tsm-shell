<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TSM Healthcare Command Center · BNCA Full System</title>
<style>
:root {
  --bg: #060d14; --panel: #0b1622; --panel2: #081018; --border: #162840; --text: #d0dcea; --muted: #4a6a8a;
  --teal: #00c896; --gold: #f0a500; --red: #ef4444; --green: #10b981; --blue: #3b82f6; --purple: #a855f7;
  --orange: #f97316; --cyan: #22d3ee; --mono: 'Courier New', monospace;
  --medical: #00c896; --pharmacy: #f0a500; --insurance: #3b82f6; --financial: #22d3ee; --legal: #a855f7;
  --vendors: #f97316; --compliance: #ef4444; --billing: #10b981; --taxprep: #e879f9; --grants: #60a5fa; --operations: #38bdf8;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 12px; min-height: 100vh; overflow-x: hidden; }
.ticker { background: #04090f; border-bottom: 1px solid #1a3050; padding: 5px 0; overflow: hidden; white-space: nowrap; }
.ticker-inner { display: inline-block; animation: scroll 50s linear infinite; font-family: var(--mono); font-size: 10px; color: var(--gold); letter-spacing: .06em; }
@keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.kpi-bar { display: grid; grid-template-columns: repeat(7,1fr); background: #07101c; border-bottom: 1px solid var(--border); }
.kpi-cell { padding: 8px 12px; border-right: 1px solid var(--border); }
.kpi-cell:last-child { border-right: none; }
.kpi-label { font-family: var(--mono); font-size: 8px; color: var(--muted); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 2px; }
.kpi-val { font-family: var(--mono); font-size: 13px; font-weight: 700; }
.kpi-sub { font-size: 9px; color: var(--muted); margin-top: 1px; }
.bnca-context-bar { display:flex; gap:18px; flex-wrap:wrap; align-items:center; padding:8px 12px; background:#08121d; border-bottom:1px solid var(--border); font-family:var(--mono); font-size:9px; color:var(--muted); letter-spacing:.08em; text-transform:uppercase; }
.bnca-context-item b { color: var(--text); font-weight: 700; }
.layout { display: grid; grid-template-columns: 180px 1fr 280px; height: calc(100vh - 126px); overflow: hidden; }
.left-sidebar { background: var(--panel); border-right: 1px solid var(--border); overflow-y: auto; display: flex; flex-direction: column; }
.sb-section { padding: 10px; border-bottom: 1px solid var(--border); }
.sb-title { font-family: var(--mono); font-size: 8px; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 8px; }
.playbook-item { padding: 7px 8px; cursor: pointer; border-radius: 4px; margin-bottom: 3px; transition: background .15s; display: flex; align-items: center; justify-content: space-between; gap:6px; }
.playbook-item:hover { background: rgba(255,255,255,.04); }
.playbook-item.active { background: rgba(0,200,150,.08); border-left: 2px solid var(--teal); }
.pb-name { font-size: 11px; color: var(--text); font-weight: 500; }
.pb-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); }
.metric-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px solid rgba(22,40,64,.6); }
.metric-row:last-child { border: none; }
.metric-label { font-size: 10px; color: var(--muted); }
.metric-val { font-family: var(--mono); font-size: 10px; font-weight: 700; }
.sys-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; }
.sys-label { font-size: 10px; color: var(--muted); }
.sys-val { font-family: var(--mono); font-size: 10px; }
.sys-val.active { color: var(--teal); } .sys-val.live { color: var(--green); } .sys-val.ready { color: var(--blue); }
.center { overflow-y: auto; display: flex; flex-direction: column; }
.deploy-bar { background: #07101c; border-bottom: 1px solid var(--border); padding: 8px 12px; }
.deploy-label { font-family: var(--mono); font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 6px; }
.node-pills { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
.node-pill { font-family: var(--mono); font-size: 9px; padding: 3px 9px; border: 1px solid; border-radius: 2px; cursor: pointer; transition: all .15s; font-weight: 700; letter-spacing: .08em; }
.node-pill.selected { opacity: 1; } .node-pill.unselected { opacity: .4; }
.pill-medical { color: var(--medical); border-color: var(--medical); } .pill-medical.selected { background: rgba(0,200,150,.12); }
.pill-pharmacy { color: var(--pharmacy); border-color: var(--pharmacy); } .pill-pharmacy.selected { background: rgba(240,165,0,.12); }
.pill-insurance { color: var(--insurance); border-color: var(--insurance); } .pill-insurance.selected { background: rgba(59,130,246,.12); }
.pill-financial { color: var(--financial); border-color: var(--financial); } .pill-financial.selected { background: rgba(34,211,238,.12); }
.pill-legal { color: var(--legal); border-color: var(--legal); } .pill-legal.selected { background: rgba(168,85,247,.12); }
.pill-vendors { color: var(--vendors); border-color: var(--vendors); } .pill-vendors.selected { background: rgba(249,115,22,.12); }
.pill-compliance { color: var(--compliance); border-color: var(--compliance); } .pill-compliance.selected { background: rgba(239,68,68,.12); }
.pill-billing { color: var(--billing); border-color: var(--billing); } .pill-billing.selected { background: rgba(16,185,129,.12); }
.pill-taxprep { color: var(--taxprep); border-color: var(--taxprep); } .pill-taxprep.selected { background: rgba(232,121,249,.12); }
.pill-grants { color: var(--grants); border-color: var(--grants); } .pill-grants.selected { background: rgba(96,165,250,.12); }
.pill-operations { color: var(--operations); border-color: var(--operations); } .pill-operations.selected { background: rgba(56,189,248,.12); }
.query-row { display: flex; gap: 6px; align-items: center; margin-bottom: 8px; }
.query-input { flex: 1; background: #081018; border: 1px solid var(--border); border-radius: 3px; color: var(--text); padding: 8px 12px; font-family: var(--mono); font-size: 11px; outline: none; }
.deploy-btn,.synth-btn{font-family: var(--mono); font-size: 10px; font-weight: 700; padding: 8px 18px; cursor: pointer; letter-spacing: .08em; transition: all .2s; border-radius: 2px;}
.deploy-btn{ background: linear-gradient(135deg,rgba(240,165,0,.2),rgba(249,115,22,.1)); border: 1px solid var(--gold); color: var(--gold); }
.synth-btn{ background: linear-gradient(135deg,rgba(168,85,247,.2),rgba(59,130,246,.1)); border: 1px solid var(--purple); color: var(--purple); }
.action-pills { display: flex; gap: 4px; flex-wrap: wrap; }
.action-pill { background: rgba(255,255,255,.05); border: 1px solid var(--border); color: var(--muted); font-size: 9px; padding: 4px 10px; cursor: pointer; transition: all .2s; font-family: var(--mono); letter-spacing: .05em; border-radius: 2px; }
.node-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border); flex: 1; }
.node-card { background: var(--panel); padding: 12px; display: flex; flex-direction: column; gap: 6px; min-height: 185px; position: relative; overflow: hidden; }
.node-card::before { content:''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
.nc-medical::before { background: var(--medical); } .nc-pharmacy::before { background: var(--pharmacy); }
.nc-insurance::before { background: var(--insurance); } .nc-financial::before { background: var(--financial); }
.nc-legal::before { background: var(--legal); } .nc-vendors::before { background: var(--vendors); }
.nc-compliance::before { background: var(--compliance); } .nc-billing::before { background: var(--billing); }
.nc-taxprep::before { background: var(--taxprep); } .nc-grants::before { background: var(--grants); }
.nc-operations::before { background: var(--operations); }
.nc-header { display:flex; justify-content:space-between; align-items:flex-start; }
.nc-live { display:flex; align-items:center; gap:4px; font-family:var(--mono); font-size:8px; color:var(--teal); text-transform:uppercase; letter-spacing:.1em; }
.nc-live-dot { width:5px;height:5px;border-radius:50%;background:var(--teal);animation:pulse 1.8s infinite; }
.nc-port { font-family: var(--mono); font-size: 8px; color: var(--muted); }
.nc-title { font-family: var(--mono); font-size: 14px; font-weight: 700; color: #fff; letter-spacing: .04em; }
.nc-subtitle { font-size: 9px; color: var(--muted); line-height: 1.4; }
.nc-progress-bar { height: 2px; background: rgba(255,255,255,.07); border-radius: 1px; overflow: hidden; }
.nc-progress-fill { height: 100%; border-radius: 1px; transition: width 1s ease; }
.nc-output { font-family: var(--mono); font-size: 9px; color: var(--muted); line-height: 1.55; flex: 1; overflow: hidden; max-height: 90px; white-space: pre-wrap; }
.nc-output.active { color: var(--text); }
.nc-footer { display: flex; gap: 4px; justify-content: space-between; align-items: center; margin-top: auto; }
.nc-open-btn { background: rgba(255,255,255,.05); border: 1px solid var(--border); color: var(--muted); font-family: var(--mono); font-size: 8px; padding: 4px 10px; cursor: pointer; border-radius:2px; }
.nc-status { font-family: var(--mono); font-size: 8px; color: var(--muted); }
.nc-status.live { color: var(--green); } .nc-status.fallback { color: var(--gold); } .nc-status.ready { color: var(--blue); }
.nc-status.running { color: var(--teal); animation: blink .8s infinite; }
.right-sidebar { background: var(--panel); border-left: 1px solid var(--border); overflow-y: auto; display: flex; flex-direction: column; }
.rs-header { padding: 12px 14px; border-bottom: 1px solid var(--border); background: rgba(0,0,0,.3); }
.rs-title { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--purple); letter-spacing: .04em; }
.rs-subtitle { font-size: 9px; color: var(--muted); margin-top: 3px; text-transform: uppercase; letter-spacing: .09em; }
.rs-node-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 4px; padding: 10px 12px; border-bottom: 1px solid var(--border); }
.rs-node-btn { border: 1px solid; padding: 5px 6px; font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .06em; border-radius: 2px; text-align: center; }
.rs-section { padding: 10px 14px; border-bottom: 1px solid var(--border); }
.rs-section-title { font-family: var(--mono); font-size: 8px; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 8px; }
.synth-output { font-family: var(--mono); font-size: 9px; color: var(--text); line-height: 1.7; white-space: pre-wrap; max-height: 320px; overflow-y: auto; }
.conf-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 3px; }
.conf-item { background: rgba(255,255,255,.03); padding: 5px 7px; border-radius: 3px; }
.conf-label { font-size: 8px; color: var(--muted); } .conf-val { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--teal); }
.report-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:12px;margin:14px 12px}
.saved-list{display:grid;gap:8px;max-height:220px;overflow:auto}
.saved-card{padding:10px;border:1px solid var(--border);border-radius:6px;background:var(--panel2)}
.saved-title{color:var(--gold);font-weight:700;font-size:11px;margin-bottom:4px}
.saved-meta{color:var(--muted);font-size:10px;margin-bottom:6px}
.alert-row{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid #0f1f0f}
.pri{padding:2px 8px;border-radius:10px;font-size:9px;font-weight:700;min-width:58px;text-align:center}
.purgent{background:#330000;color:var(--red);border:1px solid var(--red)}
.pmed{background:#332200;color:var(--gold);border:1px solid var(--gold)}
.pok{background:#003322;color:var(--green);border:1px solid var(--green)}
.alert-txt{font-size:12px;flex:1} .alert-imp{font-size:11px;color:var(--gold);min-width:90px;text-align:right}
.ai-box{margin:12px;background:var(--panel2);border:1px solid var(--border);border-radius:6px;padding:16px}
.ai-hdr{font-size:11px;font-weight:700;letter-spacing:2px;color:var(--gold);margin-bottom:10px}
.ai-res{margin-top:10px;padding:10px;background:#0b120b;border:1px solid var(--border);border-radius:4px;color:#99cc99;font-size:12px;min-height:40px;white-space:pre-wrap;line-height:1.6}
.thinking { animation: shimmer 1.2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }
@keyframes shimmer { 0%{opacity:.3} 50%{opacity:.7} 100%{opacity:.3} }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }
::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-thumb { background: #1a3050; border-radius: 2px; }
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.8); z-index: 100; display: none; align-items: center; justify-content: center; }
.modal-overlay.open { display: flex; }
.modal { background: #0b1622; border: 1px solid var(--border); border-radius: 8px; width: 700px; max-height: 80vh; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,.8); }
.modal-header { padding: 14px 18px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,.3); }
.modal-title { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--text); }
.modal-close { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 20px; padding: 0 4px; }
.modal-body { flex: 1; overflow-y: auto; padding: 16px 18px; }
.modal-output { font-family: var(--mono); font-size: 11px; color: var(--text); line-height: 1.8; white-space: pre-wrap; }
.modal-input-row { padding: 12px 18px; border-top: 1px solid var(--border); display: flex; gap: 8px; }
.modal-input { flex: 1; background: #060d14; border: 1px solid var(--border); border-radius: 4px; color: var(--text); padding: 8px 12px; font-family: var(--mono); font-size: 11px; outline: none; }
.modal-send { background: var(--gold); border: none; color: #07101c; font-weight: 700; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-family: var(--mono); font-size: 10px; }
@media (max-width: 1360px){ .layout { grid-template-columns: 170px 1fr 240px; } .node-grid { grid-template-columns: repeat(3,1fr); } }
</style>
</head>
<body>
<div class="ticker"><div class="ticker-inner">
BNCA MODE — OFFICE MANAGER ACTIONS FIRST &nbsp;//&nbsp; CLAIMS BACKLOG — 247 PENDING ADJUDICATIONS &nbsp;//&nbsp; DENIAL RATE — 18.4% VS TARGET 9% &nbsp;//&nbsp; PRIOR AUTH FRICTION — HIGH &nbsp;//&nbsp; OPERATIONS NODE — LIVE &nbsp;//&nbsp; STAFFING / THROUGHPUT — WATCHLIST ACTIVE &nbsp;//&nbsp; ALL HEALTHCARE NODES ONLINE 11 / 11
</div></div>

<div class="kpi-bar">
  <div class="kpi-cell"><div class="kpi-label">Revenue at Risk</div><div class="kpi-val" style="color:var(--red)" id="kpi-rar">$2.1M</div><div class="kpi-sub">active rev-cycle value</div></div>
  <div class="kpi-cell"><div class="kpi-label">Claims Pending</div><div class="kpi-val" style="color:var(--gold)" id="kpi-claims">247</div><div class="kpi-sub">adjudication queue</div></div>
  <div class="kpi-cell"><div class="kpi-label">Compliance Score</div><div class="kpi-val" style="color:var(--teal)" id="kpi-comp">84%</div><div class="kpi-sub">HIPAA + CMS + OIG</div></div>
  <div class="kpi-cell"><div class="kpi-label">Denial Rate</div><div class="kpi-val" style="color:var(--orange)" id="kpi-denial">18.4%</div><div class="kpi-sub">above target window</div></div>
  <div class="kpi-cell"><div class="kpi-label">Nodes Live</div><div class="kpi-val" style="color:var(--green)" id="kpi-nodes">11 / 11</div><div class="kpi-sub">bnca mesh online</div></div>
  <div class="kpi-cell"><div class="kpi-label">Ops Queue</div><div class="kpi-val" style="color:var(--blue)" id="kpi-ops">31</div><div class="kpi-sub">front-desk pressure</div></div>
  <div class="kpi-cell"><div class="kpi-label">Saved Reports</div><div class="kpi-val" style="color:var(--purple)" id="kpi-reports">0</div><div class="kpi-sub">browser + server memory</div></div>
</div>

<div class="bnca-context-bar">
  <div class="bnca-context-item">Mode: <b>Office Manager</b></div>
  <div class="bnca-context-item">Template: <b>General Healthcare</b></div>
  <div class="bnca-context-item">Scope: <b>Claims · Auths · Compliance · Staffing · Vendors</b></div>
  <div class="bnca-context-item">Engine: <b>BNCA</b></div>
</div>

<div class="layout">
  <div class="left-sidebar">
    <div class="sb-section">
      <div class="sb-title">BNCA Playbooks</div>
      <div class="playbook-item active" onclick="loadPlaybook(this,'Claim Recovery','Review claims pressure, denial exposure, and the best next office-manager actions for recovery.')"><div class="pb-name">Claim Recovery</div><div class="pb-dot"></div></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Denial Sweep','Analyze denial patterns, CPT / ICD friction, and identify the best next course of action for the office manager.')"><div class="pb-name">Denial Sweep</div><span style="font-family:var(--mono);font-size:9px;color:var(--gold)">HOT</span></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Prior Auth Bottlenecks','Review pending authorizations, turnaround delays, and recommend the best next office actions.')"><div class="pb-name">Prior Auth</div><span style="font-family:var(--mono);font-size:9px;color:var(--orange)">QUEUE</span></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Audit Sweep','Identify documentation gaps, compliance drift, and immediate remediation actions.')"><div class="pb-name">Audit Sweep</div><span style="font-family:var(--mono);font-size:9px;color:var(--red)">RISK</span></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Staffing / Throughput','Review staffing pressure, handoff delays, scheduling friction, and throughput blockers.')"><div class="pb-name">Staffing / Throughput</div><span style="font-family:var(--mono);font-size:9px;color:var(--blue)">OPS</span></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Vendor / Supply Risk','Assess vendor delays, supply constraints, and next-step mitigation actions.')"><div class="pb-name">Vendor / Supply Risk</div><span style="font-family:var(--mono);font-size:9px;color:var(--gold)">2</span></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Cash Flow','Analyze collections pressure, AR aging, and office-level revenue drag.')"><div class="pb-name">Cash Flow</div><span style="font-family:var(--mono);font-size:9px;color:var(--teal)">LIVE</span></div>
      <div class="playbook-item" onclick="loadPlaybook(this,'Tax / Filing Window','Review healthcare tax obligations, filing status, and upcoming deadlines.')"><div class="pb-name">Tax / Filing Window</div><span style="font-family:var(--mono);font-size:9px;color:var(--purple)">APR</span></div>
    </div>

    <div class="sb-section">
      <div class="sb-title">Enterprise</div>
      <div class="metric-row"><span class="metric-label">BNCA Brief</span><span class="metric-val" style="color:var(--blue)">READY</span></div>
      <div class="metric-row"><span class="metric-label">Capacity / Throughput</span><span class="metric-val" style="color:var(--teal)">+18%</span></div>
      <div class="metric-row"><span class="metric-label">Staff / Vendor ROI</span><span class="metric-val" style="color:var(--green)">LIVE</span></div>
      <div class="metric-row"><span class="metric-label">Report Memory</span><span class="metric-val" style="color:var(--purple)">ACTIVE</span></div>
    </div>

    <div class="sb-section">
      <div class="sb-title">System</div>
      <div class="sys-row"><span class="sys-label">UPLINK</span><span class="sys-val active">ACTIVE</span></div>
      <div class="sys-row"><span class="sys-label">NODES ONLINE</span><span class="sys-val live" id="nodes-count">11 / 11</span></div>
      <div class="sys-row"><span class="sys-label">AI CORE</span><span class="sys-val live">HEALTHCARE STRATEGIST</span></div>
      <div class="sys-row"><span class="sys-label">LAST BNCA</span><span class="sys-val ready" id="last-synth">—</span></div>
    </div>
  </div>

  <div class="center">
    <div class="deploy-bar">
      <div class="deploy-label">Deploy BNCA Query to Nodes</div>
      <div class="node-pills" id="node-pills"></div>
      <div class="query-row">
        <input class="query-input" id="main-query" value="Review claims pressure, prior auth delays, staffing throughput, compliance drift, and site-level operational blockers. Return the Best Next Course of Action for the office manager." placeholder="Enter query to deploy across nodes...">
        <button class="deploy-btn" id="deploy-btn" onclick="deployToNodes()">DEPLOY</button>
        <button class="synth-btn" id="synth-btn" onclick="synthesize()">SYNTHESIZE</button>
      </div>
      <div class="action-pills">
        <div class="action-pill" onclick="deployToNodes('Review claims pressure, denial exposure, and the best next office-manager actions for recovery.')">CLAIM RECOVERY</div>
        <div class="action-pill" onclick="deployToNodes('Analyze denial patterns, CPT / ICD friction, and identify the best next course of action for the office manager.')">DENIAL SWEEP</div>
        <div class="action-pill" onclick="deployToNodes('Review pending authorizations, turnaround delays, and recommend the best next office actions.')">PRIOR AUTH</div>
        <div class="action-pill" onclick="deployToNodes('Review staffing pressure, handoff delays, scheduling friction, and throughput blockers.')">STAFFING / THROUGHPUT</div>
        <div class="action-pill" onclick="saveCurrentReport()">SAVE REPORT</div>
        <div class="action-pill" onclick="synthesize()">BNCA SUMMARY</div>
      </div>
    </div>

    <div class="node-grid" id="node-grid"></div>

    <div class="ai-box">
      <div class="ai-hdr">REPORT STUDIO</div>
      <div class="report-grid">
        <div>
          <div class="ai-row">
            <input id="report-title" class="ai-inp" type="text" placeholder="Report title...">
            <input id="report-company" class="ai-inp" type="text" placeholder="System / company...">
          </div>
          <div class="ai-row">
            <button class="ask-btn" onclick="saveCurrentReport()">SAVE REPORT</button>
            <button class="ai-btn" onclick="exportCurrentReport()">EXPORT JSON</button>
            <button class="ai-btn" onclick="refreshReports()">REFRESH</button>
          </div>
          <div id="report-status" class="ai-res">> Report Studio ready.</div>
