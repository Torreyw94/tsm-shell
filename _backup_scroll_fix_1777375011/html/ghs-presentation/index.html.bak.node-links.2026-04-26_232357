<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>GHS Healthcare Command · Live Demo</title>
<style>
:root{--bg:#05080d;--panel:#07111b;--panel2:#0b1724;--line:#123050;--cyan:#00e0ff;--green:#00f59f;--gold:#ffb000;--red:#ff3b57;--text:#d9f3ff;--muted:#8fb0c8;--white:#f8f8f5}
*{box-sizing:border-box}
body{margin:0;background:radial-gradient(circle at top,#10233a 0,#05080d 42%,#000 100%);color:var(--text);font-family:Inter,system-ui,Arial;overflow:hidden}
.deck{height:100vh;display:flex;flex-direction:column}
.top{height:68px;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 24px;background:rgba(2,7,13,.92)}
.brand{font-weight:900;color:var(--cyan);letter-spacing:.16em}
.badge{border:1px solid var(--cyan);color:var(--cyan);border-radius:999px;padding:7px 12px;font:900 11px monospace}
.slides{flex:1;overflow:hidden;position:relative}
.slide{display:none;height:calc(100vh - 68px);overflow:auto;padding:42px 56px}
.slide.active{display:block}
h1{font-size:48px;letter-spacing:.02em;margin:0 0 18px}
h2{font-size:34px;color:var(--cyan);margin:0 0 18px}
p,li{font-size:19px;line-height:1.5;color:#bcd1e4}
.grid{display:grid;gap:16px}.g3{grid-template-columns:repeat(3,1fr)}.g4{grid-template-columns:repeat(4,1fr)}.g5{grid-template-columns:repeat(5,1fr)}
.card{background:linear-gradient(180deg,rgba(8,24,38,.96),rgba(3,10,16,.96));border:1px solid var(--line);border-radius:14px;padding:18px}
.card h3{color:var(--cyan);margin:0 0 10px;font-size:17px;letter-spacing:.08em}
.big{font-size:64px;color:var(--green);font-weight:900}
.nav{position:fixed;bottom:18px;right:24px;display:flex;gap:8px;z-index:50}
button{cursor:pointer}
.nav button,.btn{background:#00b7ff;color:#001018;border:0;border-radius:8px;padding:11px 14px;font:900 12px monospace;letter-spacing:.08em}
.btn.out{background:transparent;color:var(--cyan);border:1px solid var(--cyan)}
.btn.green{background:var(--green)}
.btn.gold{background:var(--gold)}
.progress{position:fixed;bottom:18px;left:24px;font:12px monospace;color:var(--muted)}
.doc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.doc{background:var(--white);color:#171717;border:2px solid #d0d0d0;border-radius:12px;padding:14px;min-height:190px}
.doc.active{background:#d9e8fb;border-color:#2f80ed}
.doc .icon{font-size:24px}.doc .k{color:#777;text-transform:uppercase;letter-spacing:.1em;font-size:12px}.doc .name{font-size:17px;margin:6px 0}.doc .pain{color:#6b4a13;font-size:13px;line-height:1.35}
.versions{display:flex;gap:6px;margin-top:12px}.versions button{background:#fff;border:1px solid #bbb;border-radius:9px;padding:8px 13px;font-size:16px}.versions button.sel{border-color:#2f80ed;background:#eef6ff}
.pipeline{display:grid;grid-template-columns:repeat(5,1fr);background:#fff;color:#111;border:2px solid #d8d8d8;border-radius:12px;overflow:hidden;margin:16px 0}
.stage{padding:16px;text-align:center;border-right:1px solid #d5d5d5}.stage:last-child{border-right:0}.stage.done{background:#e8f4dc;box-shadow:inset 0 0 0 2px #6c9d43}.stage .emoji{font-size:28px}.stage .title{font-size:15px;margin-top:6px}.stage .sub{font-size:13px;color:#555}.stage .status{margin-top:8px;color:#4a7d2d}
.preview{background:#fbfaf5;color:#222;border:2px solid #d7d7d2;border-radius:10px;padding:14px;font:13px/1.5 monospace;white-space:pre-wrap;max-height:190px;overflow:auto}
.output{background:#fff;color:#222;border:2px solid #6c9d43;border-radius:12px;padding:18px}
.node-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.node{background:#f2f0ea;border-left:4px solid #2f80ed;border-radius:9px;padding:12px;font-size:14px}.node b{color:#2f6fc1;display:block;margin-bottom:5px}
.bnca{background:#e8f4dc;border:2px solid #6c9d43;border-radius:10px;padding:14px;margin-top:12px;font-size:15px;line-height:1.4}
.letters{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.letter{background:#fff;color:#111;border:1px solid #ddd;border-radius:12px;padding:18px;white-space:pre-wrap;font:13px/1.5 Georgia,serif;max-height:360px;overflow:auto}
.checks{display:flex;gap:10px;flex-wrap:wrap;margin:12px 0}.checks label{font:13px monospace;background:#07111b;border:1px solid var(--line);border-radius:999px;padding:8px 10px;color:var(--text)}
select,textarea{width:100%;background:#02070d;color:#d9f3ff;border:1px solid var(--line);border-radius:8px;padding:10px;font:13px monospace}
@media(max-width:1000px){.doc-grid,.g3,.g4,.g5,.letters,.node-grid,.pipeline{grid-template-columns:1fr}.slide{padding:24px}.stage{border-right:0;border-bottom:1px solid #ddd}}
</style>




