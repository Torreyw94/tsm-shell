<body>
<div class="deck">
  <div class="top">
    <div><div class="brand">GHS HEALTHCARE COMMAND · LIVE EXECUTIVE DEMO</div><div style="font:11px monospace;color:var(--muted)">Document intelligence → HC Nodes → HC Strategist → Main Strategist → HITL Manager → Letters + Reports</div></div>
    <div class="badge">TSM NEURAL CORE · LIVE</div>
  </div>

  <div class="slides">
    <section class="slide active">
      <h1>Healthcare teams do not need another dashboard.</h1>
      <p>They need a command layer that turns healthcare documents into operational decisions, manager-ready reports, and professional follow-up letters.</p>
      <div class="grid g3">
        <div class="card"><h3>24 ready scenarios</h3><p>8 common healthcare document types × 3 quality levels.</p></div>
        <div class="card"><h3>Live coordination</h3><p>Each document runs through intake, HC nodes, HC Strategist, Main Strategist, and HITL.</p></div>
        <div class="card"><h3>Letter automation</h3><p>Prior auth letters, denial appeals, referral follow-ups, compliance memos, and executive briefs.</p></div>
      </div>
    </section>

    <section class="slide">
      <h2>What the client sees</h2>
      <div class="grid g5">
        <div class="card"><h3>1. Intake</h3><p>Document is parsed and classified.</p></div>
        <div class="card"><h3>2. HC Nodes</h3><p>Parallel clinical, coding, compliance, risk, and operations review.</p></div>
        <div class="card"><h3>3. HC Strategist</h3><p>Findings become BNCA.</p></div>
        <div class="card"><h3>4. Main Strategist</h3><p>Executive priority and risk view.</p></div>
        <div class="card"><h3>5. HITL</h3><p>Manager reviews, approves, and acts.</p></div>
      </div>
    </section>

    <section class="slide" id="live-run-slide">
      <h2>Live Coordination Run — Choose any document</h2>
      <div class="doc-grid" id="library"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px">
        <div>
          <div class="preview" id="preview">Select a document.</div>
          <div class="checks">
            <label><input type="checkbox" checked value="prior"> Prior Auth Letter</label>
            <label><input type="checkbox" checked value="appeal"> Denial Appeal</label>
            <label><input type="checkbox" checked value="referral"> Referral Follow-up</label>
            <label><input type="checkbox" checked value="compliance"> Compliance Memo</label>
            <label><input type="checkbox" checked value="brief"> Executive Brief</label>
          </div>
          <button class="btn green" onclick="runPipeline()">RUN SELECTED DOCUMENT</button>
          <button class="btn out" onclick="runAll24()">RUN ALL 24 SCENARIOS</button>
          <button class="btn gold" onclick="oneClickDemoMode()">ONE-CLICK DEMO MODE</button>
          <button class="btn out" onclick="sendRelay()">SEND TO HC STRATEGIST RELAY</button>
          <button class="btn out" onclick="synthesize()">PUSH TO MAIN STRATEGIST</button>
<div id="strategyRedirects" style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap">
  <button onclick="openHCStrategist()" style="background:#001018;border:1px solid #00e0ff;color:#00e0ff;padding:10px 14px;border-radius:8px;font-weight:700">
    OPEN HC STRATEGIST
  </button>

  <button onclick="openMainStrategist()" style="background:#001018;border:1px solid #00f59f;color:#00f59f;padding:10px 14px;border-radius:8px;font-weight:700">
    OPEN MAIN STRATEGIST
  </button>

  <label style="display:flex;align-items:center;gap:6px;font-size:11px;margin-left:10px">
    <input type="checkbox" id="autoRedirectToggle">
    AUTO REDIRECT
  </label>
</div>

<script>
function openHCStrategist(){
  window.open('/html/hc-strategist/index.html?v=live-demo','_blank');
}

function openMainStrategist(){
  window.open('/html/main-strategist/index.html?v=live-demo','_blank');
}

// wrap existing push functions
const oldSend = window.sendToHCStrategist || function(){};
window.sendToHCStrategist = async function(){
  await oldSend();
  if(document.getElementById('autoRedirectToggle')?.checked){
    setTimeout(()=>openHCStrategist(), 600);
  }
}

const oldPush = window.pushToMainStrategist || function(){};
window.pushToMainStrategist = async function(){
  await oldPush();
  if(document.getElementById('autoRedirectToggle')?.checked){
    setTimeout(()=>openMainStrategist(), 800);
  }
}
</script>
</button>
        </div>
        <div>
          <div class="pipeline">
            <div class="stage" id="st0"><div class="emoji">📄</div><div class="title">Document Intake</div><div class="sub">Upload & parse</div><div class="status">—</div></div>
            <div class="stage" id="st1"><div class="emoji">🔬</div><div class="title">HC-Nodes</div><div class="sub">Parallel analysis</div><div class="status">—</div></div>
            <div class="stage" id="st2"><div class="emoji">🧠</div><div class="title">HC-Strategist</div><div class="sub">BNCA synthesis</div><div class="status">—</div></div>
            <div class="stage" id="st3"><div class="emoji">📊</div><div class="title">Main Strategist</div><div class="sub">Priority & risk</div><div class="status">—</div></div>
            <div class="stage" id="st4"><div class="emoji">👤</div><div class="title">HITL Manager</div><div class="sub">Final approval</div><div class="status">—</div></div>
          </div>
          <div class="output" id="output"><h3>BNCA Output</h3><p>Run a document to see findings.</p></div>
        </div>
      </div>
    </section>

    <section class="slide">
      <h2>Generated follow-up documents</h2>
      <p>Clients can choose which documents they want produced after analysis.</p>
      <div class="letters" id="letters"></div>
    </section>

    <section class="slide">
      <h2>Executive close</h2>
      <div class="grid g3">
        <div class="card"><h3>CFO</h3><p>Reduces denial leakage, rework, and delayed revenue by turning findings into ready-to-send documents.</p></div>
        <div class="card"><h3>COO</h3><p>Shows exactly where work is stuck, who owns it, and what action happens next.</p></div>
        <div class="card"><h3>Compliance</h3><p>Keeps HITL approval, audit trails, correction memos, and standardized documentation.</p></div>
      </div>
      <p style="font-size:26px;color:var(--green);margin-top:32px">“The value is not just finding the issue. The value is producing the next action while the team is still in the workflow.”</p>
    </section>
  </div>
</div>

<div class="progress" id="progress">1 / 5</div>
<div class="nav">
  <button onclick="prevSlide()">← PREV</button>
  <button onclick="nextSlide()">NEXT →</button>
</div>

<script>
const docs=[
 {id:'prior',icon:'🔐',k:'Prior Auth',name:'Prior Auth',pain:'Manual review bottlenecks, 72hr avg delay'},
 {id:'discharge',icon:'🏥',k:'Discharge Summary',name:'Discharge Summary',pain:'Missing follow-up orders, readmission risk flags missed'},
 {id:'denial',icon:'❌',k:'Claim Denial',name:'Claim Denial',pain:'Low appeal success, missed deadlines, lost revenue'},
 {id:'referral',icon:'↗',k:'Referral Order',name:'Referral Order',pain:'Incomplete clinical context delays specialist acceptance'},
 {id:'medrec',icon:'💊',k:'Medication Reconciliation',name:'Medication Reconciliation',pain:'Discrepancies across transitions cause adverse events'},
 {id:'adt',icon:'🔔',k:'ADT Notification',name:'ADT Notification',pain:'Delayed care coordination, missed payer notifications'},
 {id:'consent',icon:'✍️',k:'Consent Form',name:'Consent Form',pain:'Missing signatures, undocumented capacity assessments'},
 {id:'clinical',icon:'📝',k:'Clinical Note',name:'Clinical Note',pain:'Vague documentation, missing HPI elements, billing risk'}
];

const versions={
 prior:{
  v1:`PRIOR AUTH REQUEST
Patient: Johnson, M.
Service: MRI Lumbar Spine
Problem: back pain
Missing: conservative therapy, neuro findings, duration, payer criteria.
Status: HOLD — insufficient medical necessity.`,
  v2:`PRIOR AUTH REQUEST
Patient: Johnson, M.
Service: MRI Lumbar Spine
6 weeks PT mentioned but no dates. Radicular pain noted. NSAID trial unclear.
Status: PARTIAL — request clarification.`,
  v3:`PRIOR AUTH REQUEST
Patient: Johnson, M.
Service: MRI Lumbar Spine
6 weeks PT failed, NSAIDs failed, worsening radicular pain, positive straight-leg raise, functional decline.
Status: APPROVE & SUBMIT.`
 },
 denial:{
  v1:`CLAIM DENIAL NOTICE
Claim #: BCB-2025-04-99231
Amount: $12,400
Denial: CO-97 duplicate claim
Missing: original claim status, remit, appeal deadline.
Status: HOLD.`,
  v2:`CLAIM DENIAL NOTICE
Claim #: BCB-2025-04-99231
Original may have paid at lower rate. Appeal deadline 05/10/2025. Need remit.
Status: REVIEW.`,
  v3:`CLAIM DENIAL NOTICE
Claim #: BCB-2025-04-99231
DOS: 03/15/2025  Patient: Martinez, J.
Amount: $12,400  Procedure: 27447
Denial: CO-97 — previously paid at claim BCB-99100
Resolution: Verify BCB-99100 payment; if underpaid, appeal with remit
Appeal deadline: 05/10/2025
Required: Clinical notes + original remit + corrected claim
Contact: BlueCross Provider Relations 1-800-555-0192`
 }
};

['discharge','referral','medrec','adt','consent','clinical'].forEach(id=>{
 const d=docs.find(x=>x.id===id);
 versions[id]={
  v1:`${d.name.toUpperCase()}
Incomplete record. Missing required fields, owner lane, and documentation needed for downstream action.
Status: HOLD — correction required.`,
  v2:`${d.name.toUpperCase()}
Partial record. Some required documentation present, but missing context creates delay, compliance exposure, or payer/provider friction.
Status: PARTIAL — clarify and resubmit.`,
  v3:`${d.name.toUpperCase()}
Complete record. Required documentation, owner lane, timeline, and action path are present.
Status: ACTIONABLE — proceed with workflow.`
 };
});

let selected={id:'denial',v:'v3'}, currentBNCA='';

function renderLib(){
 library.innerHTML=docs.map(d=>`
 <div class="doc ${selected.id===d.id?'active':''}" onclick="selectDoc('${d.id}','${selected.id===d.id?selected.v:'v1'}')">
  <div class="icon">${d.icon}</div><div class="k">${d.k}</div><div class="name">${d.name}</div><div class="pain">${d.pain}</div>
  <div class="versions">${['v1','v2','v3'].map(v=>`<button class="${selected.id===d.id&&selected.v===v?'sel':''}" onclick="event.stopPropagation();selectDoc('${d.id}','${v}')">${v}</button>`).join('')}</div>
 </div>`).join('');
 updatePreview();
}
function selectDoc(id,v){selected={id,v};renderLib()}
function doc(){return docs.find(x=>x.id===selected.id)}
function text(){return versions[selected.id][selected.v]}
function quality(){return selected.v==='v3'?'complete':selected.v==='v2'?'partial':'incomplete'}
function updatePreview(){preview.textContent=`${doc().icon} ${doc().name.toUpperCase()} — ${selected.v.toUpperCase()} — ${quality().toUpperCase()}\n\n${text()}`}

function resetStages(){[0,1,2,3,4].forEach(i=>{let e=document.getElementById('st'+i);e.classList.remove('done');e.querySelector('.status').textContent='—'})}
function stage(i,t){let e=document.getElementById('st'+i);e.classList.add('done');e.querySelector('.status').textContent=t+' ✓'}
const wait=ms=>new Promise(r=>setTimeout(r,ms));

async function runPipeline(){
 resetStages();
 output.innerHTML='<h3>BNCA Output</h3><p>Running through command pipeline...</p>';
 stage(0,'Parsed'); await wait(250);
 stage(1,'11-node review'); await wait(250);
 stage(2,'BNCA ready'); await wait(250);
 stage(3,'Prioritized'); await wait(250);
 stage(4,'HITL action');

 const b=makeBNCA();
 currentBNCA=b.action+'\n\n'+b.hitl;
 output.innerHTML=`
 <h3>BNCA Output · ${doc().name} ${selected.v.toUpperCase()}</h3>
 <div class="node-grid">
  <div class="node"><b>CLINICAL NODE</b>${b.clinical}</div>
  <div class="node"><b>CODING / BILLING NODE</b>${b.coding}</div>
  <div class="node"><b>COMPLIANCE NODE</b>${b.compliance}</div>
  <div class="node"><b>RISK / OPERATIONS NODE</b>${b.risk}</div>
 </div>
 <div class="bnca"><b>HC-STRATEGIST → MAIN STRATEGIST: BEST NEXT COURSE OF ACTION</b><br>${b.action}</div>
 <div class="bnca"><b>HITL MANAGER ACTION</b><br>${b.hitl}</div>`;
 generateLetters();
 await sendRelay(false);
}

function makeBNCA(){
 const q=quality(), d=doc();
 if(q==='complete') return {
  clinical:'Clinical context is complete enough to support downstream action.',
  coding:'Coding, claim, authorization, or documentation requirements are sufficiently supported.',
  compliance:'Required documentation elements are present and audit trail can be preserved.',
  risk:'Low risk. Workflow is ready for manager approval and execution.',
  action:`APPROVE / EXECUTE — ${d.name} ${selected.v.toUpperCase()} is complete. Proceed with the appropriate letter, submission, referral, appeal, or compliance record.`,
  hitl:'Manager approves execution, confirms owner lane, and tracks outcome in the operating record.'
 };
 if(q==='partial') return {
  clinical:'Clinical context is present but not strong enough for confident submission.',
  coding:'Some required fields exist, but ambiguity may cause payer/provider delay.',
  compliance:'Documentation gap creates moderate review and audit risk.',
  risk:'Moderate risk. Proceed only after correction owner resolves missing items.',
  action:`HOLD / RETURN FOR CORRECTION — ${d.name} ${selected.v.toUpperCase()} is partial. Request missing documentation before submission and route corrected file back through HC nodes.`,
  hitl:'Assign owner lane, request missing fields, set due date, and do not submit until corrected.'
 };
 return {
  clinical:'Clinical documentation is too weak for action.',
  coding:'Required coding/submission support is missing.',
  compliance:'High documentation risk if acted on without correction.',
  risk:'High risk. Submission may create denial, delay, compliance exposure, or patient coordination failure.',
  action:`DO NOT SUBMIT — ${d.name} ${selected.v.toUpperCase()} is incomplete. Return to source team with required correction checklist.`,
  hitl:'Manager blocks downstream action and assigns same-day remediation.'
 };
}

function wanted(){return [...document.querySelectorAll('.checks input:checked')].map(x=>x.value)}
function generateLetters(){
 const lettersOut=[];
 const w=wanted(), d=doc(), q=quality(), body=text();
 if(w.includes('prior')) lettersOut.push(['Prior Authorization Letter',priorLetter(d,q,body)]);
 if(w.includes('appeal')) lettersOut.push(['Denial Appeal Letter',appealLetter(d,q,body)]);
 if(w.includes('referral')) lettersOut.push(['Referral Follow-up Letter',referralLetter(d,q,body)]);
 if(w.includes('compliance')) lettersOut.push(['Compliance Documentation Memo',complianceMemo(d,q,body)]);
 if(w.includes('brief')) lettersOut.push(['Executive Manager Brief',execBrief(d,q,body)]);
 letters.innerHTML=lettersOut.map(x=>`<pre class="letter"><b>${x[0]}</b>\n\n${x[1]}</pre>`).join('');
}

function priorLetter(d,q,body){
return `RE: Prior Authorization Support / ${d.name}

To Utilization Review:

Please review the enclosed clinical documentation for authorization consideration.

Document Reviewed:
${body}

Medical Necessity Position:
${q==='complete'?'The record supports authorization. Required clinical indicators and supporting documentation are present.':'The record currently requires correction before payer submission. Missing details should be resolved to avoid preventable delay or denial.'}

Requested Action:
${q==='complete'?'Approve and process the requested service based on documented need.':'Return to provider team for missing documentation, then resubmit with complete clinical support.'}

Recommended Attachments:
• Provider order
• Current clinical note / HPI
• Failed conservative treatment history
• Relevant diagnostics
• Medication and therapy history
• Payer-specific checklist

Best Next Course of Action:
${currentBNCA}`;
}

function appealLetter(d,q,body){
return `RE: Appeal / Reconsideration Request

To Claims Review:

We are submitting this appeal/reconsideration request based on the documentation below.

Claim / Case Summary:
${body}

Appeal Basis:
${q==='complete'?'The documentation supports appeal execution. The record includes enough context to challenge the denial, verify payment history, and submit corrected supporting documentation.':'The appeal packet is not yet complete. Missing remit, deadline, clinical support, or correction data must be resolved before appeal submission.'}

Requested Action:
${q==='complete'?'Reverse or adjust the denial and reprocess the claim according to the corrected documentation.':'Hold appeal submission until missing elements are attached and reviewed.'}

Recommended Attachments:
• Original claim
• Remittance advice / EOB
• Corrected claim if required
• Clinical notes
• Medical necessity support
• Denial notice
• Timely filing evidence

Best Next Course of Action:
${currentBNCA}`;
}

function referralLetter(d,q,body){
return `RE: Referral Coordination Request

To Receiving Specialist / Referral Team:

Please review this referral packet and confirm acceptance or identify any missing documentation required for scheduling.

Referral Summary:
${body}

Coordination Position:
${q==='complete'?'The referral contains the clinical context, urgency, and supporting documentation needed for specialist review.':'The referral requires additional clinical context or attachments before specialist acceptance is likely.'}

Requested Action:
${q==='complete'?'Accept and schedule the patient, or confirm next available appointment window.':'Return required missing items so the referring team can complete the packet.'}

Recommended Attachments:
• Diagnosis and reason for referral
• Recent clinical note
• Imaging/lab results
• Medication list
• Urgency level
• Patient contact details

Best Next Course of Action:
${currentBNCA}`;
}

function complianceMemo(d,q,body){
return `COMPLIANCE DOCUMENTATION MEMO

Subject: ${d.name} Documentation Review

Issue Reviewed:
${body}

Compliance Finding:
${q==='complete'?'Documentation is sufficient for workflow continuation with audit trail retained.':'Documentation should not move downstream until required elements are corrected and manager approval is logged.'}

Risk:
Incomplete records can create billing, payer, consent, clinical quality, or audit exposure.

Corrective Action:
• Identify missing elements
• Assign correction owner
• Set correction deadline
• Attach supporting documentation
• Preserve manager approval trail
• Re-run through HC nodes after correction

Best Next Course of Action:
${currentBNCA}`;
}

function execBrief(d,q,body){
return `EXECUTIVE MANAGER BRIEF

Document:
${d.name} / ${selected.v.toUpperCase()} / ${q.toUpperCase()}

Operational Signal:
${d.pain}

Current Finding:
${body}

Manager Decision:
${q==='complete'?'Ready for execution with HITL approval.':'Not ready for downstream action. Assign owner lane and correction deadline.'}

Business Value:
The system converts document review into a decision, manager action, and professional follow-up document in the same workflow.

Recommended Next Step:
${currentBNCA}`;
