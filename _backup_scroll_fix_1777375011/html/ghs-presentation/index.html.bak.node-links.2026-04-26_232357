async function sendRelay(show=true){
 if(!currentBNCA) return;
 await fetch('/api/hc/node-report',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({
  nodeKey:'ghs-document-pipeline',
  node:'GHS Document Pipeline',
  bnca:currentBNCA,
  metrics:{document:doc().name,version:selected.v,quality:quality(),letters:wanted()},
  source:'ghs-presentation-live-run',
  ts:new Date().toISOString()
 })});
 if(show) alert('Sent to HC Strategist relay.');
}
async function synthesize(){
 const r=await fetch('/api/hc/strategist/synthesize',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({system:'General Healthcare',source:'ghs-presentation-live-run'})});
 const data=await r.json();
 alert('Main Strategist updated. Nodes reporting: '+(data.mainStrategist?.nodeCount||'—'));
}
async function runAll24(){
 for(const d of docs){for(const v of ['v1','v2','v3']){selected={id:d.id,v};renderLib();await runPipeline();}}
 await synthesize();
 alert('All 24 scenarios processed and pushed through the command chain.');
}

let idx=0;const slides=[...document.querySelectorAll('.slide')];
function show(i){idx=Math.max(0,Math.min(slides.length-1,i));slides.forEach(s=>s.classList.remove('active'));slides[idx].classList.add('active');progress.textContent=(idx+1)+' / '+slides.length}
function nextSlide(){show(idx+1)}function prevSlide(){show(idx-1)}
document.addEventListener('keydown',e=>{if(e.key==='ArrowRight')nextSlide();if(e.key==='ArrowLeft')prevSlide()});
renderLib();runPipeline();
</script>

<script id="real-letters-node-findings">
(function(){
  function activeDocName(){
    try { return doc().name; } catch(e){ return "Healthcare Document"; }
  }
  function activeQuality(){
    try { return quality(); } catch(e){ return "partial"; }
  }
  function activeBody(){
    try { return text(); } catch(e){ return ""; }
  }

  window.makeNodeFindings = function(){
    const d = activeDocName();
    const q = activeQuality();
    const body = activeBody();

    const complete = q === "complete";
    const partial = q === "partial";

    return {
      clinical: complete
        ? `Clinical review supports action. ${d} includes sufficient care context, patient identifiers, urgency, and supporting documentation.`
        : partial
          ? `Clinical review found usable context, but missing or conflicting elements require provider clarification before action.`
          : `Clinical review cannot support action. Required clinical context is missing or too vague.`,

      coding: complete
        ? `Coding / billing review supports downstream submission. Required codes, dates, payer context, and record linkage are adequate.`
        : partial
          ? `Coding / billing review found conflict risk. Missing claim lineage, code support, modifier detail, or authorization fields may trigger denial/rework.`
          : `Coding / billing review blocks submission. Required identifiers, codes, or payer fields are absent.`,

      compliance: complete
        ? `Compliance review supports controlled execution with HITL approval and audit trail retained.`
        : partial
          ? `Compliance review requires correction owner, deadline, and manager approval before submission.`
          : `Compliance review blocks action. Proceeding may create audit, consent, payer, or patient safety exposure.`,

      risk: complete
        ? `Risk level: LOW. Recommended path is execute, submit, appeal, route, or close workflow.`
        : partial
          ? `Risk level: MODERATE. Hold for correction to prevent denial, delay, or avoidable escalation.`
          : `Risk level: HIGH. Stop downstream action and route back to source team immediately.`,

      sourceText: body
    };
  };

  window.makeProfessionalLetters = function(){
    const d = activeDocName();
    const q = activeQuality();
    const body = activeBody();
    const b = currentBNCA || "Pending BNCA generation.";
    const complete = q === "complete";

    return {
      prior: `PRIOR AUTHORIZATION SUPPORT LETTER

RE: Authorization Review Support

To Utilization Review Team,

Please review the enclosed documentation for authorization consideration.

Document Type:
${d}

Record Summary:
${body}

Medical Necessity / Review Position:
${complete
? "The available documentation supports authorization review. The record contains sufficient clinical context, care rationale, and supporting details for payer submission."
: "The current documentation is not yet ready for payer submission. Missing or conflicting elements should be corrected before authorization is submitted to reduce preventable denial risk."}

Requested Action:
${complete
? "Please approve and process the requested service based on the enclosed clinical support."
: "Please hold submission internally until the provider team supplies the missing documentation, then resubmit with a complete authorization packet."}

Recommended Attachments:
• Provider order
• Current clinical note / HPI
• Diagnosis and service request
• Conservative therapy history, when applicable
• Medication history, when applicable
• Imaging, labs, or supporting diagnostics
• Payer-specific checklist

Best Next Course of Action:
${b}

Respectfully,
GHS Healthcare Command
Manager Review Required`,

      appeal: `DENIAL APPEAL / RECONSIDERATION LETTER

RE: Appeal / Reconsideration Request

To Claims Review Department,

We are submitting this appeal or reconsideration request based on the documentation reviewed by the GHS Healthcare Command workflow.

Document Type:
${d}

Case Summary:
${body}

Appeal Position:
${complete
? "The record supports appeal execution. The documentation includes sufficient claim context, denial rationale, and supporting information to proceed with an appeal or corrected claim workflow."
: "The appeal packet is not yet complete. Missing claim lineage, remittance data, payer rationale, clinical support, or deadline details must be resolved before submission."}

Requested Action:
${complete
? "Please reverse, adjust, or reprocess the denial based on the attached documentation and corrected support."
: "Please hold appeal submission internally until the missing elements are corrected and reviewed by the responsible owner lane."}

Recommended Attachments:
• Original claim
• Denial notice
• Remittance advice / EOB
• Corrected claim, if required
• Clinical documentation
• Medical necessity support
• Timely filing evidence
• Manager approval note

Best Next Course of Action:
${b}

Respectfully,
GHS Healthcare Command
Revenue Cycle / HITL Manager Review`,

      referral: `REFERRAL FOLLOW-UP LETTER

RE: Referral Coordination Request

To Receiving Specialist / Referral Coordination Team,

Please review this referral packet and confirm whether the patient can be accepted and scheduled, or identify any missing documentation required for acceptance.

Document Type:
${d}

Referral / Case Summary:
${body}

Coordination Position:
${complete
? "The referral appears ready for specialist review. Required clinical context, urgency, and supporting documentation are present."
: "The referral requires additional clinical context or attachments before specialist acceptance is likely. Missing information should be corrected to avoid scheduling delay."}

Requested Action:
${complete
? "Please accept the referral, confirm scheduling availability, and notify the referring team of the appointment pathway."
: "Please identify the missing items needed to complete the referral packet so the referring team can correct and resubmit."}

Recommended Attachments:
• Diagnosis and reason for referral
• Most recent clinical note
• Relevant imaging or lab results
• Medication list
• Urgency level
• Patient contact details
• Insurance / authorization details, if required

Best Next Course of Action:
${b}

Respectfully,
GHS Healthcare Command
Referral Coordination Review`,

      compliance: `COMPLIANCE DOCUMENTATION MEMO

Subject: Documentation Review and Corrective Action Memo

Document Type:
${d}

Issue Reviewed:
${body}

Compliance Finding:
${complete
? "Documentation is sufficient for workflow continuation. Required support is present and manager approval can be retained as part of the audit trail."
: "Documentation should not move downstream until required elements are corrected. The current record may create billing, payer, consent, clinical quality, or audit exposure."}

Corrective Action Requirements:
• Identify missing or conflicting elements
• Assign a correction owner
• Set correction deadline
• Attach supporting documentation
• Preserve manager approval trail
• Re-run through HC nodes after correction
• Document final approval before submission or closeout

Best Next Course of Action:
${b}

Prepared For:
HITL Manager / Compliance Review

Prepared By:
GHS Healthcare Command`,

      brief: `EXECUTIVE MANAGER BRIEF

Document:
${d}

Version / Quality:
${q.toUpperCase()}

Operational Signal:
${body}

Manager Decision:
${complete
? "Ready for execution with HITL approval."
: "Not ready for downstream action. Assign owner lane, correction deadline, and re-run after documentation is complete."}

Business Value:
The system converts document review into a decision, manager action, and professional follow-up document in the same workflow. This reduces manual drafting, avoids avoidable denials, improves response speed, and preserves manager accountability.

Recommended Next Step:
${b}

Manager Action:
Review recommendation, approve or hold execution, assign accountable owner, and track outcome in the operating record.`
    };
  };

  const oldGenerateLetters = window.generateLetters;
  window.generateLetters = function(){
    const selectedTypes = typeof wanted === "function"
      ? wanted()
      : ["prior","appeal","referral","compliance","brief"];

    const L = makeProfessionalLetters();
    const labels = {
      prior:"Prior Authorization Support Letter",
      appeal:"Denial Appeal / Reconsideration Letter",
      referral:"Referral Follow-up Letter",
      compliance:"Compliance Documentation Memo",
      brief:"Executive Manager Brief"
    };

    const container = document.getElementById("letters");
    if(!container) return;

    container.innerHTML = selectedTypes.map(k => `
      <pre class="letter"><b>${labels[k] || k}</b>

${L[k] || ""}</pre>
    `).join("");
  };

  const oldMakeBNCA = window.makeBNCA;
  window.makeBNCA = function(){
    const q = activeQuality();
    const d = activeDocName();
    const f = makeNodeFindings();

    if(q === "complete"){
      return {
        clinical:f.clinical,
        coding:f.coding,
        compliance:f.compliance,
        risk:f.risk,
        action:`APPROVE / EXECUTE — ${d} is complete. Proceed with the appropriate submission, appeal, referral, compliance record, or executive report. Generate the selected follow-up documents and preserve HITL approval.`,
        hitl:"Manager approves execution, confirms owner lane, tracks outcome, and retains the generated letter/report in the operating record."
      };
    }

    if(q === "partial"){
      return {
        clinical:f.clinical,
        coding:f.coding,
        compliance:f.compliance,
        risk:f.risk,
        action:`HOLD / RETURN FOR CORRECTION — ${d} is partial or conflicting. Request missing documentation, assign an owner lane, set a due date, and re-run through HC nodes before payer/provider submission.`,
        hitl:"Manager assigns correction owner, blocks downstream submission, confirms missing elements, and re-runs the corrected packet."
      };
    }

    return {
      clinical:f.clinical,
      coding:f.coding,
      compliance:f.compliance,
      risk:f.risk,
      action:`DO NOT SUBMIT — ${d} is incomplete. Stop downstream action and return to the source team with a correction checklist.`,
      hitl:"Manager blocks the workflow, assigns same-day remediation, and requires corrected documentation before any external action."
    };
  };

})();
</script>





