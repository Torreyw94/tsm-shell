<!DOCTYPE html>
<html lang="en">
<head>




<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TSMatter · Operations Portal</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#080c0a;--bg2:#0d120f;--bg3:#111810;--bg4:#161e15;--border:rgba(0,255,100,0.08);--border2:rgba(0,255,100,0.15);--border3:rgba(0,255,100,0.25);--g:#00ff64;--g2:#00cc50;--g3:#008f38;--gdim:rgba(0,255,100,0.12);--gold:#f0c040;--golddim:rgba(240,192,64,0.12);--red:#ff4455;--reddim:rgba(255,68,85,0.12);--amber:#ffaa00;--amberdim:rgba(255,170,0,0.12);--blue:#00aaff;--bluedim:rgba(0,170,255,0.1);--text:#c8e8c8;--text2:#6a8a6a;--text3:#3a5a3a}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;height:100vh;overflow:hidden;display:flex;flex-direction:column}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px);pointer-events:none;z-index:9999}
.topbar{height:44px;background:var(--bg2);border-bottom:1px solid var(--border2);display:flex;align-items:center;padding:0 16px;gap:0;flex-shrink:0}
.tb-brand{display:flex;align-items:center;gap:10px;margin-right:24px}
.tb-logo{width:28px;height:28px;border:1px solid var(--g3);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--g)}
.tb-client{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--text)}
.tb-client span{color:var(--g)}
.tb-sep{width:1px;height:20px;background:var(--border2);margin:0 16px}
.tb-stat{display:flex;align-items:center;gap:6px;padding:4px 10px;font-size:10px;letter-spacing:.08em;color:var(--text2);margin-right:4px}
.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;display:inline-block}
.dg{background:var(--g);box-shadow:0 0 6px var(--g)}.dr{background:var(--red);box-shadow:0 0 6px var(--red)}.da{background:var(--amber);box-shadow:0 0 4px var(--amber)}.db{background:var(--blue)}
.ticker-wrap{flex:1;overflow:hidden;height:100%;display:flex;align-items:center}
.ticker{white-space:nowrap;font-size:10px;color:var(--text3);letter-spacing:.05em;animation:ticker 55s linear infinite}
@keyframes ticker{from{transform:translateX(100%)}to{transform:translateX(-200%)}}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.tb-time{font-size:11px;color:var(--text2);letter-spacing:.06em}
.tb-user{display:flex;align-items:center;gap:8px;padding:4px 10px;border:1px solid var(--border);border-radius:3px}
.tb-av{width:22px;height:22px;border-radius:50%;background:var(--gdim);border:1px solid var(--g3);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--g);font-weight:700}
.tb-un{font-size:11px;color:var(--text)}.tb-ur{font-size:9px;color:var(--text2);margin-top:1px}
.ai-bar{height:22px;background:rgba(0,255,100,0.03);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:20px;flex-shrink:0}
.ai-bar-item{font-size:9px;color:var(--text3);letter-spacing:.08em;display:flex;align-items:center;gap:5px}
.main{display:flex;flex:1;overflow:hidden}
.leftnav{width:220px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
.nav-srch{padding:10px 12px;border-bottom:1px solid var(--border)}
.nav-srch input{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:3px;padding:6px 10px;font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text);outline:none}
.nav-srch input::placeholder{color:var(--text3)}
.nav-srch input:focus{border-color:var(--g3)}
.nav-scroll{overflow-y:auto;flex:1}
