let ttCur=0, ttAud='agent';

function setTTAud(key, el){
  ttAud=key; ttCur=0;
  document.querySelectorAll('.aud-btn').forEach(b=>b.classList.remove('active'));
  if(el) el.classList.add('active');
  ttRender();
}

function ttRender(){
  const steps = TT_TRACKS[ttAud];
  const step = steps[ttCur];
  document.getElementById('tt-pips').innerHTML = steps.map((_,i)=>
    '<div class="tt-pip'+(i<ttCur?' done':i===ttCur?' active':'')+'"></div>'
  ).join('');
  let h='<div class="tt-step-label">'+step.label+'</div>';
  h+='<div class="tt-step-title">'+step.title+'</div>';
  if(step.action) h+='<div class="tt-action">&#9658; '+step.action+'</div>';
  step.say.forEach(line=>{h+='<div class="tt-say"><p>'+line+'</p></div>';});
  if(step.objections){
    step.objections.forEach((o,i)=>{
      h+='<div class="tt-obj"><div class="tt-obj-q" onclick="ttObj('+i+')"><span>'+o.q+'</span><span id="ttchev'+i+'">&#9662;</span></div>';
      h+='<div class="tt-obj-a" id="ttoa'+i+'">Say: '+o.a+'</div></div>';
    });
  }
  if(step.tip) h+='<div class="tt-tip">&#8627; '+step.tip+'</div>';
  document.getElementById('tt-card').innerHTML=h;
  document.getElementById('tt-counter').textContent=(ttCur+1)+' / '+steps.length;
  document.getElementById('tt-back').style.visibility=ttCur===0?'hidden':'visible';
  document.getElementById('tt-next').textContent=ttCur===steps.length-1?'restart':'next →';
}

function ttGo(d){
  const steps=TT_TRACKS[ttAud];
  if(d===1&&ttCur===steps.length-1){ttCur=0;}
  else ttCur=Math.max(0,Math.min(steps.length-1,ttCur+d));
  ttRender();
}
function ttObj(i){document.getElementById('ttoa'+i).classList.toggle('open');}

ttRender();
