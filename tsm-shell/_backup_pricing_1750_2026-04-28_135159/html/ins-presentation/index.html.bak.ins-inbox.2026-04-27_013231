// ── SIM ENGINE ───────────────────────────────────────────────────────────────
function ts(){return new Date().toLocaleTimeString('en-US',{hour12:false})}
function slog(msg,cls=''){
  const el=document.getElementById('simlog');
  const d=document.createElement('div');
  d.className='ll';
  d.innerHTML=`<span class="lt">${ts()}</span><span class="${cls}">${msg}</span>`;
  el.appendChild(d);el.scrollTop=el.scrollHeight;
}
function fstep(i,s){
  const n=document.getElementById('fn'+i),l=document.getElementById('fl'+i),c=document.getElementById('fc'+i);
  n.className='fnode'+(s==='done'?' done':s==='go'?' go':'');
  if(l) l.className='flabel'+(s==='done'?' done':'');
  if(c&&s==='done') c.className='fconn done';
}
function spanel(id,s){
  document.getElementById('p-'+id).className='sim-panel'+(s==='active'?' active-panel':s==='firing'?' firing-panel':'');
  document.getElementById('pd-'+id).className='pdot'+(s==='live'?' live':s==='firing'?' firing':'');
}
function sout(id,h){document.getElementById('po-'+id).innerHTML=h;}
function delay(ms){return new Promise(r=>setTimeout(r,ms));}

async function runSim(){
  if(running)return;
  running=true;
  document.getElementById('runbtn').disabled=true;
  document.getElementById('simstatus').textContent='running...';
  document.getElementById('simlog').innerHTML='';
  const sc = AUD_SCENARIOS[currentAudKey];

  // Step 1 — intake
  fstep(0,'go');
  slog('TSM Insurance Intelligence: query received · '+sc.label+'...');
  await delay(800);
  fstep(0,'done');
  slog('Client profile parsed · routing to 4 nodes in parallel','lok');
  document.getElementById('fc0').className='fconn done';

  // Step 2 — compliance node
  await delay(400);fstep(1,'go');spanel('compliance','firing');
  document.getElementById('compliance-route').textContent = sc.compliance.route;
  slog('Compliance Node: firing · '+sc.compliance.route+'...');
  await delay(1000);
  fstep(1,'done');spanel('compliance','active');
  sout('compliance', sc.compliance.result);
  slog('Compliance Node: complete','lok');
  document.getElementById('fc1').className='fconn done';

  // Step 3 — coverage + claims in parallel
  await delay(300);fstep(2,'go');
  spanel('coverage','firing');spanel('claims','firing');
  document.getElementById('coverage-route').textContent = sc.coverage.route;
  document.getElementById('claims-route').textContent = sc.claims.route;
  slog('Coverage Node + Claims Node: firing in parallel...');
  await delay(1100);
  spanel('coverage','active');spanel('claims','active');
  sout('coverage', sc.coverage.result);
  sout('claims', sc.claims.result);
  fstep(2,'done');
  slog('Coverage + Claims nodes: complete','lok');
  document.getElementById('fc2').className='fconn done';

  // Step 4 — strategist
  await delay(400);fstep(3,'go');spanel('bnca','firing');
  slog('Insurance Strategist: synthesizing 3 node findings into BNCA...');
  try {
    const r = await fetch(BASE+'/api/hc/ask',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        query: sc.query,
        system:'TSM Insurance Intelligence',
        location:'Arizona'
      })
    });
    const d = await r.json();
    const txt = d?.answer||d?.response||d?.result||null;
    fstep(3,'done');spanel('bnca','active');
    if(txt){
      sout('bnca',`<div class="pv">⚡ BNCA · ${sc.label}</div><div class="pg">${txt.slice(0,280)}${txt.length>280?'...':''}</div>`);
      slog('BNCA generated via live AI','lok');
    } else {
      sout('bnca', sc.bnca);
      slog('BNCA generated (scenario)','lok');
    }
  } catch {
    fstep(3,'done');spanel('bnca','active');
    sout('bnca', sc.bnca);
    slog('BNCA generated (scenario)','lok');
  }
  document.getElementById('fc3').className='fconn done';

  // Step 5 — HITL
  await delay(500);fstep(4,'go');
  slog('HITL Manager: BNCA queued for agent review...');
  await delay(700);
  fstep(4,'done');
  slog('HITL review complete · action approved','lok');
  document.getElementById('fc4').className='fconn done';

  // Step 6 — agent acts
  await delay(400);fstep(5,'go');
  slog('Agent: executing BNCA action · audit trail timestamped...');
  await delay(600);
  fstep(5,'done');
  slog('── Intelligence cycle complete · 100% audit trail ──','lok');

  document.getElementById('simstatus').textContent='cycle complete ✓';
  running=false;
  document.getElementById('runbtn').disabled=false;
  document.getElementById('runbtn').textContent='▶ Run again';
}

