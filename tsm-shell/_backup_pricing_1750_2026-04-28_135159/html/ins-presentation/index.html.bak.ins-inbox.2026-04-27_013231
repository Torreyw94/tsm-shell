<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TSM · Insurance Intelligence Suite · Live Executive Demo</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0a0b0d;
  --surface:#111318;
  --surface2:#181c22;
  --border:#1f2535;
  --gold:#C9A84C;
  --gold-dim:#8A6E28;
  --gold-bright:#E8C870;
  --gold-pale:#F5DFA0;
  --teal:#1a9e8a;
  --teal-bright:#3BBFAF;
  --amber:#EF9F27;
  --amber-dim:#BA7517;
  --red:#E24B4A;
  --green:#1D9E75;
  --green-bright:#5DCAA5;
  --text:#e8ede6;
  --text-dim:#7a8f88;
  --text-muted:#3d4f48;
}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'JetBrains Mono',monospace}
.deck{width:100vw;height:100vh;position:relative}
.slide{position:absolute;inset:0;display:flex;flex-direction:column;padding:56px 72px;opacity:0;pointer-events:none;transition:opacity .4s ease}
.slide.active{opacity:1;pointer-events:all}
.nav{position:fixed;bottom:32px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:100}
.pip{width:6px;height:6px;border-radius:50%;background:var(--text-muted);transition:all .3s;cursor:pointer}
.pip.on{background:var(--gold);width:18px;border-radius:3px}
.nav-arrows{position:fixed;bottom:28px;right:48px;display:flex;gap:8px;z-index:100}
.arr{background:transparent;border:.5px solid var(--border);color:var(--text-dim);padding:6px 14px;font-family:'JetBrains Mono',monospace;font-size:12px;cursor:pointer;border-radius:4px;transition:all .2s}
.arr:hover{border-color:var(--gold);color:var(--gold)}
.slide-num{position:fixed;top:28px;right:48px;font-size:11px;color:var(--text-muted);letter-spacing:.08em}
.tag{display:inline-block;font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:3px 10px;border-radius:3px;border:.5px solid var(--border);color:var(--text-dim)}
.tag.live{border-color:var(--gold);color:var(--gold-pale);background:rgba(201,168,76,.08)}
.tag.med{border-color:var(--teal);color:var(--teal-bright);background:rgba(26,158,138,.07)}
.tag.high{border-color:var(--amber);color:var(--amber);background:rgba(239,159,39,.07)}
.divider{height:.5px;background:var(--border);margin:28px 0}

/* SLIDE 1 */
#s1{justify-content:center}
.s1-eyebrow{display:flex;gap:12px;align-items:center;margin-bottom:32px;flex-wrap:wrap}
.s1-title{font-family:'Syne',sans-serif;font-size:68px;font-weight:800;line-height:.95;letter-spacing:-.02em;color:var(--text);margin-bottom:16px}
.s1-title span{color:var(--gold)}
.s1-sub{font-size:14px;color:var(--text-dim);line-height:1.8;max-width:580px;margin-bottom:48px}
.s1-stats{display:flex;gap:48px}
.s1-stat .n{font-size:36px;font-weight:700;color:var(--gold-bright)}
.s1-stat .l{font-size:11px;color:var(--text-dim);letter-spacing:.06em;margin-top:4px}
.s1-ticker{position:absolute;bottom:56px;left:72px;right:72px;display:flex;align-items:center;gap:16px;border-top:.5px solid var(--border);padding-top:20px}
.ticker-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);animation:blink 1.4s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.ticker-text{font-size:12px;color:var(--text-dim)}
.ticker-val{color:var(--gold-pale);font-weight:500}

/* SLIDE 2 */
#s2{justify-content:center}
.s2-head{font-family:'Syne',sans-serif;font-size:40px;font-weight:800;line-height:1.1;margin-bottom:8px}
.s2-head em{color:var(--amber);font-style:normal}
.s2-deck{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:32px}
.prob-card{background:var(--surface);border:.5px solid var(--border);border-radius:8px;padding:20px 24px;position:relative;overflow:hidden}
.prob-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%}
.prob-card.p1::before{background:var(--red)}
.prob-card.p2::before{background:var(--amber)}
.prob-card.p3::before{background:var(--teal)}
.prob-card.p4::before{background:var(--gold)}
.prob-card .pc-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px}
.prob-card .pc-val{font-size:26px;font-weight:700;margin-bottom:4px}
.prob-card.p1 .pc-val{color:var(--red)}
.prob-card.p2 .pc-val{color:var(--amber)}
.prob-card.p3 .pc-val{color:var(--teal-bright)}
.prob-card.p4 .pc-val{color:var(--gold-bright)}
.prob-card .pc-desc{font-size:12px;color:var(--text-dim);line-height:1.6}

/* SLIDE 3 */
#s3{justify-content:center}
.s3-head{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;margin-bottom:28px}
.arch-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.arch-node{background:var(--surface);border:.5px solid var(--border);border-radius:8px;padding:18px 12px;text-align:center;position:relative}
.arch-node.hub{border-color:var(--gold);background:rgba(201,168,76,.05)}
.arch-node.med-node{border-color:var(--teal);background:rgba(26,158,138,.05)}
.arch-num{font-size:10px;color:var(--text-muted);margin-bottom:10px;letter-spacing:.08em}
.arch-icon{font-size:20px;margin-bottom:10px;display:block}
.arch-name{font-size:12px;font-weight:500;color:var(--text);margin-bottom:5px;line-height:1.3}
.arch-route{font-size:9.5px;color:var(--text-muted);line-height:1.5}
.arch-arrow{position:absolute;right:-7px;top:50%;transform:translateY(-50%);color:var(--gold);font-size:11px;z-index:1}
.arch-flow{margin-top:20px;background:var(--surface);border:.5px solid var(--border);border-radius:6px;padding:14px 20px;display:flex;align-items:center;gap:12px;font-size:12px;color:var(--text-dim);flex-wrap:wrap}
.arch-flow strong{color:var(--gold-pale)}

/* SLIDE 4 - SIM */
#s4{padding:24px 56px;height:100vh;overflow:hidden;display:flex;flex-direction:column}
.s4-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-shrink:0}
.s4-title{font-family:'Syne',sans-serif;font-size:26px;font-weight:800}
.aud-tabs{display:flex;gap:6px;margin-bottom:10px;flex-shrink:0}
.aud-tab{font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:5px 14px;border-radius:4px;border:.5px solid var(--border);color:var(--text-muted);cursor:pointer;transition:all .2s;font-family:'JetBrains Mono',monospace}
.aud-tab:hover{border-color:var(--gold);color:var(--gold)}
.aud-tab.active{border-color:var(--gold);color:var(--gold-pale);background:rgba(201,168,76,.08)}
.sim-wrap{display:grid;grid-template-columns:1fr 1fr;gap:8px;flex:1;min-height:0}
.sim-panel{background:var(--surface);border:.5px solid var(--border);border-radius:8px;padding:16px;display:flex;flex-direction:column;gap:10px}
.sim-panel.active-panel{border-color:var(--gold)}
.sim-panel.firing-panel{border-color:var(--amber)}
.panel-header{display:flex;align-items:center;gap:8px}
.pdot{width:6px;height:6px;border-radius:50%;background:var(--text-muted);flex-shrink:0;transition:background .3s}
.pdot.live{background:var(--gold)}
.pdot.firing{background:var(--amber);animation:blink .6s infinite}
.panel-name{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-dim)}
.panel-route{font-size:10px;color:var(--text-muted)}
.panel-out{font-size:11px;color:var(--text-dim);line-height:1.7;flex:1}
.panel-out .pv{color:var(--text);font-weight:500}
.panel-out .pg{color:var(--gold-pale);border-left:2px solid var(--gold);padding-left:8px;margin-top:6px;font-size:10px;line-height:1.6}
.panel-out .pm{display:inline-block;background:var(--surface2);border:.5px solid var(--border);border-radius:4px;padding:3px 8px;font-size:11px;margin:2px 2px 0 0}
.panel-out .pm span{color:var(--gold-bright);font-weight:500;display:block;font-size:13px}
.panel-out .pm small{color:var(--text-muted);font-size:9px}
.flow-row{display:flex;align-items:center;gap:0;margin-bottom:12px}
.fstep{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1}
.fnode{width:26px;height:26px;border-radius:50%;border:.5px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--text-muted);transition:all .3s}
.fnode.done{background:var(--gold-dim);border-color:var(--gold);color:var(--gold-pale)}
.fnode.go{background:rgba(239,159,39,.15);border-color:var(--amber);color:var(--amber);animation:blink .6s infinite}
.flabel{font-size:8px;color:var(--text-muted);text-align:center;max-width:58px;line-height:1.3}
.flabel.done{color:var(--gold)}
.fconn{flex:1;height:.5px;background:var(--border);margin-top:-14px;transition:background .4s}
.fconn.done{background:var(--gold)}
.sim-log{background:var(--surface2);border:.5px solid var(--border);border-radius:6px;padding:6px 12px;height:48px;overflow-y:auto;font-size:10px;line-height:1.6;flex-shrink:0}
.ll{display:flex;gap:10px}
.lt{color:var(--text-muted);flex-shrink:0}
.lok{color:var(--gold)}
.lwarn{color:var(--amber)}
.sim-btns{display:flex;gap:8px;align-items:center;margin-top:8px;flex-shrink:0;flex-wrap:wrap}
.btn-primary{padding:8px 22px;font-size:11px;font-family:'JetBrains Mono',monospace;font-weight:500;cursor:pointer;border-radius:4px;border:.5px solid var(--gold);background:rgba(201,168,76,.1);color:var(--gold-pale);transition:all .2s;letter-spacing:.04em}
.btn-primary:hover{background:rgba(201,168,76,.2)}
.btn-primary:disabled{opacity:.35;cursor:not-allowed}
.btn-sec{padding:8px 14px;font-size:11px;font-family:'JetBrains Mono',monospace;cursor:pointer;border-radius:4px;border:.5px solid var(--border);background:transparent;color:var(--text-dim);transition:all .2s}
.btn-sec:hover{border-color:var(--text-dim);color:var(--text)}
.btn-app{padding:6px 12px;font-size:10px;font-family:'JetBrains Mono',monospace;cursor:pointer;border-radius:4px;border:.5px solid var(--teal);background:rgba(26,158,138,.08);color:var(--teal-bright);transition:all .2s;text-decoration:none;display:inline-block}
.btn-app:hover{background:rgba(26,158,138,.18)}
.sim-status{font-size:11px;color:var(--text-muted);margin-left:auto}

/* SLIDE 5 */
#s5{justify-content:center}
.s5-head{font-family:'Syne',sans-serif;font-size:46px;font-weight:800;line-height:1.05;margin-bottom:8px}
.s5-head span{color:var(--gold)}
.s5-sub{font-size:13px;color:var(--text-dim);margin-bottom:32px}
.outcome-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.oc{background:var(--surface);border:.5px solid var(--border);border-radius:8px;padding:18px 18px 14px}
.oc-n{font-size:32px;font-weight:700;color:var(--gold-bright);margin-bottom:4px}
.oc-l{font-size:11px;color:var(--text-dim);letter-spacing:.04em;line-height:1.5}
.oc.teal .oc-n{color:var(--teal-bright)}
.outcome-bar{background:var(--surface);border:.5px solid var(--border);border-radius:8px;padding:18px 22px}
.ob-row{display:flex;align-items:center;gap:16px;padding:7px 0;border-bottom:.5px solid var(--border)}
.ob-row:last-child{border-bottom:none}
.ob-label{font-size:11px;color:var(--text-dim);width:200px;flex-shrink:0}
.ob-track{flex:1;height:4px;background:var(--surface2);border-radius:2px;overflow:hidden}
.ob-fill{height:100%;border-radius:2px;background:var(--gold);transition:width 1.2s ease}
.ob-fill.teal{background:var(--teal)}
.ob-val{font-size:12px;font-weight:500;color:var(--gold-pale);width:70px;text-align:right}
.s5-footer{margin-top:24px;display:flex;gap:32px;align-items:center}
.s5-footer .tsm{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--text)}
.s5-footer .tsm span{color:var(--gold)}
.s5-footer p{font-size:12px;color:var(--text-muted);line-height:1.6}

/* SLIDE 6 - TALK TRACK */
#s6{justify-content:flex-start;padding:40px 56px;overflow-y:auto}
.aud-selector{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.aud-btn{font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:5px 14px;border-radius:4px;border:.5px solid var(--border);color:var(--text-muted);cursor:pointer;transition:all .2s;font-family:'JetBrains Mono',monospace;background:transparent}
.aud-btn:hover{border-color:var(--gold);color:var(--gold)}
.aud-btn.active{border-color:var(--gold);color:var(--gold-pale);background:rgba(201,168,76,.08)}
.tt-progress{display:flex;gap:5px;margin-bottom:16px;flex-wrap:wrap}
.tt-pip{height:3px;flex:1;min-width:14px;border-radius:2px;background:var(--text-muted);transition:background .3s}
.tt-pip.done{background:var(--gold-dim)}
.tt-pip.active{background:var(--gold)}
.tt-card{background:var(--surface);border:.5px solid var(--border);border-radius:8px;padding:22px;min-height:240px;margin-bottom:14px}
.tt-step-label{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px}
.tt-step-title{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;color:var(--text);margin-bottom:12px;line-height:1.1}
.tt-action{display:inline-block;font-size:11px;color:var(--amber);background:rgba(239,159,39,.07);border:.5px solid var(--amber-dim);border-radius:4px;padding:5px 12px;margin-bottom:12px;letter-spacing:.04em}
.tt-say{border-left:2px solid var(--gold);padding:9px 14px;background:var(--surface2);border-radius:0 6px 6px 0;margin-bottom:7px}
.tt-say p{font-size:13px;line-height:1.8;color:var(--text-dim)}
.tt-say p .money{color:var(--gold-bright);font-weight:500}
.tt-say p .med{color:var(--teal-bright);font-weight:500}
.tt-tip{font-size:11px;color:var(--amber);background:rgba(239,159,39,.07);border-radius:4px;padding:7px 12px;margin-top:8px;border:.5px solid rgba(239,159,39,.2)}
.tt-obj{border:.5px solid var(--border);border-radius:6px;margin-top:7px;overflow:hidden}
.tt-obj-q{padding:10px 14px;font-size:12px;color:var(--text-dim);cursor:pointer;display:flex;justify-content:space-between;letter-spacing:.02em}
.tt-obj-q:hover{background:var(--surface2)}
.tt-obj-a{display:none;padding:10px 14px;font-size:12px;color:var(--text);line-height:1.7;border-top:.5px solid var(--border);background:var(--bg)}
.tt-obj-a.open{display:block}
.tt-nav{display:flex;gap:10px;align-items:center}
.tt-btn-p{padding:8px 22px;font-size:12px;font-family:'JetBrains Mono',monospace;font-weight:500;cursor:pointer;border-radius:4px;border:.5px solid var(--gold);background:rgba(201,168,76,.1);color:var(--gold-pale);transition:all .2s;letter-spacing:.04em}
.tt-btn-p:hover{background:rgba(201,168,76,.2)}
.tt-btn-g{padding:8px 16px;font-size:12px;font-family:'JetBrains Mono',monospace;cursor:pointer;border-radius:4px;border:.5px solid var(--border);background:transparent;color:var(--text-dim);transition:all .2s}
.tt-btn-g:hover{border-color:var(--text-dim);color:var(--text)}
.tt-counter{margin-left:auto;font-size:11px;color:var(--text-muted)}
</style>
</head>
<body>
<div class="deck">
<!-- SLIDE 1 · COVER -->
<div class="slide active" id="s1">
  <div class="s1-eyebrow">
    <span class="tag live">LIVE SUITE</span>
    <span class="tag med">NPN 18818059 · Licensed AZ Producer</span>
    <span class="tag high">5 APPS · ALL LINES</span>
  </div>
  <div class="s1-title">TSM<br/><span>Insurance</span><br/>Intelligence</div>
  <div class="s1-sub">Five AI-powered apps — AZ Insurance Command, DME Benefits Engine, Agents Intelligence, P&C Enterprise Command, and Pricing — coordinated into a single insurance intelligence loop for agents, agencies, brokers, and Medicare.</div>
  <div class="s1-stats">
    <div class="s1-stat"><div class="n">$2,400</div><div class="l">Avg unclaimed DME benefit per Medicare client</div></div>
    <div class="s1-stat"><div class="n">&lt; 60s</div><div class="l">Client question to BNCA output</div></div>
    <div class="s1-stat"><div class="n">5</div><div class="l">Live apps · all lines of business</div></div>
  </div>
  <div class="s1-ticker">
    <div class="ticker-dot"></div>
    <div class="ticker-text">Live · Medicare denial rate <span class="ticker-val">18.4% vs 9% target</span> · Unclaimed DME per book <span class="ticker-val">avg $2,400</span> · Agent ramp time <span class="ticker-val">cut 3x</span> · P&C renewal leakage <span class="ticker-val">-22%</span> · Compliance flags <span class="ticker-val">caught at intake</span></div>
  </div>
</div>

<!-- SLIDE 2 · PROBLEM -->
<div class="slide" id="s2">
  <div class="s2-head">Insurance has<br/><em>four failure points.</em><br/>TSM closes all of them.</div>
  <div class="divider"></div>
  <div class="s2-deck">
    <div class="prob-card p1">
      <div class="pc-label">Independent agents · daily reality</div>
      <div class="pc-val">Portal hell</div>
      <div class="pc-desc">Agents toggle between 8–12 carrier portals per day. No unified view. Carrier rules change without notice. Medicare compliance windows missed. E&O exposure grows silently.</div>
    </div>
    <div class="prob-card p2">
      <div class="pc-label">Agencies & IMOs · production gap</div>
      <div class="pc-val">6-month ramp</div>
      <div class="pc-desc">New agents average 6 months to first meaningful production. Senior agents miss 18–25% of cross-sell revenue in existing book. No AI layer to surface what's already there.</div>
    </div>
    <div class="prob-card p3">
      <div class="pc-label">Medicare · DME benefit gap</div>
      <div class="pc-val">$2,400 left</div>
      <div class="pc-desc">Average Medicare beneficiary leaves $2,400 in Part B DME benefits unclaimed annually. CPAP, CGM, oxygen, wheelchairs — agents don't check. Clients don't know. Nobody wins.</div>
    </div>
    <div class="prob-card p4">
      <div class="pc-label">TSM response · BNCA engine</div>
      <div class="pc-val">All 5 apps live</div>
      <div class="pc-desc">Every client question, every document, every compliance check routes through the AI node pipeline — Compliance, Coverage, Claims, Risk — and returns a single actionable BNCA in under 60 seconds.</div>
    </div>
  </div>
</div>

<!-- SLIDE 3 · ARCHITECTURE -->
<div class="slide" id="s3">
  <div class="s3-head">Five apps.<br/>One intelligence loop.</div>
  <div class="arch-grid">
    <div class="arch-node hub">
      <div class="arch-num">01</div>
      <div class="arch-icon">🏛</div>
      <div class="arch-name">AZ Insurance Command</div>
      <div class="arch-route">Medicare · ACA · P&C · Life<br/>Compliance · Carrier Intel<br/>Full multi-line dashboard</div>
      <div class="arch-arrow">→</div>
    </div>
    <div class="arch-node med-node">
      <div class="arch-num">02</div>
      <div class="arch-icon">💊</div>
      <div class="arch-name">DME Benefits Engine</div>
      <div class="arch-route">Medicare Part B checker<br/>8 DME categories<br/>Client-facing eligibility</div>
      <div class="arch-arrow">→</div>
    </div>
    <div class="arch-node">
      <div class="arch-num">03</div>
      <div class="arch-icon">🤝</div>
      <div class="arch-name">Agents Intelligence</div>
      <div class="arch-route">Agent · Agency · Carrier<br/>Cross-sell engine<br/>Compliance AI · Training</div>
      <div class="arch-arrow">→</div>
    </div>
    <div class="arch-node">
      <div class="arch-num">04</div>
      <div class="arch-icon">🏢</div>
      <div class="arch-name">P&C Enterprise Command</div>
      <div class="arch-route">Quote pipeline · Risk scoring<br/>Renewal engine<br/>Loss ratio analytics</div>
      <div class="arch-arrow">→</div>
    </div>
    <div class="arch-node hub">
      <div class="arch-num">05</div>
      <div class="arch-icon">⚡</div>
      <div class="arch-name">BNCA Engine · HITL</div>
      <div class="arch-route">Compliance · Coverage<br/>Claims · Risk nodes<br/>Human approval · Audit trail</div>
    </div>
  </div>
  <div class="arch-flow">
    <span style="color:var(--text-muted)">Client question or document →</span>
    <strong>4 AI nodes fire in parallel</strong>
    <span style="color:var(--text-muted)">→ Insurance Strategist synthesizes →</span>
    <strong>BNCA generated</strong>
    <span style="color:var(--text-muted)">→ HITL reviews →</span>
    <strong>Agent acts · audit trail complete</strong>
  </div>
</div>
<!-- SLIDE 4 · LIVE SIM -->
<div class="slide" id="s4" style="gap:12px">
  <div class="s4-head">
    <div class="s4-title">Live intelligence — watch it run</div>
    <div style="display:flex;gap:8px">
      <span class="tag live">LIVE · tsm-shell.fly.dev</span>
      <span class="tag med">NPN 18818059</span>
    </div>
  </div>
  <div class="aud-tabs">
    <div class="aud-tab active" onclick="setAud('medicare',this)">Medicare Agent</div>
    <div class="aud-tab" onclick="setAud('agency',this)">Agency / IMO</div>
